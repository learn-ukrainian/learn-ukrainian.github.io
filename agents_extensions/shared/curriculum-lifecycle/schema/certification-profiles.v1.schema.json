{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "curriculum-certification-profiles.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["config_version", "selectors", "profiles"],
  "properties": {
    "config_version": {"const": "curriculum-certification.v1"},
    "selectors": {"$ref": "#/$defs/selectors"},
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {"^[a-z][a-z0-9-]+$": {"$ref": "#/$defs/profile"}},
      "additionalProperties": false
    }
  },
  "$defs": {
    "profileId": {"type": "string", "pattern": "^[a-z][a-z0-9-]+$"},
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9][A-Za-z0-9._/-]*$"
    },
    "selectors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tracks", "manifest_types"],
      "properties": {
        "tracks": {"$ref": "#/$defs/selectorMap"},
        "manifest_types": {"$ref": "#/$defs/selectorMap"}
      }
    },
    "selectorMap": {
      "type": "object",
      "patternProperties": {"^[a-z][a-z0-9-]+$": {"$ref": "#/$defs/profileId"}},
      "additionalProperties": false
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "family", "readiness_profile", "pbr", "independent_review", "integration", "production_qg"],
      "properties": {
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "family": {"enum": ["core", "seminar"]},
        "readiness_profile": {"$ref": "#/$defs/profileId"},
        "pbr": {
          "type": "object",
          "additionalProperties": false,
          "required": ["adapter", "required"],
          "properties": {"adapter": {"const": "post-build-review.v4"}, "required": {"const": true}}
        },
        "independent_review": {"$ref": "#/$defs/mutationGate"},
        "integration": {"$ref": "#/$defs/mutationGate"},
        "production_qg": {"$ref": "#/$defs/productionQG"}
      }
    },
    "mutationGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_for_mutation"],
      "properties": {"required_for_mutation": {"const": true}}
    },
    "productionQG": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter", "mode"],
      "properties": {
        "adapter": {"const": "production-qg.v1"},
        "mode": {"enum": ["disabled", "pending", "armed-canary"]},
        "qualification_artifact": {"$ref": "#/$defs/repositoryPath"},
        "human_arming_artifact": {"$ref": "#/$defs/repositoryPath"}
      },
      "allOf": [
        {
          "if": {"properties": {"mode": {"const": "armed-canary"}}},
          "then": {"required": ["qualification_artifact", "human_arming_artifact"]},
          "else": {"not": {"anyOf": [{"required": ["qualification_artifact"]}, {"required": ["human_arming_artifact"]}]}}
        }
      ]
    }
  }
}
