{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "curriculum-coordinator-config.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "config_version",
    "manifest_path",
    "runtime_root",
    "lease_seconds",
    "default_wave_size",
    "maximum_wave_size",
    "health"
  ],
  "properties": {
    "config_version": {"const": "curriculum-coordinator.v1"},
    "manifest_path": {"const": "curriculum/l2-uk-en/curriculum.yaml"},
    "runtime_root": {"const": "batch_state/curriculum-lifecycle"},
    "lease_seconds": {"type": "integer", "minimum": 60, "maximum": 86400},
    "default_wave_size": {"type": "integer", "minimum": 1},
    "maximum_wave_size": {"type": "integer", "minimum": 1, "maximum": 100},
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acceptable_statuses", "require_fresh_snapshot", "capability_groups"],
      "properties": {
        "acceptable_statuses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["cool", "warm", "hot"]}
        },
        "require_fresh_snapshot": {"type": "boolean"},
        "capability_groups": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/capabilityGroup"}
        }
      }
    }
  },
  "$defs": {
    "identifier": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "capabilityGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "lanes", "minimum_available"],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "lanes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/identifier"}
        },
        "minimum_available": {"type": "integer", "minimum": 1}
      }
    }
  }
}
