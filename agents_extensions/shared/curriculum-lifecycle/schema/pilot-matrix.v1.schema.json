{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "curriculum-lifecycle-pilot-matrix.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mode", "identity_paths", "rows"],
  "properties": {
    "schema_version": {"const": "curriculum-lifecycle-pilot-matrix.v1"},
    "mode": {"const": "shadow"},
    "identity_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/path"}
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/row"}
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "hash": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
    "path": {
      "type": "string",
      "minLength": 1,
      "not": {"pattern": "(^/|^~|(^|/)\\.\\.(/|$)|\\\\)"}
    },
    "selector": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*/[a-z0-9][a-z0-9-]*$"},
    "expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module_state",
        "preparation_state",
        "state",
        "next_action",
        "disposition",
        "cleanup_state"
      ],
      "properties": {
        "module_state": {"enum": ["built", "unbuilt", "partial", "fixture"]},
        "preparation_state": {"enum": ["current", "missing", "stale", "fixture"]},
        "state": {"$ref": "#/$defs/id"},
        "next_action": {"$ref": "#/$defs/id"},
        "disposition": {"$ref": "#/$defs/id"},
        "cleanup_state": {"enum": ["unchanged", "not-required"]}
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event", "from", "to"],
      "properties": {
        "event": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"},
        "from": {"$ref": "#/$defs/id"},
        "to": {"$ref": "#/$defs/id"}
      }
    },
    "promptAssertions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "forbidden"],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "forbidden": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue", "pull_request", "merge_sha", "outcome"],
      "properties": {
        "issue": {"type": "integer", "minimum": 1},
        "pull_request": {"type": "integer", "minimum": 1},
        "merge_sha": {"$ref": "#/$defs/hash"},
        "outcome": {"enum": ["material-repair-pass", "minimal-repair-pass"]}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind"],
      "properties": {
        "path": {"$ref": "#/$defs/path"},
        "kind": {"enum": ["post-build-review-pass"]}
      }
    },
    "wave": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "position"],
      "properties": {
        "id": {"const": "folk-m01-m03"},
        "position": {"type": "integer", "minimum": 1, "maximum": 3}
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "scenario",
        "selector",
        "family",
        "expected",
        "transitions",
        "resume_evidence"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "kind": {"enum": ["repository", "historical", "fixture"]},
        "scenario": {"$ref": "#/$defs/id"},
        "selector": {"$ref": "#/$defs/selector"},
        "family": {"enum": ["core", "seminar", "fixture"]},
        "prompt_profile": {"$ref": "#/$defs/id"},
        "prompt_assertions": {"$ref": "#/$defs/promptAssertions"},
        "expected": {"$ref": "#/$defs/expectation"},
        "transitions": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/transition"}
        },
        "resume_evidence": {"type": "string", "pattern": "^[a-zA-Z0-9_.:-]+$"},
        "wave": {"$ref": "#/$defs/wave"},
        "provenance": {"$ref": "#/$defs/provenance"},
        "evidence": {"$ref": "#/$defs/evidence"}
      },
      "allOf": [
        {
          "if": {"properties": {"kind": {"enum": ["repository", "historical"]}}},
          "then": {"required": ["prompt_profile", "prompt_assertions"]}
        },
        {
          "if": {"properties": {"kind": {"const": "historical"}}},
          "then": {"required": ["provenance"]},
          "else": {"not": {"required": ["provenance"]}}
        },
        {
          "if": {"properties": {"kind": {"const": "fixture"}}},
          "then": {
            "properties": {
              "family": {"const": "fixture"},
              "expected": {
                "properties": {
                  "module_state": {"const": "fixture"},
                  "preparation_state": {"const": "fixture"}
                }
              }
            }
          }
        }
      ]
    }
  }
}
