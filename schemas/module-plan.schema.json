{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://learn-ukrainian.github.io/schemas/module-plan.schema.json",
  "title": "Module Plan",
  "description": "Schema for individual module plans (plans/{level}/{slug}.yaml)",
  "type": "object",
  "required": ["module", "level", "sequence", "version", "title", "focus", "pedagogy", "objectives", "content_outline", "word_target"],
  "properties": {
    "module": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Module slug (e.g., 01-how-to-talk-about-grammar)"
    },
    "level": {
      "type": "string",
      "pattern": "^([Aa]1|[Aa]2|[Bb]1|[Bb]2|[Cc]1|[Cc]2|[Bb]2-[Hh][Ii][Ss][Tt]|[Bb]2-[Pp][Rr][Oo]|[Cc]1-[Bb][Ii][Oo]|[Cc]1-[Hh][Ii][Ss][Tt]|[Cc]1-[Pp][Rr][Oo]|[Cc]2-[Pp][Rr][Oo]|[Ll][Ii][Tt])$"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1,
      "description": "Module number within the level"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "title": {
      "type": "string",
      "description": "Module title in Ukrainian"
    },
    "subtitle": {
      "type": "string",
      "description": "Optional English subtitle"
    },
    "focus": {
      "type": "string",
      "enum": ["grammar", "vocabulary", "cultural", "history", "biography", "literature", "integration", "checkpoint", "professional"],
      "description": "Primary focus of the module"
    },
    "pedagogy": {
      "type": "string",
      "enum": ["TTT", "PPP", "seminar", "workshop", "review"],
      "description": "Teaching approach"
    },
    "objectives": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Learning objectives"
    },
    "content_outline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["section", "words"],
        "properties": {
          "section": {
            "type": "string",
            "description": "Section title (will become H2 header)"
          },
          "words": {
            "type": "integer",
            "minimum": 0,
            "description": "Target word count for this section"
          },
          "subsections": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "H3 subsections within this section"
          },
          "key_concepts": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Key concepts/vocabulary to introduce"
          },
          "primary_sources": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Required primary source excerpts (for history/lit modules)"
          }
        }
      },
      "minItems": 1
    },
    "word_target": {
      "type": "integer",
      "minimum": 500,
      "description": "Total word count target (excluding summary)"
    },
    "word_tolerance": {
      "type": "number",
      "minimum": 0,
      "maximum": 0.2,
      "default": 0.05,
      "description": "Acceptable tolerance (e.g., 0.05 = ±5%)"
    },
    "vocabulary": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Words that MUST appear in content"
        },
        "recommended": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Words that MAY appear"
        },
        "forbidden": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Words that MUST NOT appear (too advanced)"
        }
      }
    },
    "activities": {
      "type": "object",
      "required": ["types_required", "min_items_per_type"],
      "properties": {
        "types_required": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "quiz", "fill-in", "match-up", "true-false", "unjumble",
              "group-sort", "anagram", "error-correction", "cloze",
              "select", "translate", "mark-the-words", "highlight-morphemes",
              "essay-response", "comparative-study", "reading",
              "critical-analysis", "authorial-intent"
            ]
          },
          "description": "Activity types that must be present"
        },
        "min_items_per_type": {
          "type": "integer",
          "minimum": 1,
          "description": "Minimum items for each required type"
        },
        "total_min_items": {
          "type": "integer",
          "minimum": 1,
          "description": "Minimum total activity items"
        },
        "no_mirroring": {
          "type": "boolean",
          "default": true,
          "description": "Activities must not copy lesson text verbatim"
        }
      }
    },
    "dialogue_situations": {
      "type": "array",
      "description": "Unique dialogue settings with specific objects and genders. See docs/best-practices/dialogue-situations.md",
      "items": {
        "type": "object",
        "required": ["setting", "speakers", "motivation"],
        "properties": {
          "setting": {
            "type": "string",
            "minLength": 30,
            "description": "WHERE + WHAT: specific location and objects with gender labels (m/f/n/pl)"
          },
          "speakers": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "Speaker names with roles in Ukrainian"
          },
          "motivation": {
            "type": "string",
            "description": "WHY: which grammar this setting naturally produces"
          }
        },
        "additionalProperties": false
      }
    },
    "reading_situations": {
      "type": "array",
      "description": "B2+ analytical reading passages. See docs/best-practices/b2-c2-plan-architecture.md",
      "items": {
        "type": "object",
        "required": ["source_type", "topic", "motivation"],
        "properties": {
          "source_type": { "type": "string", "description": "e.g., 'наукова стаття', 'художній уривок', 'офіційний лист'" },
          "topic": { "type": "string", "description": "What the text is about" },
          "key_elements": { "type": "array", "items": { "type": "string" }, "description": "Terms or devices to include" },
          "motivation": { "type": "string", "description": "Why this text motivates the grammar/focus" }
        },
        "additionalProperties": false
      }
    },
    "listening_situations": {
      "type": "array",
      "description": "B2+ listening comprehension tasks. See docs/best-practices/b2-c2-plan-architecture.md",
      "items": {
        "type": "object",
        "required": ["media_type", "setting", "motivation"],
        "properties": {
          "media_type": { "type": "string", "enum": ["відео", "аудіо", "інтерв'ю", "подкаст", "лекція"] },
          "setting": { "type": "string", "description": "Context of the recording" },
          "focus_points": { "type": "array", "items": { "type": "string" }, "description": "What to capture" },
          "motivation": { "type": "string", "description": "Pedagogical goal" }
        },
        "additionalProperties": false
      }
    },
    "writing_tasks": {
      "type": "array",
      "description": "B2+ structured production tasks. See docs/best-practices/b2-c2-plan-architecture.md",
      "items": {
        "type": "object",
        "required": ["task_type", "prompt", "motivation"],
        "properties": {
          "task_type": { "type": "string", "enum": ["есе", "офіційний лист", "відгук", "репортаж", "власне висловлення"] },
          "prompt": { "type": "string", "description": "The assignment for the learner" },
          "requirements": { "type": "array", "items": { "type": "string" }, "description": "e.g., 'мінімум 200 слів', 'використати пасивний стан'" },
          "motivation": { "type": "string", "description": "Why this task?" }
        },
        "additionalProperties": false
      }
    },
    "discussion_topics": {
      "type": "array",
      "description": "B2+ oral production/debate prompts. See docs/best-practices/b2-c2-plan-architecture.md",
      "items": {
        "type": "object",
        "required": ["context", "questions", "motivation"],
        "properties": {
          "context": { "type": "string", "description": "Scenario or controversial statement for debate" },
          "questions": { "type": "array", "items": { "type": "string" }, "description": "Prompts for discussion" },
          "motivation": { "type": "string", "description": "Pedagogical goal" }
        },
        "additionalProperties": false
      }
    },
    "connects_to": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "previous": { "type": ["string", "null"] },
            "next": { "type": ["string", "null"] },
            "related": { "type": "array", "items": { "type": "string" } }
          }
        },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ],
      "description": "Links to related modules (object or array format)"
    },
    "constraints": {
      "type": "object",
      "properties": {
        "min_engagement_boxes": {
          "type": "integer",
          "minimum": 0
        },
        "min_examples": {
          "type": "integer",
          "minimum": 0
        },
        "immersion_target": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "naturalness_threshold": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "min_primary_sources": {
          "type": "integer",
          "minimum": 0,
          "description": "For history/literature modules"
        }
      },
      "description": "Override level constraints if needed"
    },
    "sources": {
      "type": ["object", "array"],
      "description": "Primary and secondary sources for content"
    },
    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "date", "changes"],
        "properties": {
          "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+$"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "changes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        }
      },
      "description": "Version history for plan changes (per Epic #465 review)"
    }
  },
  "additionalProperties": true
}
