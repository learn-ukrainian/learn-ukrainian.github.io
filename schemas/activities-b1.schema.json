      {
        "$ref": "#/definitions/cloze-b1"
      },
      {
        "$ref": "#/definitions/comparative-study-b1"
      },
      {
        "$ref": "#/definitions/critical-analysis-b1"
      },
      {
        "$ref": "#/definitions/error-correction-b1"
      },
      {
        "$ref": "#/definitions/essay-response-b1"
      },
      {
        "$ref": "#/definitions/fill-in-b1"
      },
      {
        "$ref": "#/definitions/group-sort-b1"
      },
      {
        "$ref": "#/definitions/mark-the-words-b1"
      },
      {
        "$ref": "#/definitions/match-up-b1"
      },
      {
        "$ref": "#/definitions/observe-b1"
      },
      {
        "$ref": "#/definitions/odd-one-out-b1"
      },
      {
        "$ref": "#/definitions/order-b1"
      },
      {
        "$ref": "#/definitions/phrase-table-b1"
      },
      {
        "$ref": "#/definitions/quiz-b1"
      },
      {
        "$ref": "#/definitions/reading-b1"
      },
      {
        "$ref": "#/definitions/select-b1"
      },
      {
        "$ref": "#/definitions/translate-b1"
      },
      {
        "$ref": "#/definitions/true-false-b1"
      },
      {
        "$ref": "#/definitions/unjumble-b1"
      }
    ]
  },
