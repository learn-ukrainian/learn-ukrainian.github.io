            "additionalProperties": false
          }
        },
        "title": {
          "type": "string",
          "description": "Optional display title for the activity"
        }
      },
      "additionalProperties": false
    },
    "classify-a2": {
      "type": "object",
      "required": [
        "type",
        "instruction",
        "categories"
      ],
      "properties": {
        "type": {
          "const": "classify"
        },
        "id": {
          "type": "string"
        },
        "instruction": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        },
        "categories": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": [
              "label",
              "items"
