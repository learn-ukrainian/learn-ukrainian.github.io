              "answer": {
                "type": "string",
                "minLength": 1,
                "description": "Correct option text for string-option quiz items"
              },
              "explanation": {
                "type": "string"
              }
            },
            "allOf": [
              {
                "anyOf": [
                  {
                    "required": [
                      "question"
                    ]
                  },
                  {
                    "required": [
                      "prompt"
                    ]
                  }
                ]
              },
              {
                "anyOf": [
                  {
                    "required": [
                      "correct"
                    ]
                  },
                  {
                    "required": [
                      "answer"
                    ]
