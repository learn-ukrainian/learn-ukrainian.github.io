            "properties": {
              "label": {
                "type": "string",
                "minLength": 1
              },
              "symbol_hint": {
                "type": "string"
              },
              "items": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          }
        },
        "title": {
          "type": "string",
          "description": "Optional display title for the activity"
        }
      },
      "additionalProperties": false
    },
    "cloze-a2": {
      "type": "object",
      "required": [
        "type",
        "instruction",
        "text"
      ],
      "properties": {
        "type": {
          "const": "cloze"
        },
        "id": {
          "type": "string"
        },
        "instruction": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "description": "Text with {gap} or {{N}} markers"
        },
        "options": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Global option pool (for simpler cloze)"
        },
        "blanks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "answer",
              "options"
            ],
            "properties": {
              "id": {
                "type": "integer",
                "minimum": 1
              },
              "answer": {
                "type": "string",
                "minLength": 1
              },
              "options": {
                "type": "array",
                "minItems": 2,
                "maxItems": 6,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          }
        },
        "title": {
          "type": "string",
          "description": "Optional display title for the activity"
        }
      },
      "additionalProperties": false
    },
    "error-correction-a2": {
      "type": "object",
      "required": [
        "type",
        "instruction",
        "items"
      ],
      "properties": {
        "type": {
          "const": "error-correction"
        },
        "id": {
          "type": "string"
        },
        "instruction": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "sentence",
              "error",
              "correction"
