      "type": "object",
      "required": [
        "type",
        "instruction",
        "items"
      ],
      "properties": {
        "type": {
          "const": "anagram"
        },
        "id": {
          "type": "string"
        },
        "instruction": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "letters",
              "answer"
            ],
            "properties": {
              "letters": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "string",
                  "minLength": 1
