                        "text",
                        "correct"
                      ],
                      "properties": {
                        "text": {
                          "type": "string",
                          "minLength": 1
                        },
                        "correct": {
                          "type": "boolean"
                        }
                      },
                      "additionalProperties": false
                    }
                  ]
                }
              },
