                        "maxItems": 6,
                        "items": {
                          "type": "object",
                          "required": [
                            "text",
                            "correct"
                          ],
                          "properties": {
                            "text": {
                              "type": "string",
                              "minLength": 1
                            },
                            "correct": {
                              "type": "boolean"
                            }
                          },
                          "additionalProperties": false
                        }
                      }
                    }
                  }
                ]
              }
            ],
            "additionalProperties": false
          }
        },
        "title": {
          "type": "string",
          "description": "Optional display title for the activity"
        }
      },
      "additionalProperties": false
    },
