            "additionalProperties": false
          }
        },
        "title": {
          "type": "string",
          "description": "Optional display title for the activity"
        }
      },
      "additionalProperties": false
    },
    "fill-in-a2": {
      "type": "object",
      "required": [
        "type",
        "instruction",
        "items"
      ],
      "properties": {
