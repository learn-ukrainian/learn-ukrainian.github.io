        "type",
        "instruction",
        "items"
      ],
      "properties": {
        "type": {
          "const": "error-correction"
        },
        "id": {
          "type": "string"
        },
        "instruction": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
