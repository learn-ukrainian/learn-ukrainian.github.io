            "properties": {
              "sentence": {
                "type": "string",
                "minLength": 1
              },
              "error": {
                "type": "string",
                "minLength": 1,
                "description": "The incorrect word or phrase"
              },
              "correction": {
                "type": "string",
                "minLength": 1,
                "description": "The correct replacement"
              },
              "error_type": {
                "type": "string",
                "enum": [
                  "word",
                  "phrase",
                  "register",
                  "construction"
                ]
              },
              "options": {
                "type": "array",
                "minItems": 2,
                "maxItems": 6,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "explanation": {
                "type": "string"
              }
