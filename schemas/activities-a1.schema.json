{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://learn-ukrainian.github.io/schemas/activities-a1.schema.json",
  "title": "A1 Module Activities",
  "description": "Activity schema for A1 level modules. Core activity types with basic requirements.",
  "type": "array",
  "items": {
    "oneOf": [
      {
        "$ref": "#/definitions/quiz-a1"
      },
      {
        "$ref": "#/definitions/match-up-a1"
      },
      {
        "$ref": "#/definitions/fill-in-a1"
      },
      {
        "$ref": "#/definitions/group-sort-a1"
      },
      {
        "$ref": "#/definitions/unjumble-a1"
      },
      {
        "$ref": "#/definitions/true-false-a1"
      },
      {
        "$ref": "#/definitions/anagram-a1"
      },
      {
        "$ref": "#/definitions/watch-and-repeat-a1"
      },
      {
        "$ref": "#/definitions/classify-a1"
      },
      {
        "$ref": "#/definitions/image-to-letter-a1"
      },
      {
        "$ref": "#/definitions/observe-a1"
      },
      {
        "$ref": "#/definitions/letter-grid-a1"
      },
      {
        "$ref": "#/definitions/translate-a1"
      },
      {
        "$ref": "#/definitions/error-correction-a1"
      }
    ]
  },
  "definitions": {
    "quiz-a1": {
      "type": "object",
      "required": [
        "type",
        "items"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "quiz"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": [
              "question",
              "options"
            ],
            "properties": {
              "question": {
                "type": "string",
                "minLength": 1
              },
              "options": {
                "type": "array",
                "minItems": 2,
                "maxItems": 8,
                "items": {
                  "oneOf": [
                    {
                      "type": "string",
                      "minLength": 1
                    },
                    {
                      "type": "object",
                      "required": [
                        "text",
                        "correct"
                      ],
                      "properties": {
                        "text": {
                          "type": "string",
                          "minLength": 1
                        },
                        "correct": {
                          "type": "boolean"
                        }
                      },
                      "additionalProperties": false
                    }
                  ]
                }
              },
              "correct": {
                "type": "integer",
                "minimum": 0,
                "description": "0-based index (V2 format)"
              },
              "explanation": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "instruction": {
          "type": "string",
          "description": "Additional instructions for the learner"
        },
        "vesum_exempt": {
          "type": "boolean",
          "description": "If true, VESUM checker skips distractor validation for this activity (e.g., spelling quizzes with intentional misspellings)"
        },
        "notes": {
          "type": "string",
          "description": "Internal notes about the activity (not shown to learners)"
        },
        "id": {
          "type": "string"
        }
      }
    },
    "match-up-a1": {
      "type": "object",
      "required": [
        "type",
        "pairs"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "match-up"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "instruction": {
          "type": "string",
          "description": "Additional instructions for the learner"
        },
        "pairs": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": [
              "left",
              "right"
            ],
            "additionalProperties": false,
            "properties": {
              "left": {
                "type": "string",
                "minLength": 1
              },
              "right": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "id": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "fill-in-a1": {
      "type": "object",
      "required": [
        "type",
        "items"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "fill-in"
        },
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "instruction": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": [
              "sentence",
              "answer"
            ],
            "additionalProperties": false,
            "properties": {
              "sentence": {
                "type": "string",
                "minLength": 1
              },
              "answer": {
                "type": "string",
                "minLength": 1
              },
              "options": {
                "type": "array",
                "minItems": 2,
                "maxItems": 8,
                "description": "Optional multiple-choice distractors; omit for open-ended fill-ins",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "explanation": {
                "type": "string"
              }
            }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "group-sort-a1": {
      "type": "object",
      "required": [
        "type",
        "groups"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "group-sort"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "instruction": {
          "type": "string",
          "description": "Additional instructions for the learner"
        },
        "groups": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": [
              "label",
              "items"
            ],
            "additionalProperties": false,
            "properties": {
              "items": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string"
              }
            }
          }
        },
        "id": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "properties": {
            "groups": {
              "description": "Total items across all groups must be >= 10"
            }
          }
        }
      ]
    },
    "unjumble-a1": {
      "type": "object",
      "required": [
        "type",
        "items"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "unjumble"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "oneOf": [
              {
                "required": [
                  "words",
                  "answer"
                ],
                "additionalProperties": false,
                "properties": {
                  "words": {
                    "type": "array",
                    "minItems": 3,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "answer": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              {
                "required": [
                  "words",
                  "correct_order"
                ],
                "additionalProperties": false,
                "properties": {
                  "words": {
                    "type": "array",
                    "minItems": 3,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "correct_order": {
                    "type": "array",
                    "minItems": 3,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            ]
          }
        },
        "instruction": {
          "type": "string",
          "description": "Additional instructions for the learner"
        },
        "id": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "true-false-a1": {
      "type": "object",
      "required": [
        "type",
        "items"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "true-false"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "instruction": {
          "type": "string",
          "description": "Additional instructions for the learner"
        },
        "items": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": [
              "statement",
              "correct"
            ],
            "additionalProperties": false,
            "properties": {
              "statement": {
                "type": "string",
                "minLength": 1
              },
              "correct": {
                "type": "boolean"
              },
              "explanation": {
                "type": "string"
              }
            }
          }
        },
        "id": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "anagram-a1": {
      "type": "object",
      "description": "A1 anagram — accepts both V1 (scrambled string) and V2 (letters array) formats",
      "required": [
        "type",
        "items"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "anagram"
        },
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "instruction": {
          "type": "string",
          "description": "Additional instructions for the learner"
        },
        "items": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": [
              "answer"
            ],
            "additionalProperties": false,
            "properties": {
              "scrambled": {
                "type": "string"
              },
              "letters": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "answer": {
                "type": "string",
                "minLength": 1
              },
              "hint": {
                "type": "string"
              }
            }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "watch-and-repeat-a1": {
      "type": "object",
      "description": "Cyrillic modules (1-4) only. Watch Anna Ohoiko video, repeat the sound/word aloud.",
      "required": [
        "type",
        "items"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "watch-and-repeat"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "instruction": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "video"
            ],
            "additionalProperties": false,
            "properties": {
              "letter": {
                "type": "string",
                "description": "The letter being demonstrated"
              },
              "word": {
                "type": "string",
                "description": "Example word being demonstrated"
              },
              "video": {
                "type": "string",
                "description": "YouTube URL for Anna Ohoiko pronunciation video"
              },
              "note": {
                "type": "string"
              }
            }
          }
        },
        "id": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "classify-a1": {
      "type": "object",
      "description": "Cyrillic modules (1-4) only. Sort letters into categories (vowel/consonant, voiced/voiceless).",
      "required": [
        "type",
        "categories"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "classify"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "instruction": {
          "type": "string"
        },
        "categories": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": [
              "label",
              "items"
            ],
            "additionalProperties": false,
            "properties": {
              "label": {
                "type": "string",
                "description": "Category label, e.g. Голосні, Приголосні"
              },
              "symbol_hint": {
                "type": "string",
                "description": "Hint for renderer, e.g. vowel, consonant"
              },
              "items": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "id": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "image-to-letter-a1": {
      "type": "object",
      "description": "Cyrillic modules (1-4) only. See an emoji — tap which letter the word starts with.",
      "required": [
        "type",
        "items"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "image-to-letter"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "instruction": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": [
              "emoji",
              "answer",
              "distractors"
            ],
            "additionalProperties": false,
            "properties": {
              "emoji": {
                "type": "string"
              },
              "answer": {
                "type": "string",
                "description": "The correct letter"
              },
              "distractors": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "string"
                }
              },
              "note": {
                "type": "string"
              }
            }
          }
        },
        "id": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "observe-a1": {
      "type": "object",
      "required": [
        "type",
        "examples",
        "prompt"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "observe"
        },
        "id": {
          "type": "string"
        },
        "instruction": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "examples": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        }
      }
    },
    "letter-grid-a1": {
      "type": "object",
      "required": [
        "type",
        "letters"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "letter-grid"
        },
        "id": {
          "type": "string"
        },
        "instruction": {
          "type": "string"
        },
        "letters": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "upper",
              "lower"
            ],
            "additionalProperties": false,
            "properties": {
              "upper": {
                "type": "string"
              },
              "lower": {
                "type": "string"
              },
              "emoji": {
                "type": "string"
              },
              "key_word": {
                "type": "string"
              },
              "sound_type": {
                "type": "string"
              }
            }
          }
        },
        "title": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "translate-a1": {
      "type": "object",
      "required": [
        "type",
        "instruction",
        "items"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "translate"
        },
        "id": {
          "type": "string"
        },
        "instruction": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": [
              "source"
            ],
            "additionalProperties": false,
            "properties": {
              "source": {
                "type": "string"
              },
              "answer": {
                "type": "string"
              },
              "options": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "text": {
                      "type": "string"
                    },
                    "correct": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        },
        "title": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "error-correction-a1": {
      "type": "object",
      "required": [
        "type",
        "items"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "error-correction"
        },
        "title": {
          "type": "string"
        },
        "instruction": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": [
              "sentence",
              "error",
              "correction"
            ],
            "properties": {
              "sentence": {
                "type": "string"
              },
              "error": {
                "type": "string"
              },
              "correction": {
                "type": "string"
              },
              "error_type": {
                "type": "string"
              },
              "explanation": {
                "type": "string"
              },
              "options": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}