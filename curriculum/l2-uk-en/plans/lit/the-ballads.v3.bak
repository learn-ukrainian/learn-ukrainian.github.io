vocabulary_hints:
  recommended:
  - мавка (forest nymph)
  - відьма (witch)
  - перетворення (transformation)
  - самотність (loneliness)
  - готика (gothic)
  required:
  - балада (ballad)
  - романтизм (romanticism)
  - метаморфоза (metamorphosis)
  - русалка (water nymph)
  - фатум (fate)
  - причинна (bewitched/mad woman)
  - потойбіччя (afterworld)
  - демонологія (demonology)
  - архетип (archetype)
  - символіка (symbolism)
word_target: 5000
