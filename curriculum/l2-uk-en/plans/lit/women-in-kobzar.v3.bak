vocabulary_hints:
  recommended:
  - подвійні стандарти (double standards)
  - страдниця (sufferer)
  - ганьба (shame)
  - матір (mother)
  - доля (fate)
  required:
  - покритка (unwed mother)
  - наймичка (hired servant woman)
  - архетип (archetype)
  - жертовність (self-sacrifice)
  - емпатія (empathy)
  - пафос (pathos)
  - димінутив (diminutive)
  - катарсис (catharsis)
  - удова (widow)
  - сирота (orphan)
