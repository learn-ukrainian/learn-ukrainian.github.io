vocabulary_hints:
  recommended:
  - козачок (servant boy)
  - меценат (patron)
  - портрет (portrait)
  - живопис (painting)
  - свобода (freedom)
  required:
  - кріпацтво (serfdom)
  - кріпак (serf)
  - поміщик (landowner)
  - панщина (corvée)
  - викуп (ransom/redemption)
  - дяк (church clerk/teacher)
  - академія (academy)
  - лотерея (lottery)
  - пророк (prophet)
  - геній (genius)
word_target: 5000
