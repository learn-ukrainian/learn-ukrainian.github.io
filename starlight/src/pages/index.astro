---
import CourseLayout from '../layouts/CourseLayout.astro';
import curriculumStats from '../data/curriculum-stats.json';

type TrackStats = Record<string, { modules?: number } | number>;

const stats = curriculumStats as TrackStats;
const moduleCount = (id: string) => {
  const entry = stats[id];
  return typeof entry === 'object' && entry ? entry.modules ?? 0 : 0;
};

const coreTracks = [
  { id: 'a1', label: 'A1', title: 'Beginner Course', status: 'Released' },
  { id: 'a2', label: 'A2', title: 'Pre-Intermediate Course', status: 'Released' },
  { id: 'b1', label: 'B1', title: 'Intermediate Course', status: 'Preview' },
  { id: 'b2', label: 'B2', title: 'Upper-Intermediate Course', status: 'Planned' },
  { id: 'c1', label: 'C1', title: 'Advanced Course', status: 'Planned' },
  { id: 'c2', label: 'C2', title: 'Mastery Course', status: 'Long-range' },
];

const seminarTracks = [
  { id: 'folk', label: 'Folk', title: 'Folk Culture', status: 'Seminar test track' },
  { id: 'bio', label: 'BIO', title: 'Biographies', status: 'Planned seminar' },
  { id: 'hist', label: 'HIST', title: 'History Of Ukraine', status: 'Planned seminar' },
  { id: 'istorio', label: 'ISTORIO', title: 'Historiography', status: 'Planned seminar' },
  { id: 'lit', label: 'LIT', title: 'Ukrainian Literature', status: 'Planned seminar' },
  { id: 'lit-essay', label: 'LIT-ESSAY', title: 'Essays', status: 'Planned seminar' },
  { id: 'lit-hist-fic', label: 'LIT-HIST-FIC', title: 'Historical Fiction', status: 'Planned seminar' },
  { id: 'lit-fantastika', label: 'LIT-FANTASTIKA', title: 'Fantastika', status: 'Planned seminar' },
  { id: 'lit-war', label: 'LIT-WAR', title: 'War Literature', status: 'Planned seminar' },
  { id: 'lit-humor', label: 'LIT-HUMOR', title: 'Humor', status: 'Planned seminar' },
  { id: 'lit-youth', label: 'LIT-YOUTH', title: 'Youth Literature', status: 'Planned seminar' },
  { id: 'lit-drama', label: 'LIT-DRAMA', title: 'Drama', status: 'Planned seminar' },
  { id: 'oes', label: 'OES', title: 'Old East Slavic', status: 'Planned seminar' },
  { id: 'ruth', label: 'RUTH', title: 'Ruthenian Baroque', status: 'Planned seminar' },
].filter((track) => moduleCount(track.id) > 0);
---

<CourseLayout
  title="Learn Ukrainian"
  description="An English learner interface for released A1 and A2 Ukrainian courses, a B1 preview, and the Word Atlas reference tool."
  eyebrow="Course ladder and reference tools"
  subtitle="A practical English interface for learning Ukrainian."
  currentPath="/"
  wide
>
  <section class="home-intro">
    <div>
      <p class="home-kicker">Learn Ukrainian</p>
      <h2>Start with A1. Continue with A2. Preview B1 when you are ready.</h2>
      <p>
        The released course path is A1, then A2. B1 is open as an intermediate preview so learners
        and teachers can see the next direction without treating it as a finished release. Word Atlas
        supports the course as a reference tool, not as a separate course track. Seminar tracks are
        listed for context, but they are not public entry points yet.
      </p>
      <div class="home-actions">
        <a class="home-primary" href="/a1/">Start A1</a>
        <a class="home-secondary" href="/b1/">Open B1 Preview</a>
      </div>
    </div>
    <aside class="roadmap-panel" aria-label="Roadmap">
      <div><strong>A1</strong><span>Released beginner course</span></div>
      <div><strong>A2</strong><span>Released continuation course</span></div>
      <div><strong>B1</strong><span>Intermediate preview</span></div>
      <div><strong>Word Atlas</strong><span>Reference tool</span></div>
      <div><strong>Seminars</strong><span>Not promoted yet</span></div>
    </aside>
  </section>

  <section>
    <h2>Available Now</h2>
    <div class="lu-card-grid">
      <a class="lu-card" href="/a1/">
        <span class="track-badge a1">A1</span>
        <h3>Beginner Course</h3>
        <p>55 modules for sounds, reading, first conversations, everyday needs, and an A1 finale.</p>
      </a>
      <a class="lu-card" href="/a2/">
        <span class="track-badge a2">A2</span>
        <h3>Pre-Intermediate Course</h3>
        <p>69 modules take learners from the A2 bridge through everyday situations, cases, aspect, and the A2 finale.</p>
      </a>
      <a class="lu-card" href="/b1/">
        <span class="track-badge b1">B1 Preview</span>
        <h3>Intermediate Preview</h3>
        <p>The first B1 module is open with Ukrainian-led explanations, activities, vocabulary, and resources.</p>
      </a>
      <a class="lu-card" href="/lexicon/">
        <span class="track-badge atlas">Reference</span>
        <h3>Word Atlas</h3>
        <p>A learner reference that goes beyond a lexicon: meanings, morphology, usage, etymology where available, and course links.</p>
      </a>
    </div>
  </section>

  <section class="track-inventory" aria-labelledby="upcoming-tracks">
    <div class="section-heading">
      <h2 id="upcoming-tracks">Course Map</h2>
      <p>
        This map separates released courses, preview work, and future inventory. The recommended
        learner path is A1 first, then A2, with B1 available as a preview. Seminar tracks are shown
        for context only and are not promoted as learner entry points yet.
      </p>
    </div>

    <div class="track-inventory-grid">
      <section class="track-column">
        <h3>Course Ladder</h3>
        <ul>
          {coreTracks.map((track) => (
            <li>
              <span class="track-code">{track.label}</span>
              <span class="track-title">{track.title}</span>
              <span class="track-meta">{moduleCount(track.id)} modules · {track.status}</span>
            </li>
          ))}
        </ul>
      </section>
      <section class="track-column">
        <h3>Seminar Tracks</h3>
        <ul>
          {seminarTracks.map((track) => (
            <li>
              <span class="track-code">{track.label}</span>
              <span class="track-title">{track.title}</span>
              <span class="track-meta">{moduleCount(track.id)} modules · {track.status}</span>
            </li>
          ))}
        </ul>
      </section>
    </div>
  </section>

  <style>
    .home-intro {
      display: grid;
      grid-template-columns: minmax(0, 1.5fr) minmax(260px, 0.8fr);
      gap: 28px;
      align-items: stretch;
      margin: 10px 0 42px;
    }
    .home-kicker {
      margin: 0 0 8px;
      color: var(--lu-blue);
      font-size: 0.82rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .home-intro h2 {
      margin-top: 0;
      color: var(--lu-gray-900);
      border: 0;
      font-size: 2rem;
      max-width: 720px;
    }
    .home-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 22px;
    }
    .home-primary,
    .home-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 0 22px;
      border-radius: 8px;
      font-weight: 800;
      text-decoration: none;
    }
    .home-primary {
      background: var(--lu-yellow);
      color: var(--lu-on-yellow);
    }
    .home-secondary {
      border: 2px solid var(--lu-blue);
      color: var(--lu-blue);
    }
    .roadmap-panel {
      display: grid;
      gap: 10px;
      padding: 18px;
      border-radius: var(--lu-radius);
      background: var(--lu-surface-raised);
      box-shadow: var(--lu-shadow);
    }
    .roadmap-panel div {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      padding: 10px 0;
      border-bottom: 1px solid var(--lu-border);
    }
    .roadmap-panel div:last-child {
      border-bottom: 0;
    }
    .roadmap-panel strong {
      color: var(--lu-blue);
    }
    .roadmap-panel span {
      color: var(--lu-gray-600);
      font-size: 0.86rem;
      text-align: right;
    }
    .track-badge {
      display: inline-block;
      margin-bottom: 10px;
      padding: 3px 10px;
      border-radius: 6px;
      color: #FFFFFF;
      font-size: 0.76rem;
      font-weight: 900;
    }
    .track-badge.a1 { background: var(--lu-green); }
    .track-badge.a2 { background: #1565C0; }
    .track-badge.b1 { background: #E65100; }
    .track-badge.folk { background: #A4133C; }
    .track-badge.atlas { background: var(--lu-teal); }
    /* In dark mode --lu-green/--lu-teal go pale → white text fails. The folk
       chip is a fixed dark crimson, so it keeps white text. */
    :global([data-theme='dark']) .track-badge.a1,
    :global([data-theme='dark']) .track-badge.atlas {
      color: var(--lu-on-yellow);
    }
    .section-heading {
      max-width: 760px;
      margin-bottom: 16px;
    }
    .section-heading p {
      margin-top: 0;
      color: var(--lu-gray-600);
    }
    .track-inventory {
      margin-top: 38px;
    }
    .track-inventory-grid {
      display: grid;
      grid-template-columns: minmax(260px, 0.75fr) minmax(0, 1.25fr);
      gap: 18px;
      align-items: start;
    }
    .track-column {
      border: 1px solid var(--lu-border);
      border-radius: var(--lu-radius);
      background: var(--lu-surface-raised);
      box-shadow: var(--lu-shadow);
      overflow: hidden;
    }
    .track-column h3 {
      margin: 0;
      padding: 14px 16px;
      border-bottom: 1px solid var(--lu-border);
      color: var(--lu-blue);
      font-size: 0.96rem;
    }
    .track-column ul {
      display: grid;
      gap: 0;
      margin: 0;
      padding: 0;
      list-style: none;
    }
    .track-column li {
      display: grid;
      grid-template-columns: minmax(92px, 0.38fr) minmax(130px, 0.72fr) minmax(150px, 0.74fr);
      gap: 10px;
      align-items: center;
      padding: 11px 16px;
      border-bottom: 1px solid var(--lu-border);
      font-size: 0.86rem;
    }
    .track-column li:last-child {
      border-bottom: 0;
    }
    .track-code {
      color: var(--lu-blue);
      font-weight: 900;
      white-space: nowrap;
    }
    .track-title {
      color: var(--lu-gray-900);
      font-weight: 700;
    }
    .track-meta {
      color: var(--lu-gray-600);
      font-size: 0.8rem;
      text-align: right;
    }
    @media (max-width: 820px) {
      .home-intro {
        grid-template-columns: 1fr;
      }
      .home-intro h2 {
        font-size: 1.55rem;
      }
      .track-inventory-grid {
        grid-template-columns: 1fr;
      }
      .track-column li {
        grid-template-columns: 1fr;
        gap: 2px;
      }
      .track-meta {
        text-align: left;
      }
    }
  </style>
</CourseLayout>
