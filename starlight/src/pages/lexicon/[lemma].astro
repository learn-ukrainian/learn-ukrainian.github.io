---
/**
 * Word Atlas (Лексикон) — per-lemma dynamic route.
 *
 * v1 scope (per docs/best-practices/word-atlas-design.md §9):
 *   Render ~80 lemmas referenced by a1/my-morning (built) +
 *   a1/sounds-letters-and-hello (plan-only) + a1/things-have-gender
 *   (plan-only). One static page per lemma, served at `/lexicon/<slug>/`.
 *
 * Data: `getStaticPaths` reads the build-time manifest at
 * `src/data/lexicon-manifest.json`. The manifest is generated by
 * `scripts/lexicon/build_data_manifest.py`.
 *
 * v1 deliberately ships THIN. Sections beyond «Шапка» + «Курсові
 * посилання» are stubbed with «Дані готуються» («data coming soon»)
 * placeholders so the route's contract is visible without blocking on
 * VESUM / ESUM / SUM-20 / heritage / synonyms / external-collection
 * enrichment. Each placeholder cites the design-doc section that will
 * fill it in so readers can see the scope.
 */
import CourseLayout from "../../layouts/CourseLayout.astro";
import manifest from "../../data/lexicon-manifest.json";

interface CourseUsage {
  track: string;
  module_num: number;
  slug: string;
  context: string;
}

interface MeaningOrEtymology {
  text: string;
  source: string;
  note?: string;
}

interface Enrichment {
  morphology?: {
    pos: string;
    form_count: number;
    forms: Array<{ form: string; label: string }>;
    source: string;
  };
  meaning?: MeaningOrEtymology;
  etymology?: MeaningOrEtymology;
  sources?: string[];
}

interface LexiconEntry {
  lemma: string;
  url_slug: string;
  gloss: string | null;
  pos: string | null;
  ipa: string | null;
  primary_source: string;
  course_usage: CourseUsage[];
  enrichment?: Enrichment;
}

interface LexiconManifest {
  version: string;
  generated_at: string;
  stats: Record<string, number>;
  modules: Array<{ track: string; module_num: number; slug: string }>;
  entries: LexiconEntry[];
}

const POS_LABELS_UK: Record<string, string> = {
  noun: "іменник",
  verb: "дієслово",
  adj: "прикметник",
  adv: "прислівник",
  pronoun: "займенник",
  pron: "займенник",
  num: "числівник",
  prep: "прийменник",
  conj: "сполучник",
  particle: "частка",
  interjection: "вигук",
  phrase: "фраза",
};

const TRACK_LABELS_UK: Record<string, string> = {
  a1: "А1",
  a2: "А2",
  b1: "B1",
  b2: "B2",
  c1: "C1",
  c2: "C2",
  hist: "Історія",
  istorio: "Історіо",
  bio: "Біографії",
  lit: "Література",
  oes: "ДРМ",
  ruth: "Русинський бароко",
};

// Maps the manifest's machine context tokens (built_vocabulary /
// plan_required / plan_recommended) to human-readable Ukrainian badge
// labels. Without this the raw token leaks into the course-link badge.
const CONTEXT_LABELS_UK: Record<string, string> = {
  built_vocabulary: "вивчається",
  plan_required: "обов’язкова",
  plan_recommended: "рекомендована",
};

export async function getStaticPaths() {
  const data = manifest as LexiconManifest;
  return data.entries.map((entry) => ({
    params: { lemma: entry.url_slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: LexiconEntry };

const frontmatter = {
  title: entry.lemma,
  description: entry.gloss
    ? `${entry.lemma} — ${entry.gloss}`
    : `${entry.lemma} — Лексикон`,
  template: "doc" as const,
  pagefind: true,
};

const posLabel = entry.pos ? POS_LABELS_UK[entry.pos] ?? entry.pos : null;
const enrichment = entry.enrichment;
const hasEnrichment = Boolean(
  enrichment && (enrichment.morphology || enrichment.meaning || enrichment.etymology),
);
---

<CourseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  eyebrow="Word Atlas"
  subtitle={entry.gloss ? `Course word: ${entry.gloss}` : "Course vocabulary entry"}
  currentPath={`/lexicon/${entry.url_slug}/`}
  heroVariant="lexicon"
  wide
>
  {/* ---------- §1 Шапка ---------- */}
  <header class="lex-header">
    <p class="lex-eyebrow">Лексикон</p>
    <h2 class="lex-lemma">{entry.lemma}</h2>
    <p class="lex-headline">
      {posLabel && <span class="lex-pos">{posLabel}</span>}
      {entry.gloss && <span class="lex-gloss">«{entry.gloss}»</span>}
      {entry.ipa && <span class="lex-ipa">[{entry.ipa}]</span>}
    </p>
  </header>

  {/* ---------- §12 Курсові посилання (highest-value v1 section) ---------- */}
  <h2>Курсові посилання</h2>
  {entry.course_usage.length === 0 ? (
    <p class="lex-empty">Це слово ще не введено у жодному курсовому модулі.</p>
  ) : (
    <ul class="lex-course-list">
      {entry.course_usage
        .slice()
        .sort((a, b) => {
          if (a.track !== b.track) return a.track.localeCompare(b.track);
          return a.module_num - b.module_num;
        })
        .map((u) => (
          <li>
            <a href={`/${u.track}/${u.slug}/`}>
              {TRACK_LABELS_UK[u.track] ?? u.track.toUpperCase()} ·{" "}
              М{String(u.module_num).padStart(2, "0")} · {u.slug}
            </a>
            <span class="lex-context-tag" title={u.context}>
              {CONTEXT_LABELS_UK[u.context] ?? u.context}
            </span>
          </li>
        ))}
    </ul>
  )}

  {/* ---------- Значення (Грінченко 1907 / СУМ-11) ---------- */}
  {enrichment?.meaning && (
    <>
      <h2>Значення та засвідчення</h2>
      <blockquote class="lex-meaning">
        <p>{enrichment.meaning.text}</p>
        <cite>{enrichment.meaning.source}</cite>
      </blockquote>
      {enrichment.meaning.note && (
        <p class="lex-source-note">{enrichment.meaning.note}</p>
      )}
    </>
  )}

  {/* ---------- Етимологія (ЕСУМ) ---------- */}
  {enrichment?.etymology && (
    <>
      <h2>Етимологія</h2>
      <blockquote class="lex-meaning">
        <p>{enrichment.etymology.text}</p>
        <cite>{enrichment.etymology.source}</cite>
      </blockquote>
    </>
  )}

  {/* ---------- Морфологія (повна парадигма VESUM) ---------- */}
  {enrichment?.morphology && (
    <>
      <h2>Морфологія</h2>
      <p class="lex-morph-meta">
        {enrichment.morphology.pos}
        {" · "}
        {enrichment.morphology.form_count} форм{" · "}
        <span class="lex-source-inline">{enrichment.morphology.source}</span>
      </p>
      <ul class="lex-forms">
        {enrichment.morphology.forms.map((f) => (
          <li>
            <span class="lex-form">{f.form}</span>
            {f.label && <span class="lex-form-label">{f.label}</span>}
          </li>
        ))}
      </ul>
    </>
  )}

  {/* ---------- Honest note when a lemma has no dictionary data yet ---------- */}
  {!hasEnrichment && (
    <>
      <h2>Значення, етимологія, морфологія</h2>
      <p class="lex-stub">
        Для цього слова ще немає словникових даних у локальних джерелах
        (VESUM, Грінченко, ЕСУМ). Розділ заповниться з розширенням корпусу.
      </p>
    </>
  )}

  {enrichment?.sources && enrichment.sources.length > 0 && (
    <p class="lex-sources-line">
      Джерела: {enrichment.sources.join(" · ")}
    </p>
  )}

  <hr />
  <p class="lex-muted">
    <a href="/lexicon/">← Усі статті Лексикону</a>
  </p>
</CourseLayout>

<style>
  /* Header / hero ------------------------------------------------------- */
  .lex-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--lu-border);
  }
  .lex-eyebrow {
    color: var(--sl-color-accent-high);
    font-size: var(--sl-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    margin: 0 0 0.4rem 0;
  }
  .lex-lemma {
    font-size: 2.6rem;
    margin: 0 0 0.6rem 0;
    line-height: 1.1;
  }
  .lex-headline {
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-base);
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    align-items: baseline;
  }
  .lex-pos {
    font-variant: small-caps;
    color: var(--sl-color-accent-high);
    font-weight: 600;
  }
  .lex-gloss {
    font-style: italic;
  }
  .lex-ipa {
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 0.95em;
    color: var(--sl-color-gray-3);
  }

  /* Course usage list --------------------------------------------------- */
  .lex-course-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 2rem 0;
  }
  .lex-course-list li {
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--lu-border);
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: baseline;
    justify-content: space-between;
  }
  .lex-course-list li:last-child {
    border-bottom: none;
  }
  .lex-context-tag {
    font-size: 0.78em;
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    color: var(--sl-color-gray-3);
    background: var(--lu-surface-muted);
    padding: 0.15rem 0.45rem;
    border: 1px solid var(--lu-border);
    border-radius: 4px;
  }

  /* Meaning / etymology (source-cited dictionary blocks) ---------------- */
  .lex-meaning {
    margin: 0.6rem 0 1.4rem 0;
    padding: 0.8rem 1.1rem;
    border-left: 3px solid var(--lu-blue);
    background: var(--lu-surface-muted);
    border-radius: 0 8px 8px 0;
  }
  .lex-meaning p {
    margin: 0 0 0.4rem 0;
  }
  .lex-meaning cite {
    font-size: 0.8em;
    font-style: normal;
    font-weight: 600;
    color: var(--sl-color-accent-high);
  }
  .lex-source-note {
    font-size: 0.82em;
    color: var(--sl-color-gray-3);
    margin: -0.8rem 0 1.4rem 0;
  }

  /* Morphology paradigm ------------------------------------------------- */
  .lex-morph-meta {
    color: var(--sl-color-gray-2);
    margin-bottom: 0.7rem;
  }
  .lex-source-inline {
    font-weight: 600;
    color: var(--sl-color-accent-high);
  }
  .lex-forms {
    list-style: none;
    padding: 0;
    margin: 0 0 1.6rem 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.3rem 1.2rem;
  }
  .lex-forms li {
    display: flex;
    justify-content: space-between;
    gap: 0.6rem;
    padding: 0.3rem 0;
    border-bottom: 1px solid var(--lu-border);
  }
  .lex-form {
    font-weight: 600;
  }
  .lex-form-label {
    font-size: 0.78em;
    color: var(--sl-color-gray-3);
    text-align: right;
  }
  .lex-sources-line {
    font-size: 0.82em;
    color: var(--sl-color-gray-3);
    border-top: 1px solid var(--lu-border);
    padding-top: 0.8rem;
  }

  /* No-data fallback ---------------------------------------------------- */
  .lex-stub {
    color: var(--sl-color-gray-2);
    font-style: italic;
    margin-bottom: 0.6rem;
  }

  /* Empty + muted ------------------------------------------------------- */
  .lex-empty,
  .lex-muted {
    color: var(--sl-color-gray-3);
  }
</style>
