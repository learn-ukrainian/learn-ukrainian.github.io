---
/**
 * Word Atlas (Лексикон) — per-lemma dynamic route.
 *
 * v1 scope (per docs/best-practices/word-atlas-design.md §9):
 *   Render ~80 lemmas referenced by a1/my-morning (built) +
 *   a1/sounds-letters-and-hello (plan-only) + a1/things-have-gender
 *   (plan-only). One static page per lemma, served at `/lexicon/<slug>/`.
 *
 * Data: `getStaticPaths` reads the build-time manifest at
 * `src/data/lexicon-manifest.json`. The manifest is generated by
 * `scripts/lexicon/build_data_manifest.py`.
 *
 * v1 deliberately ships THIN. Sections beyond «Шапка» + «Курсові
 * посилання» are stubbed with «Дані готуються» («data coming soon»)
 * placeholders so the route's contract is visible without blocking on
 * VESUM / ESUM / SUM-20 / heritage / synonyms / external-collection
 * enrichment. Each placeholder cites the design-doc section that will
 * fill it in so readers can see the scope.
 */
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import manifest from "../../data/lexicon-manifest.json";

interface CourseUsage {
  track: string;
  module_num: number;
  slug: string;
  context: string;
}

interface LexiconEntry {
  lemma: string;
  url_slug: string;
  gloss: string | null;
  pos: string | null;
  ipa: string | null;
  primary_source: string;
  course_usage: CourseUsage[];
}

interface LexiconManifest {
  version: string;
  generated_at: string;
  stats: Record<string, number>;
  modules: Array<{ track: string; module_num: number; slug: string }>;
  entries: LexiconEntry[];
}

const POS_LABELS_UK: Record<string, string> = {
  noun: "іменник",
  verb: "дієслово",
  adj: "прикметник",
  adv: "прислівник",
  pronoun: "займенник",
  pron: "займенник",
  num: "числівник",
  prep: "прийменник",
  conj: "сполучник",
  particle: "частка",
  interjection: "вигук",
  phrase: "фраза",
};

const TRACK_LABELS_UK: Record<string, string> = {
  a1: "А1",
  a2: "А2",
  b1: "B1",
  b2: "B2",
  c1: "C1",
  c2: "C2",
  hist: "Історія",
  istorio: "Історіо",
  bio: "Біографії",
  lit: "Література",
  oes: "ДРМ",
  ruth: "Русинський бароко",
};

export async function getStaticPaths() {
  const data = manifest as LexiconManifest;
  return data.entries.map((entry) => ({
    params: { lemma: entry.url_slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: LexiconEntry };

const frontmatter = {
  title: entry.lemma,
  description: entry.gloss
    ? `${entry.lemma} — ${entry.gloss}`
    : `${entry.lemma} — Лексикон`,
  template: "doc" as const,
  pagefind: true,
};

const posLabel = entry.pos ? POS_LABELS_UK[entry.pos] ?? entry.pos : null;
---

<StarlightPage frontmatter={frontmatter}>
  {/* ---------- §1 Шапка ---------- */}
  <header class="lex-header">
    <p class="lex-eyebrow">Лексикон</p>
    <h1 class="lex-lemma">{entry.lemma}</h1>
    <p class="lex-headline">
      {posLabel && <span class="lex-pos">{posLabel}</span>}
      {entry.gloss && <span class="lex-gloss">«{entry.gloss}»</span>}
      {entry.ipa && <span class="lex-ipa">[{entry.ipa}]</span>}
    </p>
  </header>

  {/* ---------- §12 Курсові посилання (highest-value v1 section) ---------- */}
  <h2>Курсові посилання</h2>
  {entry.course_usage.length === 0 ? (
    <p class="lex-empty">Це слово ще не введено у жодному курсовому модулі.</p>
  ) : (
    <ul class="lex-course-list">
      {entry.course_usage
        .slice()
        .sort((a, b) => {
          if (a.track !== b.track) return a.track.localeCompare(b.track);
          return a.module_num - b.module_num;
        })
        .map((u) => (
          <li>
            <a href={`/${u.track}/${u.slug}/`}>
              {TRACK_LABELS_UK[u.track] ?? u.track.toUpperCase()} ·{" "}
              М{String(u.module_num).padStart(2, "0")} · {u.slug}
            </a>
            <span class="lex-context-tag">{u.context}</span>
          </li>
        ))}
    </ul>
  )}

  {/* ---------- Placeholder sections (v1.1+) ---------- */}
  <h2>Значення, етимологія, морфологія, статус…</h2>
  <p class="lex-stub">
    Цей розділ буде заповнено наступними версіями Лексикону. Заплановані
    джерела (див.{" "}
    <a href="https://github.com/learn-ukrainian/learn-ukrainian.github.io/blob/main/docs/best-practices/word-atlas-design.md">
      design doc §4
    </a>
    ):
  </p>
  <ul class="lex-stub-list">
    <li>
      <strong>Значення</strong> — СУМ-20 (slovnyk.me), Грінченко 1907, СУМ-11
      (з прапором русифікації)
    </li>
    <li>
      <strong>Етимологія</strong> — ЕСУМ томи 1-6 (jsonl)
    </li>
    <li>
      <strong>Морфологія</strong> — повна парадигма з VESUM
    </li>
    <li>
      <strong>Походження + статус</strong> — heritage merger (Грінченко + ЕСУМ
      + slovnyk.me + Антоненко-Давидович)
    </li>
    <li>
      <strong>Стилістичні нотатки</strong> — Антоненко-Давидович + UA-GEC
    </li>
    <li>
      <strong>Синоніми, антоніми</strong> — Ukrajinet WordNet
    </li>
    <li>
      <strong>Фразеологізми</strong> — Фразеологічний словник (25K)
    </li>
    <li>
      <strong>Літературні засвідчення</strong> — корпус 125K чанків (літописи,
      поезія, правові)
    </li>
    <li>
      <strong>Підручники</strong> — корпус 23K чанків (1-11 клас)
    </li>
    <li>
      <strong>Зовнішні матеріали</strong> — ULP блоги/YouTube, Похрібний,
      Історія мови, Реальна історія, Комік історик, IMTGSH
    </li>
    <li>
      <strong>Переклад</strong> — Балла EN→UK
    </li>
    <li>
      <strong>Wikipedia</strong> — uk.wikipedia.org
    </li>
  </ul>

  <hr />
  <p class="lex-muted">
    <a href="/lexicon/">← Усі статті Лексикону</a>
  </p>
</StarlightPage>

<style>
  /* Header / hero ------------------------------------------------------- */
  .lex-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
  }
  .lex-eyebrow {
    color: var(--sl-color-accent-high);
    font-size: var(--sl-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    margin: 0 0 0.4rem 0;
  }
  .lex-lemma {
    font-size: 2.6rem;
    margin: 0 0 0.6rem 0;
    line-height: 1.1;
  }
  .lex-headline {
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-base);
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    align-items: baseline;
  }
  .lex-pos {
    font-variant: small-caps;
    color: var(--sl-color-accent-high);
    font-weight: 600;
  }
  .lex-gloss {
    font-style: italic;
  }
  .lex-ipa {
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 0.95em;
    color: var(--sl-color-gray-3);
  }

  /* Course usage list --------------------------------------------------- */
  .lex-course-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 2rem 0;
  }
  .lex-course-list li {
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--sl-color-gray-5);
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: baseline;
    justify-content: space-between;
  }
  .lex-course-list li:last-child {
    border-bottom: none;
  }
  .lex-context-tag {
    font-size: 0.78em;
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    color: var(--sl-color-gray-3);
    background: var(--sl-color-gray-6);
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
  }

  /* Placeholder sections ------------------------------------------------ */
  .lex-stub {
    color: var(--sl-color-gray-2);
    font-style: italic;
    margin-bottom: 0.6rem;
  }
  .lex-stub-list {
    color: var(--sl-color-gray-2);
    font-size: 0.95em;
  }
  .lex-stub-list li {
    margin: 0.3rem 0;
  }

  /* Empty + muted ------------------------------------------------------- */
  .lex-empty,
  .lex-muted {
    color: var(--sl-color-gray-3);
  }
</style>
