          {enrichment.morphology.pos} · {enrichment.morphology.form_count} форм ·{" "}
          {enrichment.morphology.source}
        </p>
        {nounParadigm ? (
          <div class="atlas-paradigm-scroll">
            <table class="atlas-paradigm-table">
              <thead>
                <tr>
                  <th scope="col" class="atlas-paradigm-case">Відмінок</th>
                  <th scope="col">Однина</th>
                  <th scope="col">Множина</th>
                </tr>
              </thead>
              <tbody>
                {CASE_ROWS.map((caseRow) => (
                  <tr>
                    <th scope="row">{caseRow.label}</th>
                    <td>{stressDisplay(nounParadigm.cases[caseRow.key]?.singular)}</td>
                    <td>{stressDisplay(nounParadigm.cases[caseRow.key]?.plural)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : verbParadigm ? (
          <div class="atlas-paradigm-stack">
            {verbParadigm.infinitive && (
              <p class="atlas-infinitive">
                <span>Інфінітив</span>
                <strong>{stressDisplay(verbParadigm.infinitive)}</strong>
              </p>
            )}

            {VERB_TENSE_ROWS.filter((tense) => verbParadigm.tenses?.[tense.key]).map((tense) => (
              <div class="atlas-paradigm-block">
                <h3>{tense.label}</h3>
                <div class="atlas-paradigm-scroll">
                  <table class="atlas-paradigm-table atlas-paradigm-table-verb">
                    <thead>
                      <tr>
                        <th scope="col">Особа</th>
                        <th scope="col">Однина</th>
                        <th scope="col">Множина</th>
                      </tr>
                    </thead>
                    <tbody>
                      {PERSON_ROWS.map((person) => (
                        <tr>
                          <th scope="row">{person.label}</th>
                          <td>{stressDisplay(verbParadigm.tenses?.[tense.key]?.["однина"]?.[person.key])}</td>
                          <td>{stressDisplay(verbParadigm.tenses?.[tense.key]?.["множина"]?.[person.key])}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            ))}

            {imperativeRows.length > 0 && (
              <div class="atlas-paradigm-block">
                <h3>Наказовий спосіб</h3>
                <div class="atlas-paradigm-scroll">
                  <table class="atlas-paradigm-table atlas-paradigm-table-verb">
                    <thead>
                      <tr>
                        <th scope="col">Особа</th>
                        <th scope="col">Однина</th>
                        <th scope="col">Множина</th>
                      </tr>
                    </thead>
                    <tbody>
                      {imperativeRows.map((person) => (
                        <tr>
                          <th scope="row">{person.label}</th>
                          <td>
                            {verbParadigm.imperative?.["однина"]?.[person.key] ? (
                              stressDisplay(verbParadigm.imperative["однина"][person.key])
                            ) : (
                              <span class="atlas-empty-cell">—</span>
                            )}
                          </td>
                          <td>
                            {verbParadigm.imperative?.["множина"]?.[person.key] ? (
                              stressDisplay(verbParadigm.imperative["множина"][person.key])
                            ) : (
                              <span class="atlas-empty-cell">—</span>
                            )}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            {verbParadigm.past && (
              <div class="atlas-paradigm-block">
                <h3>Минулий час</h3>
                <div class="atlas-paradigm-scroll">
                  <table class="atlas-paradigm-table atlas-paradigm-table-past">
                    <thead>
                      <tr>
                        {PAST_ROWS.map((pastRow) => (
                          <th scope="col">{pastRow.label}</th>
                        ))}
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        {PAST_ROWS.map((pastRow) => (
                          <td>
                            {verbParadigm.past?.[pastRow.key] ? (
                              stressDisplay(verbParadigm.past[pastRow.key])
                            ) : (
                              <span class="atlas-empty-cell">—</span>
                            )}
                          </td>
                        ))}
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            )}
          </div>
        ) : (
          <ul class="atlas-form-grid">
            {enrichment.morphology.forms.map((form) => (
              <li>
                <span>{form.stress ?? stressDisplay(form.form)}</span>
                {form.label && <small>{form.label}</small>}
              </li>
            ))}
          </ul>
        )}
      </section>
    )}

    {sourceList.length > 0 && (
      <footer class="atlas-provenance">
        <h2>Походження даних</h2>
        <div class="atlas-provenance-list">
          {sourceList.map((source) => (
            <span>{source}</span>
          ))}
        </div>
        <p>
          Версія маніфесту: {manifest.version} · остання генерація: {manifest.generated_at}
        </p>
        {usesKaikki && <p class="atlas-license-note">{KAIKKI_ATTRIBUTION}</p>}
      </footer>
    )}

    <p class="atlas-back-link">
      <a href="/lexicon/index/">← Повернутися до А-Я покажчика</a>
    </p>
  </article>
</CourseLayout>

