---
/**
 * Атлас слів (Лексикон) — per-lemma detail route.
 */
import CourseLayout from "../../layouts/CourseLayout.astro";
import manifest from "../../data/lexicon-manifest.json";

interface CourseUsage {
  track: string;
  module_num: number;
  slug: string;
  context: string;
}

interface SourcedText {
  text: string;
  source: string;
  note?: string;
}

interface Pronunciation {
  ipa: string;
  source: string;
}

interface Meaning {
  definitions: string[];
  source: string;
  synonyms?: string[];
  note?: string;
  sovietization_risk?: number;
  sovietization_keywords?: string[];
}

interface DefinitionCard {
  id: string;
  source: string;
  source_pill?: string;
  note?: string;
  definitions: string[];
  source_url?: string;
  sovietization_risk?: number;
  sovietization_keywords?: string[];
  flag_note?: string;
}

interface SynonymSection {
  items: string[];
  source: string;
  source_urls?: string[];
}

interface IdiomSection {
  items: Array<{
    text?: string;
    phrase: string;
    definition: string;
    source: string;
    source_url?: string;
  }>;
  source: string;
  source_urls?: string[];
}

interface LexiconSections {
  synonyms?: SynonymSection;
  idioms?: IdiomSection;
}

interface NounParadigm {
  kind: "noun";
  cases: Record<string, { singular: string; plural: string }>;
}

interface VerbParadigm {
  kind: "verb";
  infinitive?: string;
  tenses?: Record<string, Record<string, Record<string, string>>>;
  imperative?: Record<string, Record<string, string>>;
  past?: Record<string, string>;
}

type MorphologyParadigm = NounParadigm | VerbParadigm | { kind: "other" };

interface Enrichment {
  morphology?: {
    pos: string;
    form_count: number;
    forms: Array<{ form: string; label: string; stress?: string }>;
    paradigm?: MorphologyParadigm;
    stress?: {
      source: string;
      forms: Record<string, string>;
    };
    source: string;
  };
  stress?: {
    form: string;
    source: string;
  };
  cefr?: {
    level: string;
    source: string;
    pos?: string;
    text?: string;
  };
  meaning?: Meaning;
  definition_cards?: DefinitionCard[];
  etymology?: SourcedText;
  literary_attestation?: {
    text: string;
    source: string;
    source_label?: string;
    chunk_id?: string;
  };
  sources?: string[];
}

interface HeritageAttestation {
  source: string;
  ref: string;
  detail?: string;
}

interface HeritageStatus {
  classification: string;
  attestations: HeritageAttestation[];
  is_russianism: boolean;
  russian_shadow: boolean;
  calque_warning?: { detail?: string } | null;
}

interface LexiconEntry {
  lemma: string;
  url_slug: string;
  gloss: string | null;
  pos: string | null;
  ipa: string | null;
  pronunciation?: Pronunciation | null;
  primary_source: string;
  course_usage: CourseUsage[];
  sections?: LexiconSections;
  enrichment?: Enrichment;
  heritage_status?: HeritageStatus | null;
}

interface LexiconManifest {
  version: string;
  generated_at: string;
  stats: Record<string, number>;
  entries: LexiconEntry[];
}

const POS_LABELS_UK: Record<string, string> = {
  noun: "іменник",
  verb: "дієслово",
  adj: "прикметник",
  adv: "прислівник",
  pronoun: "займенник",
  pron: "займенник",
  num: "числівник",
  numeral: "числівник",
  prep: "прийменник",
  conj: "сполучник",
  particle: "частка",
  interjection: "вигук",
  "proper noun": "власна назва",
  proper_noun: "власна назва",
  phrase: "фраза",
};

const TRACK_LABELS_UK: Record<string, string> = {
  a1: "А1",
  a2: "А2",
  b1: "B1",
  b2: "B2",
  c1: "C1",
  c2: "C2",
  hist: "Історія",
  istorio: "Історіо",
  bio: "Біографії",
  lit: "Література",
  oes: "ДРМ",
  ruth: "Русинський бароко",
};

const CONTEXT_LABELS_UK: Record<string, string> = {
  built_vocabulary: "вивчається",
  plan_required: "обов’язкова",
  plan_recommended: "рекомендована",
  surzhyk_to_avoid: "остерігайтеся",
};

const CASE_ROWS = [
  { key: "називний", label: "Називний" },
  { key: "родовий", label: "Родовий" },
  { key: "давальний", label: "Давальний" },
  { key: "знахідний", label: "Знахідний" },
  { key: "орудний", label: "Орудний" },
  { key: "місцевий", label: "Місцевий" },
  { key: "кличний", label: "Кличний" },
];

const PERSON_ROWS = [
  { key: "1", label: "1 особа" },
  { key: "2", label: "2 особа" },
  { key: "3", label: "3 особа" },
];

const VERB_TENSE_ROWS = [
  { key: "теперішній", label: "Теперішній час" },
  { key: "майбутній", label: "Майбутній час" },
];

const PAST_ROWS = [
  { key: "чол.", label: "Чол." },
  { key: "жін.", label: "Жін." },
  { key: "сер.", label: "Сер." },
  { key: "множина", label: "Множина" },
];
const KAIKKI_SOURCE = "kaikki/Wiktionary (CC BY-SA 3.0)";
const KAIKKI_ATTRIBUTION = "Pronunciation / etymology from English Wiktionary, CC BY-SA 3.0.";

// Heritage classification → UK label + one-line gloss. Authentic Ukrainian
// statuses (archaism/historism/dialect/borrowing) are the decolonization layer:
// they prove a word is inherited Ukrainian, not a Russianism. Keyed off the
// classifier's `classification`; the русизм warning is keyed off `is_russianism`.
const HERITAGE_CLASSIFICATION_UK: Record<string, { label: string; gloss: string; tone: string }> = {
  standard: { label: "Сучасна норма", gloss: "Кодифікована сучасна українська форма (VESUM).", tone: "norm" },
  archaism: { label: "Архаїзм", gloss: "Застаріле українське слово, засвідчене в питомих джерелах.", tone: "heritage" },
  "authentic-archaism": { label: "Архаїзм", gloss: "Застаріле українське слово, засвідчене в питомих джерелах.", tone: "heritage" },
  historism: { label: "Історизм", gloss: "Слово на позначення зниклої реалії; питома українська лексика.", tone: "heritage" },
  dialect: { label: "Діалектизм", gloss: "Регіональна українська форма, засвідчена в словниках.", tone: "heritage" },
  borrowing: { label: "Запозичення", gloss: "Засвоєне запозичення в межах української норми.", tone: "heritage" },
};

const HERITAGE_WARNING_UK: Record<string, { label: string; gloss: string }> = {
  russianism: {
    label: "Русизм",
    gloss: "Ця форма має ознаки русизму. Для нормативної української використовуйте відповідник нижче.",
  },
  sovietism: {
    label: "Радянізм",
    gloss: "Це радянсько-ідеологічна форма. Для нейтральної української використовуйте відповідник нижче.",
  },
  surzhyk: {
    label: "Суржик",
    gloss: "Ця форма належить до суржику. Для стандартної української використовуйте відповідник нижче.",
  },
};

export async function getStaticPaths() {
  const data = manifest as LexiconManifest;
  return data.entries.map((entry) => ({
    params: { lemma: entry.url_slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: LexiconEntry };
const sections = entry.sections;
const enrichment = entry.enrichment;
const paradigm = enrichment?.morphology?.paradigm;
const nounParadigm = paradigm?.kind === "noun" ? paradigm : null;
const verbParadigm = paradigm?.kind === "verb" ? paradigm : null;
const headerStress = enrichment?.stress?.form ?? null;
const cefrLevel = enrichment?.cefr?.level ?? null;
const definitionCards = enrichment?.definition_cards ?? [];
const pronunciation = entry.pronunciation ?? null;
const formatIpa = (ipa: string | null | undefined) => {
  const value = ipa?.trim();
  if (!value) return null;
  return value.startsWith("[") || value.startsWith("/") ? value : `[${value}]`;
};
const headwordIpa = formatIpa(pronunciation?.ipa ?? entry.ipa);
const morphologyStressForms = enrichment?.morphology?.stress?.forms ?? {};
const stressDisplay = (form: string | undefined | null) =>
  form ? morphologyStressForms[form] ?? form : "";
const imperativeRows = verbParadigm?.imperative
  ? PERSON_ROWS.filter((person) =>
      Boolean(
        verbParadigm.imperative?.["однина"]?.[person.key] ||
          verbParadigm.imperative?.["множина"]?.[person.key],
      ),
    )
  : [];
const posLabel = entry.pos ? POS_LABELS_UK[entry.pos] ?? entry.pos : null;
const letter = entry.lemma.charAt(0).toLocaleUpperCase("uk");
const courseUsage = entry.course_usage.slice().sort((a, b) => {
  if (a.track !== b.track) return a.track.localeCompare(b.track);
  return a.module_num - b.module_num;
});
// Provenance lists DATA sources only (VESUM, Вікісловник, …). The course-usage
// context (plan_required → «обов'язкова») is NOT a data source — never let it
// leak into the provenance footer. Empty ⇒ the footer is omitted (design §4 #15).
const sectionSources = [
  pronunciation?.source,
  sections?.synonyms?.source,
  sections?.idioms?.source,
].filter((source): source is string => Boolean(source));
const sourceList = Array.from(
  new Set([
    ...(enrichment?.sources && enrichment.sources.length > 0 ? enrichment.sources : []),
    ...sectionSources,
  ]),
).sort((a, b) => a.localeCompare(b, "uk"));

const heritage = entry.heritage_status ?? null;
const heritageClass = heritage ? HERITAGE_CLASSIFICATION_UK[heritage.classification] ?? null : null;
const heritageWarning = heritage
  ? HERITAGE_WARNING_UK[heritage.classification] ??
    (heritage.is_russianism ? HERITAGE_WARNING_UK.russianism : null)
  : null;
const showHeritageWarning = Boolean(
  heritage &&
    heritageWarning &&
    (heritage.is_russianism ||
      heritage.classification === "russianism" ||
      heritage.classification === "sovietism" ||
      heritage.classification === "surzhyk"),
);
const standardAlternatives = showHeritageWarning
  ? Array.from(
      new Set(
        (heritage?.attestations ?? [])
          .filter((a) => a.source === "standard_alternative" && a.ref)
          .map((a) => a.ref),
      ),
    )
  : [];
const hasPreSovietAttestation = Boolean(
  (heritage?.attestations ?? []).some((attestation) =>
    /grinchenko_1907|1907|Голоскевич|1929|ЕСУМ|esum/.test(
      `${attestation.source} ${attestation.ref} ${attestation.detail ?? ""}`,
    ),
  ),
);
const showEditorialSuccess = Boolean(
  heritage && !heritage.is_russianism && !showHeritageWarning && hasPreSovietAttestation,
);
const showEditorialWarning = Boolean(showHeritageWarning);
const usesKaikki = Boolean(
  pronunciation?.source === KAIKKI_SOURCE || enrichment?.etymology?.source === KAIKKI_SOURCE,
);
// "standard" is the unremarkable default (codified modern norm) — it gets the
// glanceable header pill but no dedicated section. The section is reserved for
// the noteworthy cases: a non-standard authentic status (archaism/historism/
// dialect/borrowing) or any word-level decolonization warning.
const isNoteworthyClass = Boolean(
  heritage && heritageClass && heritage.classification !== "standard",
);
const showHeritage = Boolean(
  heritage &&
    (isNoteworthyClass ||
      showHeritageWarning ||
      heritage.russian_shadow ||
      heritage.calque_warning),
);
const hasDictionaryData = Boolean(
    pronunciation ||
    enrichment?.morphology ||
    enrichment?.meaning ||
    definitionCards.length > 0 ||
    enrichment?.etymology ||
    enrichment?.literary_attestation ||
    sections?.synonyms ||
    sections?.idioms ||
    showHeritage ||
    showEditorialSuccess ||
    showEditorialWarning,
);

const frontmatter = {
  title: entry.lemma,
  description: entry.gloss
    ? `${entry.lemma} — ${entry.gloss}`
    : `${entry.lemma} — стаття Лексикону`,
  template: "doc" as const,
  pagefind: true,
};
---

<CourseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  eyebrow={`Лексикон · А-Я · ${letter}`}
  subtitle={entry.gloss ? `Курсова стаття: «${entry.gloss}»` : "Курсова словникова стаття з посиланнями на уроки."}
  currentPath={`/lexicon/${entry.url_slug}/`}
  heroVariant="lexicon"
  wide
>
  <article class="atlas-detail">
    <nav class="atlas-view-nav" aria-label="Навігація Лексикону">
      <a href="/lexicon/">Пошук</a>
      <a href="/lexicon/index/">А-Я покажчик</a>
    </nav>

    <header class="atlas-word-card">
      <div>
        <p class="atlas-kicker">Лексикон · літера {letter}</p>
        <h2>
          {entry.lemma}
          {headerStress && <span class="word-stress">[{headerStress}]</span>}
        </h2>
        <p class="atlas-word-line">
          {posLabel && <span>{posLabel}</span>}
          {entry.gloss && <span>«{entry.gloss}»</span>}
          {headwordIpa && <span class="atlas-ipa">{headwordIpa}</span>}
        </p>
      </div>

      <div class="atlas-status-badges" aria-label="Статус статті">
        <span>{CONTEXT_LABELS_UK[entry.primary_source] ?? entry.primary_source}</span>
        <span>{courseUsage.length} {courseUsage.length === 1 ? "модуль" : "модулів"}</span>
        {cefrLevel && <span class="status-badge cefr">CEFR {cefrLevel}</span>}
        {enrichment?.morphology && <span>{enrichment.morphology.form_count} форм</span>}
        {showHeritageWarning && heritageWarning && (
          <span class="atlas-heritage-pill atlas-heritage-pill--russism">
            {heritageWarning.label}
          </span>
        )}
        {!showHeritageWarning && heritageClass && (
          <span class={`atlas-heritage-pill atlas-heritage-pill--${heritageClass.tone}`}>
            {heritageClass.label}
          </span>
        )}
      </div>
    </header>

    {!hasDictionaryData && (
      <section class="atlas-callout" aria-labelledby="atlas-status-title">
        <div class="atlas-callout-icon" aria-hidden="true">ℹ</div>
        <div>
          <h2 id="atlas-status-title">Стаття-заготовка</h2>
          <p>
            Це курсова лема, але словниковий шар ще готується. Сторінка вже
            фіксує місце слова в курсі, щоб посилання з уроків були стабільні.
          </p>
        </div>
      </section>
    )}

    {showHeritageWarning && heritageWarning && (
      <section class="atlas-section" aria-label="Редакційне попередження">
        <div class="editorial-warn">
          <div class="editorial-warn-header">
            <div class="editorial-warn-icon" aria-hidden="true">⚠</div>
            {heritageWarning.label ?? "Редакційне попередження"}
          </div>
          <p>{heritageWarning.gloss}</p>
          {standardAlternatives.length > 0 && (
            <p class="editorial-meta">Українська норма: {standardAlternatives.join(", ")}</p>
          )}
        </div>
      </section>
    )}

    {showEditorialSuccess && (
      <section class="atlas-section" aria-label="Редакційне підтвердження">
        <div class="editorial-success">
          <div class="editorial-success-header">
            <div class="editorial-success-icon" aria-hidden="true">✓</div>
            Питома українська лексика — засвідчена до радянської доби, не русизм
          </div>
          <p>
            Лема має дорадянське словникове засвідчення і не позначена
            класифікатором як русизм. Радянські словникові ілюстрації, якщо
            вони показані нижче, оцінюються окремо як ризик джерела.
          </p>
        </div>
      </section>
    )}

    {showHeritage && (
      <section class="atlas-section atlas-heritage" aria-labelledby="atlas-heritage-title">
        <div class="atlas-section-head">
          <p class="atlas-kicker">Деколонізація</p>
          <h2 id="atlas-heritage-title">Походження та статус</h2>
        </div>

        {showHeritageWarning && heritageWarning ? (
          <div class="atlas-heritage-card atlas-heritage-card--russism">
            <p class="atlas-source-label">{heritageWarning.label}</p>
            <p>{heritageWarning.gloss}</p>
            {standardAlternatives.length > 0 && (
              <p class="atlas-chip-line">
                <strong>Українська норма:</strong>{" "}
                {standardAlternatives.map((alt) => (
                  <span>{alt}</span>
                ))}
              </p>
            )}
          </div>
        ) : heritageClass ? (
          <div class={`atlas-heritage-card atlas-heritage-card--${heritageClass.tone}`}>
            <p class="atlas-source-label">{heritageClass.label}</p>
            <p>{heritageClass.gloss}</p>
          </div>
        ) : (
          <div class="atlas-heritage-card">
            <p class="atlas-source-label">Статус уточнюється</p>
            <p>Класифікацію цієї форми ще не визначено за локальними джерелами.</p>
          </div>
        )}

        {heritage?.russian_shadow && !showHeritageWarning && (
          <p class="atlas-heritage-warn">
            ⚠ Морфологічна тінь російської форми — перевірте відмінювання за VESUM
            та Правописом 2019.
          </p>
        )}
        {heritage?.calque_warning && (
          <p class="atlas-heritage-warn">
            ⚠ Калька{heritage.calque_warning.detail ? `: ${heritage.calque_warning.detail}` : ""}.
          </p>
        )}
      </section>
    )}

    <section class="atlas-section" aria-labelledby="atlas-course-title">
      <div class="atlas-section-head">
        <p class="atlas-kicker">У курсі</p>
        <h2 id="atlas-course-title">Модулі, де зустрічається слово</h2>
      </div>

      {courseUsage.length === 0 ? (
        <p class="atlas-muted">Це слово ще не введено у жодному курсовому модулі.</p>
      ) : (
        <div class="atlas-course-grid">
          {courseUsage.map((usage) => (
            <a class="atlas-course-card" href={`/${usage.track}/${usage.slug}/`}>
              <span>
                {TRACK_LABELS_UK[usage.track] ?? usage.track.toUpperCase()} ·{" "}
                М{String(usage.module_num).padStart(2, "0")}
              </span>
              <strong>{usage.slug}</strong>
              <small>{CONTEXT_LABELS_UK[usage.context] ?? usage.context}</small>
            </a>
          ))}
        </div>
      )}
    </section>

    {(definitionCards.length > 0 || enrichment?.meaning) && (
      <section class="atlas-section" aria-labelledby="atlas-meaning-title">
        <div class="atlas-section-head">
          <p class="atlas-kicker">Тлумачення</p>
          <h2 id="atlas-meaning-title">Значення</h2>
        </div>

        {definitionCards.length > 0 ? (
          <div class="def-card-list">
            {definitionCards.map((card) => (
              <article class={`def-card ${card.id}`}>
                <div class="def-source">
                  <span class="src-pill">{card.source_pill ?? card.source}</span>
                  {card.note && <span>{card.note}</span>}
                </div>
                <div class="def-text">
                  {card.definitions.map((definition) => (
                    <p>{definition}</p>
                  ))}
                </div>
                {card.flag_note && <div class="def-flag-inline">{card.flag_note}</div>}
              </article>
            ))}
          </div>
        ) : enrichment?.meaning ? (
          <div class="atlas-source-card atlas-source-card-primary">
            <p class="atlas-source-label">{enrichment.meaning.source}</p>
            <ol>
              {enrichment.meaning.definitions.map((definition) => (
                <li>{definition}</li>
              ))}
            </ol>
            {enrichment.meaning.synonyms && enrichment.meaning.synonyms.length > 0 && (
              <p class="atlas-chip-line">
                <strong>Синоніми:</strong>{" "}
                {enrichment.meaning.synonyms.map((synonym) => (
                  <span>{synonym}</span>
                ))}
              </p>
            )}
            {enrichment.meaning.note && <p class="atlas-note">{enrichment.meaning.note}</p>}
          </div>
        ) : null}
      </section>
    )}

    {sections?.synonyms && sections.synonyms.items.length > 0 && (
      <section class="atlas-section" aria-labelledby="atlas-synonyms-title">
        <div class="atlas-section-head">
          <p class="atlas-kicker">Слововживання</p>
          <h2 id="atlas-synonyms-title">Синоніми</h2>
        </div>

        <div class="atlas-source-card atlas-source-card-synonyms">
          <p class="atlas-source-label">{sections.synonyms.source}</p>
          <div class="atlas-chip-line atlas-chip-line-large">
            {sections.synonyms.items.map((synonym) => (
              <span>{synonym}</span>
            ))}
          </div>
        </div>
      </section>
    )}

    {sections?.idioms && sections.idioms.items.length > 0 && (
      <section class="atlas-section" aria-labelledby="atlas-idioms-title">
        <div class="atlas-section-head">
          <p class="atlas-kicker">Сталі вирази</p>
          <h2 id="atlas-idioms-title">Фразеологізми</h2>
        </div>

        <div class="atlas-idiom-grid">
          {sections.idioms.items.map((idiom) => (
            <article class="atlas-idiom-card">
              <h3>{idiom.phrase}</h3>
              <p>{idiom.definition}</p>
              <span>{idiom.source}</span>
            </article>
          ))}
        </div>
      </section>
    )}

    {enrichment?.etymology && (
      <section class="atlas-section" aria-labelledby="atlas-etymology-title">
        <div class="atlas-section-head">
          <p class="atlas-kicker">Походження</p>
          <h2 id="atlas-etymology-title">Етимологія</h2>
        </div>
        <blockquote class="atlas-quote-card">
          <p>{enrichment.etymology.text}</p>
          <cite>{enrichment.etymology.source}</cite>
        </blockquote>
      </section>
    )}

    {enrichment?.literary_attestation && (
      <section class="atlas-section" aria-labelledby="atlas-literary-title">
        <div class="atlas-section-head">
          <p class="atlas-kicker">Джерела</p>
          <h2 id="atlas-literary-title">Літературні засвідчення</h2>
        </div>
        <div class="source-box">
          <div class="source-box-header">
            {enrichment.literary_attestation.source_label ?? "Літературний корпус"}
          </div>
          <blockquote>{enrichment.literary_attestation.text}</blockquote>
          <div class="source-cite">
            {enrichment.literary_attestation.source}
            {enrichment.literary_attestation.chunk_id && ` · ${enrichment.literary_attestation.chunk_id}`}
          </div>
        </div>
      </section>
    )}

    {enrichment?.morphology && (
      <section class="atlas-section" aria-labelledby="atlas-morph-title">
        <div class="atlas-section-head">
          <p class="atlas-kicker">Форми</p>
          <h2 id="atlas-morph-title">Морфологія</h2>
        </div>

