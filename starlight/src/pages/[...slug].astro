const HIDDEN_DOCS = new Set(['a1/review-clears-needs-human']);
const PUBLIC_LESSON_PREFIXES = new Set(['a1', 'folk']);
const normalizeId = (id: string) => id.replace(/\.mdx?$/, '').replace(/\/index$/, '');
const hrefFromRoute = (route: string) => `/${route}/`;
const trackIds = Object.keys(TRACKS);

const allDocs = await getCollection('docs');
const visibleDocs = allDocs.filter((entry) => {
  const id = normalizeId(entry.id);
  const track = id.split('/')[0];
  if (HIDDEN_DOCS.has(id)) return false;
  if (entry.data.draft) return false;
  return track in TRACKS;
});

const deployedDocsByTrack = new Map<string, DocsEntry[]>();
for (const entry of visibleDocs) {
  const id = normalizeId(entry.id);
  const track = id.split('/')[0];
  if (id === track) continue;
  const bucket = deployedDocsByTrack.get(track) ?? [];
  bucket.push(entry);
  deployedDocsByTrack.set(track, bucket);
}
for (const entries of deployedDocsByTrack.values()) {
  entries.sort((a, b) => (a.data.sidebar?.order ?? 999) - (b.data.sidebar?.order ?? 999));
}

const searchItems: SearchItem[] = [
  ...trackIds.map((id) => {
    const track = TRACKS[id];
    return {
      title: `${track.label} · ${track.title}`,
      href: `/${id}/`,
      type: track.family === 'core' ? 'Core track' : 'Seminar track',
      track: track.label,
      text: `${track.subtitle} ${track.status} ${track.points.join(' ')} ${track.pattern.join(' ')}`,
    };
  }),
  ...visibleDocs
    .filter((entry) => {
      const id = normalizeId(entry.id);
      const track = id.split('/')[0];
      return PUBLIC_LESSON_PREFIXES.has(track) && id !== track;
    })
    .map((entry) => {
      const id = normalizeId(entry.id);
      const track = id.split('/')[0];
      return {
        title: entry.data.title,
        href: hrefFromRoute(id),
        type: track === 'folk' ? 'Seminar lesson' : 'Core lesson',
        track: TRACKS[track]?.label ?? track.toUpperCase(),
        text: `${entry.data.title} ${entry.data.description ?? ''} ${entry.data.sidebar?.label ?? ''}`,
      };
    }),
  ...lexicon.entries.slice(0, 160).map((entry) => ({
    title: entry.lemma,
    href: `/lexicon/${entry.url_slug}/`,
    type: 'Word Atlas',
    track: 'Atlas',
    text: `${entry.lemma} ${entry.gloss ?? ''}`,
  })),
  {
    title: 'Етимологія',
    href: '/etymology/',
    type: 'Reference',
    track: 'Reference',
    text: 'ЕСУМ etymology reference entries cognates proto forms source dictionary',
  },
];

export async function getStaticPaths() {
  const normalizeDocId = (id: string) => id.replace(/\.mdx?$/, '').replace(/\/index$/, '');
  const publicLessonPrefixes = new Set(['a1', 'folk']);
  const hiddenDocs = new Set(['a1/review-clears-needs-human']);
  const tracks = ['a1', 'a2', 'b1', 'b2', 'c1', 'c2', 'folk', 'bio', 'hist', 'istorio', 'lit', 'oes', 'ruth'];
  const docs = (await getCollection('docs')).filter((entry) => {
    const id = normalizeDocId(entry.id);
    const track = id.split('/')[0];
    if (!publicLessonPrefixes.has(track)) return false;
    if (id === track) return false;
    if (hiddenDocs.has(id)) return false;
    if (entry.data.draft) return false;
    return true;
  });

  return [
    ...tracks.map((track) => ({
      params: { slug: track },
      props: { kind: 'track', track },
    })),
    { params: { slug: 'search' }, props: { kind: 'search' } },
    { params: { slug: 'missing-content' }, props: { kind: 'state', state: 'missing-content' } },
    { params: { slug: 'empty-reference' }, props: { kind: 'state', state: 'empty-reference' } },
    ...docs.map((entry) => ({
      params: { slug: normalizeDocId(entry.id) },
      props: { kind: 'doc', entry },
    })),
  ];
}

const props = Astro.props as RouteProps;
const pageTrack = props.kind === 'track'
  ? TRACKS[props.track]
  : props.kind === 'doc'
    ? TRACKS[normalizeId(props.entry.id).split('/')[0]]
    : undefined;

let Content: Awaited<ReturnType<typeof render<'docs'>>>['Content'] | undefined;
let docRoute = '';
let docTrack = '';
let isSeminarLesson = false;
let previousLink: { href: string; label: string } | undefined;
let nextLink: { href: string; label: string } | undefined;

if (props.kind === 'doc') {
  const rendered = await render(props.entry);
  Content = rendered.Content;
  docRoute = normalizeId(props.entry.id);
  docTrack = docRoute.split('/')[0];
  isSeminarLesson = TRACKS[docTrack]?.family === 'seminar';
  const prev = props.entry.data.prev;
  const next = props.entry.data.next;
  if (typeof prev === 'string') previousLink = { href: `/${docTrack}/${prev}/`, label: 'Previous' };
  if (typeof next === 'string') nextLink = { href: `/${docTrack}/${next}/`, label: 'Next' };
}

const pageMeta = (() => {
  if (props.kind === 'track') {
    const track = TRACKS[props.track];
    return {
      title: track.title,
      description: track.subtitle,
      eyebrow: track.eyebrow,
      subtitle: track.subtitle,
      currentPath: `/${props.track}/`,
      heroVariant: track.heroVariant,
      wide: true,
    };
  }
  if (props.kind === 'search') {
    return {
      title: 'Search',
      description: 'Search the learner UI, course lessons, track landings, Word Atlas entries, and reference pages.',
      eyebrow: 'Find a page',
      subtitle: 'Static client-side search for lessons, tracks, Word Atlas entries, and references.',
      currentPath: '/search/',
      heroVariant: 'lexicon' as HeroVariant,
      wide: true,
    };
  }
  if (props.kind === 'state') {
    const title = props.state === 'not-found'
      ? 'Page Not Found'
      : props.state === 'missing-content'
        ? 'Missing Content'
        : 'Empty Reference State';
    return {
      title,
      description: 'Learner UI state template for missing, unavailable, and empty content.',
      eyebrow: 'Learner state',
      subtitle: 'A clear route state keeps learners oriented instead of dropping them into a generic docs page.',
      currentPath: props.state === 'not-found' ? '/404/' : `/${props.state}/`,
      heroVariant: 'unavailable' as HeroVariant,
      wide: true,
    };
  }

  const route = normalizeId(props.entry.id);
  const track = route.split('/')[0];
  const order = props.entry.data.sidebar?.order;
  return {
    title: props.entry.data.title,
    description: props.entry.data.description ?? TRACKS[track]?.subtitle,
    eyebrow: `${TRACKS[track]?.label ?? track.toUpperCase()} · ${order ? `Module ${String(order).padStart(2, '0')}` : 'Lesson'}`,
    subtitle: props.entry.data.description ?? TRACKS[track]?.subtitle,
    currentPath: hrefFromRoute(route),
    heroVariant: TRACKS[track]?.heroVariant ?? 'core',
    wide: false,
  };
})();

const navItems = props.kind === 'doc'
  ? [
      { href: '/', label: 'Home' },
      { href: `/${docTrack}/`, label: TRACKS[docTrack]?.label ?? docTrack.toUpperCase() },
      { href: hrefFromRoute(docRoute), label: props.entry.data.sidebar?.label ?? props.entry.data.title },
    ]
  : [
      { href: '/', label: 'Home' },
      { href: pageMeta.currentPath, label: pageMeta.title },
    ];

// Doc-layout lesson sidebar (#2823): persistent track navigation built from the
// same per-track sorted lesson list the track landing page uses.
const sidebar = props.kind === 'doc'
  ? (() => {
      const lessons = deployedDocsByTrack.get(docTrack) ?? [];
      if (lessons.length === 0) return undefined;
      const links = lessons.map((entry) => {
        const id = normalizeId(entry.id);
        const order = entry.data.sidebar?.order;
        return {
          href: hrefFromRoute(id),
          label: entry.data.title,
          num: order ? String(order).padStart(2, '0') : '•',
          active: id === docRoute,
        };
      });
      const currentIndex = links.findIndex((link) => link.active);
      const position = currentIndex >= 0 ? currentIndex + 1 : 0;
      return {
        backHref: `/${docTrack}/`,
        backLabel: TRACKS[docTrack]?.label ?? docTrack.toUpperCase(),
        positionLabel: position > 0
          ? `Lesson ${position} of ${links.length}`
          : `${links.length} lessons`,
        progressDone: position,
        progressTotal: links.length,
        links,
      };
    })()
  : undefined;
---

<CourseLayout
  title={pageMeta.title}
  description={pageMeta.description}
  eyebrow={pageMeta.eyebrow}
  subtitle={pageMeta.subtitle}
  currentPath={pageMeta.currentPath}
  heroVariant={pageMeta.heroVariant}
  navItems={navItems}
  sidebar={sidebar}
  wide={pageMeta.wide}
  showHero
>
  {props.kind === 'track' && pageTrack ? (
    <section class:list={['track-overview', `track-${props.track}`, pageTrack.family, pageTrack.state]}>
      <div class="track-status-panel">
        <span>{pageTrack.status}</span>
        <strong>
          {moduleCount(props.track)}
          {' '}
          {pageTrack.state === 'released' || pageTrack.state === 'test' ? 'available modules' : 'planned modules'}
        </strong>
      </div>

      <div class="track-overview-grid">
        <section class="track-lead">
          <p class="track-family">{pageTrack.family === 'core' ? 'Core ladder' : 'Seminar track'}</p>
          <h2>{pageTrack.title}</h2>
          <p>{pageTrack.subtitle}</p>
          <div class="track-actions">
            {pageTrack.primaryAction && <a class="track-primary" href={pageTrack.primaryAction.href}>{pageTrack.primaryAction.label}</a>}
            {pageTrack.secondaryAction && <a class="track-secondary" href={pageTrack.secondaryAction.href}>{pageTrack.secondaryAction.label}</a>}
          </div>
        </section>

        <section class="track-notes" aria-label={`${pageTrack.label} notes`}>
          {pageTrack.points.map((point) => (
            <p>{point}</p>
          ))}
        </section>
      </div>

      <section class="track-pattern">
        <h2>Template Pattern</h2>
        <div class="track-pattern-grid">
          {pageTrack.pattern.map((item) => (
            <span>{item}</span>
          ))}
        </div>
      </section>

      {pageTrack.family === 'seminar' && (
        <section class="seminar-frame">
          <div>
            <h2>Seminar Reading Frame</h2>
            <p>
              Source-heavy lessons use a different rhythm from the core ladder: evidence first,
              interpretation second, and practice that asks learners to compare claims rather than
              memorize isolated facts.
            </p>
          </div>
          <ul>
            <li>source note with provenance and limits</li>
            <li>context card before claims get interpreted</li>
            <li>decolonization or bias check where the topic requires it</li>
            <li>workbook tasks for comparison, evaluation, and response</li>
          </ul>
        </section>
      )}

      {pageTrack.state === 'unavailable' || pageTrack.state === 'planned' || pageTrack.state === 'next' ? (
        <section class="route-state-card">
          <p class="state-code">{pageTrack.state === 'next' ? 'Next Track' : 'Unavailable Today'}</p>
          <h2>This track is mapped, not released.</h2>
          <p>
            The learner UI keeps the route visible so navigation, search, and future publishing have
            a real template, but it does not claim this content is ready for study.
          </p>
          <a href="/a1/">Use the available A1 track</a>
        </section>
      ) : (
        <section class="module-preview">
          <h2>Available Modules</h2>
          <div class="module-preview-list">
            {(deployedDocsByTrack.get(props.track) ?? []).map((entry) => {
              const id = normalizeId(entry.id);
              return (
                <a href={hrefFromRoute(id)}>
                  <span>{entry.data.sidebar?.order ? String(entry.data.sidebar.order).padStart(2, '0') : 'Lesson'}</span>
                  <strong>{entry.data.title}</strong>
                </a>
              );
            })}
          </div>
        </section>
      )}

      <section class="track-support">
        <h2>Learning Support</h2>
        <div class="track-support-grid">
          <a href="/lexicon/">
            <strong>Word Atlas</strong>
            <span>Static vocabulary, morphology, etymology, and course usage pages.</span>
          </a>
          <a href="/search/">
            <strong>Search</strong>
            <span>Find lessons, track pages, Word Atlas entries, and reference surfaces.</span>
          </a>
          <a href="https://www.ukrainianlessons.com/">
            <strong>Ukrainian Lessons</strong>
            <span>Recommended external learning ecosystem; inspiration only, not copied content.</span>
          </a>
        </div>
      </section>
    </section>
  ) : props.kind === 'search' ? (
    <section class="search-page" data-search-root>
      <form class="search-panel" role="search">
        <label for="course-search">Search lessons, tracks, and reference pages</label>
        <div class="search-input-row">
          <input id="course-search" name="q" type="search" placeholder="Try gender, колядки, вікно, etymology..." autocomplete="off" />
          <button type="submit">Search</button>
        </div>
      </form>

      <div class="search-state search-loading" data-search-loading hidden>
        <span class="state-code">Loading</span>
        <p>Preparing the local index.</p>
      </div>
      <div class="search-state search-error" data-search-error hidden>
        <span class="state-code">Error</span>
        <h2>Search could not run.</h2>
        <p>The static page is still available. Use the course links below while the search script recovers.</p>
      </div>
      <div class="search-state search-empty" data-search-empty hidden>
        <span class="state-code">No Results</span>
        <h2>No matching pages.</h2>
        <p>Try a broader term, a Ukrainian lemma, or open A1, Folk, Word Atlas, or Etymology directly.</p>
      </div>

      <section class="search-results-section" aria-live="polite">
        <div class="section-heading">
          <h2 data-search-heading>Suggested Pages</h2>
          <p data-search-count>Start with a broad query or use the shortcuts.</p>
        </div>
        <div class="search-results" data-search-results>
          {searchItems.slice(0, 9).map((item) => (
            <a href={item.href}>
              <span>{item.type} · {item.track}</span>
              <strong>{item.title}</strong>
            </a>
          ))}
        </div>
      </section>

      <script is:inline define:vars={{ searchItems }}>
        const root = document.querySelector('[data-search-root]');
        const input = root?.querySelector('#course-search');
        const form = root?.querySelector('form');
        const results = root?.querySelector('[data-search-results]');
        const count = root?.querySelector('[data-search-count]');
        const heading = root?.querySelector('[data-search-heading]');
        const empty = root?.querySelector('[data-search-empty]');
        const error = root?.querySelector('[data-search-error]');
        const loading = root?.querySelector('[data-search-loading]');
        const params = new URLSearchParams(window.location.search);
        const normalize = (value) => String(value || '').toLocaleLowerCase('uk');
        const escapeHtml = (value) => String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
        const render = (query) => {
          const q = normalize(query).trim();
          error.hidden = params.get('state') !== 'error';
          loading.hidden = true;
          if (!results || !count || !heading || !empty || !error.hidden) return;
          const matches = q
            ? searchItems.filter((item) => normalize(`${item.title} ${item.text} ${item.type} ${item.track}`).includes(q)).slice(0, 24)
            : searchItems.slice(0, 9);
          empty.hidden = matches.length !== 0 || !q;
          heading.textContent = q ? `Results for "${query}"` : 'Suggested Pages';
          count.textContent = matches.length
            ? `${matches.length} ${matches.length === 1 ? 'match' : 'matches'} in the static learner index.`
            : q
              ? 'No pages matched this query.'
              : 'Start with a broad query or use the shortcuts.';
          results.innerHTML = matches.map((item) => (
            `<a href="${escapeHtml(item.href)}"><span>${escapeHtml(item.type)} · ${escapeHtml(item.track)}</span><strong>${escapeHtml(item.title)}</strong></a>`
          )).join('');
        };
        if (input) {
          input.value = params.get('q') || '';
          input.addEventListener('input', () => render(input.value));
        }
        form?.addEventListener('submit', (event) => {
          event.preventDefault();
          const query = input?.value || '';
          const url = query ? `/search/?q=${encodeURIComponent(query)}` : '/search/';
          window.history.replaceState(null, '', url);
          render(query);
        });
        render(input?.value || '');
      </script>
    </section>
  ) : props.kind === 'state' ? (
    <section class="route-state-card big">
      <p class="state-code">
        {props.state === 'not-found' ? '404' : props.state === 'missing-content' ? 'Missing' : 'Empty'}
      </p>
      <h2>
        {props.state === 'not-found'
          ? 'This page is not part of the public learner UI.'
          : props.state === 'missing-content'
            ? 'The route exists, but the lesson content is not ready.'
            : 'The reference template has an empty state.'}
      </h2>
      <p>
        {props.state === 'not-found'
          ? 'Hidden drafts and unknown routes should fail clearly, with useful recovery paths.'
          : props.state === 'missing-content'
            ? 'Learners should get a plain explanation and a path back to an available track.'
            : 'Atlas and reference indexes should communicate when a filter or future dataset has no records.'}
      </p>
      <div class="state-actions">
        <a href="/a1/">A1 Release</a>
        <a href="/folk/">Folk Seminar</a>
        <a href="/search/">Search</a>
        <a href="/lexicon/">Word Atlas</a>
      </div>
    </section>
  ) : Content ? (
    <section class:list={['lesson-shell', isSeminarLesson && 'seminar-lesson']}>
      <aside class="lesson-companion" aria-label="Lesson context">
        <p class="state-code">{isSeminarLesson ? 'Seminar' : 'Core lesson'}</p>
        <h2>{isSeminarLesson ? 'Source-Heavy Reading' : 'Learner Path'}</h2>
        <p>
          {isSeminarLesson
            ? 'Read for evidence, context, and interpretation. Source notes and workbook tasks stay visible as part of the seminar frame.'
            : 'Use the lesson tab first, then vocabulary, activities, and resources. Dialogue and tables are styled for repeated practice.'}
        </p>
      </aside>
      <Content />
      {(previousLink || nextLink) && (
        <nav class="lesson-next-prev" aria-label="Lesson navigation">
          {previousLink ? <a href={previousLink.href}>← {previousLink.label}</a> : <span></span>}
          {nextLink ? <a href={nextLink.href}>{nextLink.label} →</a> : <span></span>}
        </nav>
      )}
    </section>
  ) : null}
</CourseLayout>
