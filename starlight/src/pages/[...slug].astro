---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import CourseLayout from '../layouts/CourseLayout.astro';
import curriculumStats from '../data/curriculum-stats.json';
import lexiconManifest from '../data/lexicon-manifest.json';

type DocsEntry = CollectionEntry<'docs'>;
type TrackStats = Record<string, { modules?: number } | number>;
type HeroVariant = 'core' | 'folk' | 'lexicon' | 'seminar' | 'lit' | 'history' | 'unavailable';
type TrackFamily = 'core' | 'seminar' | 'reference';
type TrackState = 'released' | 'beta' | 'next' | 'planned' | 'test' | 'unavailable';
type TrackOverview = {
  label: string;
  title: string;
  eyebrow: string;
  subtitle: string;
  status: string;
  family: TrackFamily;
  state: TrackState;
  heroVariant: HeroVariant;
  primaryAction?: { href: string; label: string };
  secondaryAction?: { href: string; label: string };
  points: string[];
  pattern: string[];
};
type SearchItem = {
  title: string;
  href: string;
  type: string;
  track: string;
  text: string;
};
type LexiconManifest = {
  entries: Array<{ lemma: string; url_slug: string; gloss: string | null }>;
};
type RouteProps =
  | { kind: 'doc'; entry: DocsEntry }
  | { kind: 'track'; track: string }
  | { kind: 'search' }
  | { kind: 'state'; state: 'missing-content' | 'empty-reference' | 'not-found' };

const stats = curriculumStats as TrackStats;
const lexicon = lexiconManifest as LexiconManifest;
const moduleCount = (id: string) => {
  const entry = stats[id];
  return typeof entry === 'object' && entry ? entry.modules ?? 0 : 0;
};

const TRACKS: Record<string, TrackOverview> = {
