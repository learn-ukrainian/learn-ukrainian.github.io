---
/**
 * Custom PageTitle — gradient module header with level badge.
 * On splash pages (homepage), suppressed entirely (Home.tsx renders its own hero).
 * On docs pages, renders the POC-style gradient banner.
 */
import Default from '@astrojs/starlight/components/PageTitle.astro';

const route = Astro.locals.starlightRoute;
const hasSidebar = route.hasSidebar;

// Extract level info from the URL path
const path = Astro.url.pathname;
const pathParts = path.split('/').filter(Boolean);
const level = pathParts[0]?.toUpperCase() || '';

// Determine header style based on track
const isCore = ['A1','A2','B1','B2','C1','C2'].includes(level);
const isSeminar = ['HIST','BIO','ISTORIO','LIT','FOLK','OES','RUTH'].includes(level);
const isModule = pathParts.length >= 2 && hasSidebar;

// Level color mapping
const levelColors: Record<string, string> = {
  'A1': '#2E7D32', 'A2': '#1565C0', 'B1': '#E65100', 'B2': '#C62828',
  'C1': '#6A1B9A', 'C2': '#8D6E00',
  'HIST': '#BF360C', 'BIO': '#0D47A1', 'ISTORIO': '#880E4F', 'LIT': '#4A148C',
  'FOLK': '#33691E', 'OES': '#33691E', 'RUTH': '#004D40',
};
const bgColor = levelColors[level] || '#0057B8';

// Module number from slug mapping (basic extraction)
const slug = pathParts[1] || '';
const title = route.entry.data.title;

// Breadcrumb labels
const levelLabels: Record<string, string> = {
  'A1': 'A1 — Beginner', 'A2': 'A2 — Elementary', 'B1': 'B1 — Intermediate',
  'B2': 'B2 — Upper-Intermediate', 'C1': 'C1 — Advanced', 'C2': 'C2 — Mastery',
  'HIST': 'HIST — Історія', 'BIO': 'BIO — Біографії', 'ISTORIO': 'ISTORIO',
  'LIT': 'LIT — Література', 'FOLK': 'FOLK — Фольклор',
  'OES': 'OES — Old East Slavic', 'RUTH': 'RUTH — Ruthenian',
};
---

{!hasSidebar ? (
  /* Splash page — suppress title, Home.tsx has its own hero */
  null
) : isModule ? (
  /* Module page — gradient header with badge */
  <div class="lu-module-header" style={`background: linear-gradient(135deg, ${bgColor}, color-mix(in srgb, ${bgColor} 70%, #000))`}>
    <nav class="lu-breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="lu-sep" aria-hidden="true">›</span>
      <a href={`/${pathParts[0]}/`}>{levelLabels[level] || level}</a>
      <span class="lu-sep" aria-hidden="true">›</span>
      <span>{title}</span>
    </nav>
    <span class="lu-level-badge">{level}</span>
    <h1 id="_top">{title}</h1>
  </div>
) : (
  /* Index/landing page — use default Starlight title */
  <Default {...Astro.props}><slot /></Default>
)}

<style>
  .lu-module-header {
    color: white;
    padding: 1rem 1.5rem 1.25rem;
    border-radius: 12px;
    border-bottom: 4px solid var(--sl-color-accent);
    margin-bottom: 1.5rem;
  }
  .lu-breadcrumbs {
    font-size: 0.75rem;
    margin-bottom: 0.75rem;
    opacity: 0.8;
  }
  .lu-breadcrumbs a {
    color: rgba(255,255,255,0.8);
    text-decoration: none;
  }
  .lu-breadcrumbs a:hover { color: white; text-decoration: underline; }
  .lu-sep { margin: 0 0.4rem; opacity: 0.5; }
  .lu-breadcrumbs span:last-child { opacity: 0.9; }
  .lu-level-badge {
    display: inline-block;
    background: var(--sl-color-accent);
    color: var(--sl-color-black);
    font-weight: 700;
    font-size: 0.75rem;
    padding: 2px 10px;
    border-radius: 4px;
    margin-bottom: 0.5rem;
  }
  .lu-module-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
  }
</style>
