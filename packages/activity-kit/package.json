{
  "name": "@learn-ukrainian/activity-kit",
  "version": "0.1.0",
  "description": "Versioned React activity player and schemas for Learn Ukrainian.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
