{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://learn-ukrainian.github.io/packages/activity-kit/lu.activity.v1.schema.json",
  "title": "Learn Ukrainian Activity v1",
  "description": "Public B1 activity envelope. Self-contained payload definitions for all shipped Hramatka widgets.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "title", "level", "payload", "answer_key", "provenance"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "type": {
      "enum": [
        "true-false",
        "cloze",
        "match-up",
        "text-questions",
        "multiple-choice",
        "quiz",
        "mark-the-words",
        "fill-in",
        "glossary",
        "form-build",
        "error-correction",
        "paraphrase",
        "continue-sentence",
        "roleplay-dialog",
        "short-writing",
        "audio-listen-repeat",
        "model-answer-discussion",
        "sentence-transformation"
      ]
    },
    "title": { "type": "string", "minLength": 1 },
    "level": {
      "const": "b1",
      "description": "The public pilot contract is limited to the B1 scope."
    },
    "payload": {
      "oneOf": [
        { "$ref": "#/$defs/trueFalsePayload" },
        { "$ref": "#/$defs/clozePayload" },
        { "$ref": "#/$defs/matchUpPayload" },
        { "$ref": "#/$defs/textQuestionsPayload" },
        { "$ref": "#/$defs/multipleChoicePayload" },
        { "$ref": "#/$defs/quizPayload" },
        { "$ref": "#/$defs/markTheWordsPayload" },
        { "$ref": "#/$defs/fillInPayload" },
        { "$ref": "#/$defs/glossaryPayload" },
        { "$ref": "#/$defs/formBuildPayload" },
        { "$ref": "#/$defs/errorCorrectionPayload" },
        { "$ref": "#/$defs/paraphrasePayload" },
        { "$ref": "#/$defs/continueSentencePayload" },
        { "$ref": "#/$defs/roleplayDialogPayload" },
        { "$ref": "#/$defs/shortWritingPayload" },
        { "$ref": "#/$defs/audioListenRepeatPayload" },
        { "$ref": "#/$defs/modelAnswerDiscussionPayload" },
        { "$ref": "#/$defs/sentenceTransformationPayload" }
      ]
    },
    "answer_key": { "type": "object" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "generator", "gates"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "generator": { "type": "string", "minLength": 1 },
        "gates": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "true-false" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/trueFalsePayload" },
          "answer_key": { "$ref": "#/$defs/trueFalseAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "cloze" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/clozePayload" },
          "answer_key": { "$ref": "#/$defs/clozeAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "match-up" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/matchUpPayload" },
          "answer_key": { "$ref": "#/$defs/matchUpAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "text-questions" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/textQuestionsPayload" },
          "answer_key": { "$ref": "#/$defs/teacherGuidanceAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "multiple-choice" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/multipleChoicePayload" },
          "answer_key": { "$ref": "#/$defs/multipleChoiceAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "quiz" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/quizPayload" },
          "answer_key": { "$ref": "#/$defs/quizAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "mark-the-words" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/markTheWordsPayload" },
          "answer_key": { "$ref": "#/$defs/markTheWordsAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "fill-in" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/fillInPayload" },
          "answer_key": { "$ref": "#/$defs/fillInAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "glossary" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/glossaryPayload" },
          "answer_key": { "$ref": "#/$defs/teacherGuidanceAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "form-build" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/formBuildPayload" },
          "answer_key": { "$ref": "#/$defs/itemsAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "error-correction" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/errorCorrectionPayload" },
          "answer_key": { "$ref": "#/$defs/itemsAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "paraphrase" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/paraphrasePayload" },
          "answer_key": { "$ref": "#/$defs/itemsAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "continue-sentence" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/continueSentencePayload" },
          "answer_key": { "$ref": "#/$defs/teacherGuidanceAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "roleplay-dialog" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/roleplayDialogPayload" },
          "answer_key": { "$ref": "#/$defs/teacherGuidanceAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "short-writing" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/shortWritingPayload" },
          "answer_key": { "$ref": "#/$defs/teacherGuidanceAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "audio-listen-repeat" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/audioListenRepeatPayload" },
          "answer_key": { "$ref": "#/$defs/unscoredAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "model-answer-discussion" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/modelAnswerDiscussionPayload" },
          "answer_key": { "$ref": "#/$defs/modelAnswerDiscussionAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "sentence-transformation" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/sentenceTransformationPayload" },
          "answer_key": { "$ref": "#/$defs/sentenceTransformationAnswerKey" }
        }
      }
    }
  ],
  "$defs": {
    "trueFalsePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "true-false" },
        "instruction": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["statement", "correct"],
            "properties": {
              "statement": { "type": "string", "minLength": 1 },
              "correct": { "type": "boolean" },
              "explanation": { "type": "string" }
            }
          }
        }
      }
    },
    "clozePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "text", "blanks"],
      "properties": {
        "type": { "const": "cloze" },
        "instruction": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "blanks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "answer", "options"],
            "properties": {
              "id": { "type": "integer", "minimum": 1 },
              "answer": { "type": "string", "minLength": 1 },
              "options": {
                "type": "array",
                "minItems": 2,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "matchUpPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "pairs"],
      "properties": {
        "type": { "const": "match-up" },
        "instruction": { "type": "string", "minLength": 1 },
        "pairs": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["left", "right"],
            "properties": {
              "left": { "type": "string", "minLength": 1 },
              "right": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "textQuestionsPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "text-questions" },
        "instruction": { "type": "string", "minLength": 1 },
        "source_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Optional anchor excerpt or passage reference for comprehension tasks."
        },
        "items": { "$ref": "#/$defs/stringItems" }
      }
    },
    "multipleChoicePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "multiple-choice" },
        "instruction": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["prompt", "options"],
            "properties": {
              "prompt": { "type": "string", "minLength": 1 },
              "options": {
                "type": "array",
                "minItems": 2,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "quizPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "quiz" },
        "instruction": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["question", "options", "correct"],
            "properties": {
              "question": { "type": "string", "minLength": 1 },
              "options": {
                "type": "array",
                "minItems": 2,
                "maxItems": 6,
                "items": { "type": "string", "minLength": 1 }
              },
              "correct": {
                "type": "integer",
                "minimum": 0,
                "description": "0-based index of the correct option"
              },
              "explanation": { "type": "string" }
            }
          }
        }
      }
    },
    "markTheWordsPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "text", "target_words"],
      "properties": {
        "type": { "const": "mark-the-words" },
        "instruction": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "target_words": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "criteria": { "type": "string" }
      }
    },
    "fillInPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "fill-in" },
        "instruction": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sentence", "answer"],
            "properties": {
              "sentence": {
                "type": "string",
                "minLength": 1,
                "description": "Sentence with ____ or {answer} marking the blank"
              },
              "answer": { "type": "string", "minLength": 1 },
              "options": {
                "type": "array",
                "minItems": 2,
                "maxItems": 6,
                "items": { "type": "string", "minLength": 1 }
              },
              "explanation": { "type": "string" }
            }
          }
        }
      }
    },
    "glossaryPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "gloss_lang", "items"],
      "properties": {
        "type": { "const": "glossary" },
        "instruction": { "type": "string", "minLength": 1 },
        "gloss_lang": { "type": "string", "minLength": 1 },
        "items": { "$ref": "#/$defs/termGlossItems" }
      }
    },
    "formBuildPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "form-build" },
        "instruction": { "type": "string", "minLength": 1 },
        "items": { "$ref": "#/$defs/stringItems" }
      }
    },
    "errorCorrectionPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "error-correction" },
        "instruction": { "type": "string", "minLength": 1 },
        "items": { "$ref": "#/$defs/stringItems" }
      }
    },
    "paraphrasePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "paraphrase" },
        "instruction": { "type": "string", "minLength": 1 },
        "items": { "$ref": "#/$defs/stringItems" }
      }
    },
    "continueSentencePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "continue-sentence" },
        "instruction": { "type": "string", "minLength": 1 },
        "items": { "$ref": "#/$defs/stringItems" }
      }
    },
    "roleplayDialogPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "scenario", "prompts"],
      "properties": {
        "type": { "const": "roleplay-dialog" },
        "instruction": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "prompts": { "$ref": "#/$defs/stringItems" }
      }
    },
    "shortWritingPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "prompt"],
      "properties": {
        "type": { "const": "short-writing" },
        "prompt": { "type": "string", "minLength": 1 },
        "source_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Optional anchor excerpt or passage reference for the writing prompt."
        }
      }
    },
    "audioListenRepeatPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "asset_id", "segments"],
      "properties": {
        "type": { "const": "audio-listen-repeat" },
        "instruction": { "type": "string", "minLength": 1 },
        "asset_id": { "type": "string", "minLength": 1 },
        "segments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "start_ms", "duration_ms"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "start_ms": { "type": "integer", "minimum": 0 },
              "duration_ms": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "modelAnswerDiscussionPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "prompt", "rubric_checklist"],
      "properties": {
        "type": { "const": "model-answer-discussion" },
        "instruction": { "type": "string", "minLength": 1 },
        "prompt": { "type": "string", "minLength": 1 },
        "rubric_checklist": { "$ref": "#/$defs/stringItems" }
      }
    },
    "sentenceTransformationPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "sentence-transformation" },
        "instruction": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "source", "prompt"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "source": { "type": "string", "minLength": 1 },
              "prompt": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "stringItems": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "termGlossItems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["term", "gloss"],
        "properties": {
          "term": { "type": "string", "minLength": 1 },
          "gloss": { "type": "string", "minLength": 1 }
        }
      }
    },
    "trueFalseAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["index", "correct"],
            "properties": {
              "index": { "type": "integer", "minimum": 0 },
              "correct": { "type": "boolean" }
            }
          }
        }
      }
    },
    "clozeAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blanks"],
      "properties": {
        "blanks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "answer"],
            "properties": {
              "id": { "type": "integer", "minimum": 1 },
              "answer": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "matchUpAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pairs"],
      "properties": {
        "pairs": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["left_index", "right_index"],
            "properties": {
              "left_index": { "type": "integer", "minimum": 0 },
              "right_index": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "multipleChoiceAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["index", "correct"],
            "properties": {
              "index": { "type": "integer", "minimum": 0 },
              "correct": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "quizAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["index", "correct"],
            "properties": {
              "index": { "type": "integer", "minimum": 0 },
              "correct": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "markTheWordsAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_words"],
      "properties": {
        "target_words": { "$ref": "#/$defs/stringItems" }
      }
    },
    "fillInAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": { "$ref": "#/$defs/stringItems" }
      }
    },
    "itemsAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": { "items": { "$ref": "#/$defs/stringItems" } }
    },
    "teacherGuidanceAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["guidance"],
      "properties": {
        "guidance": { "type": "string", "minLength": 1 },
        "model_answers": { "$ref": "#/$defs/stringItems" },
        "model_answer": { "type": "string", "minLength": 1 },
        "rubric": { "type": "string", "minLength": 1 }
      }
    },
    "unscoredAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score"],
      "properties": {
        "score": { "type": "null" }
      }
    },
    "modelAnswerDiscussionAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_answer", "score"],
      "properties": {
        "model_answer": { "type": "string", "minLength": 1 },
        "score": { "type": "null" }
      }
    },
    "sentenceTransformationAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "accepted_answers"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "accepted_answers": { "$ref": "#/$defs/stringItems" }
            }
          }
        }
      }
    }
  }
}
