{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://learn-ukrainian.github.io/packages/activity-kit/lu.activity.v1.schema.json",
  "title": "Learn Ukrainian Activity v1",
  "description": "Public B1 activity envelope. Its payload discriminates the shipped widgets and the versionable lesson-document registry.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "title",
    "level",
    "payload",
    "answer_key",
    "provenance"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "type": {
      "enum": [
        "true-false",
        "cloze",
        "match-up",
        "text-questions",
        "multiple-choice",
        "glossary",
        "form-build",
        "error-correction",
        "paraphrase",
        "continue-sentence",
        "roleplay-dialog",
        "short-writing"
      ]
    },
    "title": { "type": "string", "minLength": 1 },
    "level": {
      "const": "b1",
      "description": "The public pilot contract is limited to the B1 scope."
    },
    "payload": {
      "oneOf": [
        { "$ref": "#/$defs/trueFalsePayload" },
        { "$ref": "#/$defs/clozePayload" },
        { "$ref": "#/$defs/matchUpPayload" },
        { "$ref": "#/$defs/textQuestionsPayload" },
        { "$ref": "#/$defs/multipleChoicePayload" },
        { "$ref": "#/$defs/glossaryPayload" },
        { "$ref": "#/$defs/formBuildPayload" },
        { "$ref": "#/$defs/errorCorrectionPayload" },
        { "$ref": "#/$defs/paraphrasePayload" },
        { "$ref": "#/$defs/continueSentencePayload" },
        { "$ref": "#/$defs/roleplayDialogPayload" },
        { "$ref": "#/$defs/shortWritingPayload" }
      ]
    },
    "answer_key": { "type": "object" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "generator", "gates"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "generator": { "type": "string", "minLength": 1 },
        "gates": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "true-false" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/trueFalsePayload" },
          "answer_key": { "$ref": "#/$defs/trueFalseAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "cloze" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/clozePayload" },
          "answer_key": { "$ref": "#/$defs/clozeAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "match-up" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/matchUpPayload" },
          "answer_key": { "$ref": "#/$defs/matchUpAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "text-questions" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/textQuestionsPayload" },
          "answer_key": { "$ref": "#/$defs/teacherGuidanceAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "multiple-choice" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/multipleChoicePayload" },
          "answer_key": { "$ref": "#/$defs/multipleChoiceAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "glossary" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/glossaryPayload" },
          "answer_key": { "$ref": "#/$defs/teacherGuidanceAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "form-build" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/formBuildPayload" },
          "answer_key": { "$ref": "#/$defs/itemsAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "error-correction" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/errorCorrectionPayload" },
          "answer_key": { "$ref": "#/$defs/itemsAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "paraphrase" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/paraphrasePayload" },
          "answer_key": { "$ref": "#/$defs/itemsAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "continue-sentence" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/continueSentencePayload" },
          "answer_key": { "$ref": "#/$defs/teacherGuidanceAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "roleplay-dialog" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/roleplayDialogPayload" },
          "answer_key": { "$ref": "#/$defs/teacherGuidanceAnswerKey" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "short-writing" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/shortWritingPayload" },
          "answer_key": { "$ref": "#/$defs/teacherGuidanceAnswerKey" }
        }
      }
    }
  ],
  "$defs": {
    "trueFalsePayload": {
      "$ref": "https://learn-ukrainian.github.io/schemas/activity-v2.schema.json#/$defs/true-false"
    },
    "clozePayload": {
      "allOf": [
        {
          "$ref": "https://learn-ukrainian.github.io/schemas/activity-v2.schema.json#/$defs/cloze"
        },
        { "required": ["blanks"] }
      ]
    },
    "matchUpPayload": {
      "$ref": "https://learn-ukrainian.github.io/schemas/activity-v2.schema.json#/$defs/match-up"
    },
    "textQuestionsPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "text-questions" },
        "instruction": { "type": "string", "minLength": 1 },
        "items": { "$ref": "#/$defs/stringItems" }
      }
    },
    "multipleChoicePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "multiple-choice" },
        "instruction": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["prompt", "options"],
            "properties": {
              "prompt": { "type": "string", "minLength": 1 },
              "options": {
                "type": "array",
                "minItems": 2,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "glossaryPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "gloss_lang", "items"],
      "properties": {
        "type": { "const": "glossary" },
        "instruction": { "type": "string", "minLength": 1 },
        "gloss_lang": { "type": "string", "minLength": 1 },
        "items": { "$ref": "#/$defs/termGlossItems" }
      }
    },
    "formBuildPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "form-build" },
        "instruction": { "type": "string", "minLength": 1 },
        "items": { "$ref": "#/$defs/stringItems" }
      }
    },
    "errorCorrectionPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "error-correction" },
        "instruction": { "type": "string", "minLength": 1 },
        "items": { "$ref": "#/$defs/stringItems" }
      }
    },
    "paraphrasePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "paraphrase" },
        "instruction": { "type": "string", "minLength": 1 },
        "items": { "$ref": "#/$defs/stringItems" }
      }
    },
    "continueSentencePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "items"],
      "properties": {
        "type": { "const": "continue-sentence" },
        "instruction": { "type": "string", "minLength": 1 },
        "items": { "$ref": "#/$defs/stringItems" }
      }
    },
    "roleplayDialogPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "instruction", "scenario", "prompts"],
      "properties": {
        "type": { "const": "roleplay-dialog" },
        "instruction": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "prompts": { "$ref": "#/$defs/stringItems" }
      }
    },
    "shortWritingPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "prompt"],
      "properties": {
        "type": { "const": "short-writing" },
        "prompt": { "type": "string", "minLength": 1 }
      }
    },
    "stringItems": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "termGlossItems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["term", "gloss"],
        "properties": {
          "term": { "type": "string", "minLength": 1 },
          "gloss": { "type": "string", "minLength": 1 }
        }
      }
    },
    "trueFalseAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["index", "correct"],
            "properties": {
              "index": { "type": "integer", "minimum": 0 },
              "correct": { "type": "boolean" }
            }
          }
        }
      }
    },
    "clozeAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blanks"],
      "properties": {
        "blanks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "answer"],
            "properties": {
              "id": { "type": "integer", "minimum": 1 },
              "answer": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "matchUpAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pairs"],
      "properties": {
        "pairs": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["left_index", "right_index"],
            "properties": {
              "left_index": { "type": "integer", "minimum": 0 },
              "right_index": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "multipleChoiceAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["index", "correct"],
            "properties": {
              "index": { "type": "integer", "minimum": 0 },
              "correct": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "itemsAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": { "items": { "$ref": "#/$defs/stringItems" } }
    },
    "teacherGuidanceAnswerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["guidance"],
      "properties": { "guidance": { "type": "string", "minLength": 1 } }
    }
  }
}
