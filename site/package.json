{
  "name": "starlight",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "atlas:build-db": "cd .. && .venv/bin/python -m scripts.atlas.atlas_db --db data/atlas.db",
    "atlas:build-search": "cd .. && .venv/bin/python -m scripts.audit.generate_search_index --db data/atlas.db",
    "atlas:perf": "node ./scripts/benchmark-atlas-db.mjs",
    "atlas:validate-aliases": "cd .. && .venv/bin/python -m scripts.atlas.atlas_db --db data/atlas.db --validate-aliases-only",
    "hydrate": "node ./scripts/hydrate-manifest.mjs && npm run atlas:build-db && npm run atlas:build-search && node ./scripts/hydrate-practice-deck.mjs && node --experimental-strip-types ./scripts/hydrate-lexicon-api-shards.ts",
    "hydrate:manifest": "node ./scripts/hydrate-manifest.mjs && npm run atlas:build-db",
    "hydrate:practice": "node ./scripts/hydrate-practice-deck.mjs",
    "dev": "npm run hydrate && astro dev",
    "start": "npm run dev",
    "build": "npm run hydrate && astro build",
    "build:full": "npm run hydrate && BUILD_ETYMOLOGY_ROUTES=1 astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "npm run hydrate && vitest run",
    "test:watch": "npm run hydrate && vitest --watch",
    "test:coverage": "npm run hydrate && vitest run --coverage"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@mdx-js/mdx": "^3.1.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.6",
    "better-sqlite3": "^12.11.1",
    "playwright": "^1.60.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.7",
    "rehype-mermaid": "^3.0.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.35.2",
    "ts-fsrs": "^5.4.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^4.1.8",
    "happy-dom": "^20.10.6",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "yaml-language-server": "1.23.0",
    "esbuild": ">=0.28.1",
    "vite": ">=8.0.13",
    "js-yaml": ">=4.2.0",
    "markdown-it": ">=14.2.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.28.1": true
  }
}
