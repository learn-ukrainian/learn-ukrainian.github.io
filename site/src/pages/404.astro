---
import CourseLayout from '../layouts/CourseLayout.astro';
import ChromeText from '../components/chrome/ChromeText.astro';
---

<CourseLayout
  title="Page Not Found"
  description="The requested page is not part of the public learner UI."
  eyebrow="404"
  subtitle="Hidden drafts and unknown routes fail clearly, with useful recovery paths."
  currentPath="/404/"
  heroVariant="unavailable"
  wide
>
  <section class="route-state-card big">
    <p class="state-code">404</p>
    <h2><ChromeText k="state.notFoundTitle" /></h2>
    <p><ChromeText k="state.notFoundBody" /></p>
    <div class="state-actions">
      <a href="/a1/"><ChromeText k="nav.a1" /></a>
      <a href="/b1/"><ChromeText k="nav.b1" /></a>
      <a href="/search/"><ChromeText k="nav.search" /></a>
      <a href="/lexicon/"><ChromeText k="nav.atlas" /></a>
    </div>
  </section>
</CourseLayout>
