---
import CourseLayout from '../layouts/CourseLayout.astro';
import ChromeText from '../components/chrome/ChromeText.astro';
import type { ChromeKey } from '../lib/i18n/chrome';
import curriculumStats from '../data/curriculum-stats.json';

type TrackStats = Record<string, { modules?: number } | number>;

type TrackRow = {
  id: string;
  label: string;
  titleKey: ChromeKey;
  statusKey: ChromeKey;
  href?: string;
};

const stats = curriculumStats as TrackStats;
const moduleCount = (id: string) => {
  const entry = stats[id];
  return typeof entry === 'object' && entry ? entry.modules ?? 0 : 0;
};

const coreTracks: TrackRow[] = [
  { id: 'a1', label: 'A1', titleKey: 'home.track.beginner', statusKey: 'status.released' },
  { id: 'a2', label: 'A2', titleKey: 'home.track.preIntermediate', statusKey: 'status.released' },
  { id: 'b1', label: 'B1', titleKey: 'home.track.intermediate', statusKey: 'status.released' },
  { id: 'b2', label: 'B2', titleKey: 'home.track.upperIntermediate', statusKey: 'status.preview' },
  { id: 'c1', label: 'C1', titleKey: 'home.track.advanced', statusKey: 'status.planned' },
  { id: 'c2', label: 'C2', titleKey: 'home.track.mastery', statusKey: 'status.longRange' },
];

const seminarTracks: TrackRow[] = [
  { id: 'folk', label: 'FOLK', titleKey: 'home.seminar.folk', statusKey: 'status.previewLive', href: '/folk/' },
  { id: 'bio', label: 'BIO', titleKey: 'level.bio.name', statusKey: 'status.plannedSeminar' },
  { id: 'hist', label: 'HIST', titleKey: 'home.seminar.hist', statusKey: 'status.plannedSeminar' },
  { id: 'istorio', label: 'ISTORIO', titleKey: 'level.istorio.name', statusKey: 'status.plannedSeminar' },
  { id: 'lit', label: 'LIT', titleKey: 'home.seminar.lit', statusKey: 'status.plannedSeminar' },
  { id: 'lit-essay', label: 'LIT-ESSAY', titleKey: 'home.seminar.litEssay', statusKey: 'status.plannedSeminar' },
  { id: 'lit-hist-fic', label: 'LIT-HIST-FIC', titleKey: 'home.seminar.litHistFic', statusKey: 'status.plannedSeminar' },
  { id: 'lit-fantastika', label: 'LIT-FANTASTIKA', titleKey: 'home.seminar.litFantastika', statusKey: 'status.plannedSeminar' },
  { id: 'lit-war', label: 'LIT-WAR', titleKey: 'home.seminar.litWar', statusKey: 'status.plannedSeminar' },
  { id: 'lit-humor', label: 'LIT-HUMOR', titleKey: 'home.seminar.litHumor', statusKey: 'status.plannedSeminar' },
  { id: 'lit-youth', label: 'LIT-YOUTH', titleKey: 'home.seminar.litYouth', statusKey: 'status.plannedSeminar' },
  { id: 'lit-drama', label: 'LIT-DRAMA', titleKey: 'home.seminar.litDrama', statusKey: 'status.plannedSeminar' },
  { id: 'oes', label: 'OES', titleKey: 'level.oes.name', statusKey: 'status.plannedSeminar' },
  { id: 'ruth', label: 'RUTH', titleKey: 'home.seminar.ruth', statusKey: 'status.plannedSeminar' },
].filter((track) => moduleCount(track.id) > 0);
---

<CourseLayout
  title="Learn Ukrainian"
  description="An English learner interface for released A1, A2, and B1 Ukrainian courses, a B2 preview, and the Word Atlas reference tool."
  eyebrowKey="home.eyebrow"
  subtitle="A practical English interface for learning Ukrainian."
  currentPath="/"
  wide
>
  <section class="home-intro">
    <div>
      <p class="home-kicker">Learn Ukrainian</p>
      <h2><ChromeText k="home.introHeading" /></h2>
      <p>
        <ChromeText k="home.introBody" />
      </p>
      <div class="home-actions">
        <a class="home-primary" href="/a1/"><ChromeText k="home.actionStartA1" /></a>
        <a class="home-secondary" href="/b1/"><ChromeText k="home.actionOpenB1Preview" /></a>
      </div>
    </div>
    <aside class="roadmap-panel" aria-label="Roadmap">
      <div><strong>A1</strong><span><ChromeText k="home.roadmapA1" /></span></div>
      <div><strong>A2</strong><span><ChromeText k="home.roadmapA2" /></span></div>
      <div><strong>B1</strong><span><ChromeText k="home.roadmapB1" /></span></div>
      <div><strong><ChromeText k="nav.atlas" /></strong><span><ChromeText k="home.roadmapAtlasDesc" /></span></div>
      <div><strong><ChromeText k="home.roadmapSeminars" /></strong><span><ChromeText k="home.roadmapSeminarsNote" /></span></div>
    </aside>
  </section>

  <section>
    <h2><ChromeText k="home.availableNow" /></h2>
    <div class="lu-card-grid">
      <a class="lu-card" href="/a1/">
        <span class="track-badge a1">A1</span>
        <h3><ChromeText k="home.track.beginner" /></h3>
        <p><ChromeText k="home.cardA1Desc" /></p>
      </a>
      <a class="lu-card" href="/a2/">
        <span class="track-badge a2">A2</span>
        <h3><ChromeText k="home.track.preIntermediate" /></h3>
        <p><ChromeText k="home.cardA2Desc" /></p>
      </a>
      <a class="lu-card" href="/b1/">
        <span class="track-badge b1"><ChromeText k="nav.b1" /></span>
        <h3><ChromeText k="home.track.intermediate" /></h3>
        <p><ChromeText k="home.cardB1Desc" /></p>
      </a>
      <a class="lu-card" href="/lexicon/">
        <span class="track-badge atlas"><ChromeText k="label.reference" /></span>
        <h3><ChromeText k="nav.atlas" /></h3>
        <p><ChromeText k="home.cardAtlasDesc" /></p>
      </a>
      <a class="lu-card" href="/readings/">
        <span class="track-badge atlas"><ChromeText k="label.reference" /></span>
        <h3><ChromeText k="nav.readings" /></h3>
        <p><ChromeText k="home.cardReadingsDesc" /></p>
      </a>
    </div>
  </section>

  <section class="track-inventory" aria-labelledby="upcoming-tracks">
    <div class="section-heading">
      <h2 id="upcoming-tracks"><ChromeText k="home.courseMapHeading" /></h2>
      <p>
        <ChromeText k="home.courseMapBody" />
      </p>
    </div>

    <div class="track-inventory-grid">
      <section class="track-column">
        <h3><ChromeText k="home.courseLadder" /></h3>
        <ul>
          {coreTracks.map((track) => (
            <li>
              <span class="track-code">{track.label}</span>
              <span class="track-title"><ChromeText k={track.titleKey} /></span>
              <span class="track-meta">{moduleCount(track.id)} <ChromeText k="stats.modules" /> · <ChromeText k={track.statusKey} /></span>
            </li>
          ))}
        </ul>
      </section>
      <section class="track-column">
        <h3><ChromeText k="home.seminarTracks" /></h3>
        <ul>
          {seminarTracks.map((track) => (
            <li>
              {track.href ? (
                <a class="track-link" href={track.href}>
                  <span class="track-code">{track.label}</span>
                  <span class="track-title"><ChromeText k={track.titleKey} /></span>
                  <span class="track-meta">{moduleCount(track.id)} <ChromeText k="stats.modules" /> · <ChromeText k={track.statusKey} /></span>
                </a>
              ) : (
                <Fragment>
                  <span class="track-code">{track.label}</span>
                  <span class="track-title"><ChromeText k={track.titleKey} /></span>
                  <span class="track-meta">{moduleCount(track.id)} <ChromeText k="stats.modules" /> · <ChromeText k={track.statusKey} /></span>
                </Fragment>
              )}
            </li>
          ))}
        </ul>
      </section>
    </div>
  </section>

  <style>
    .home-intro {
      display: grid;
      grid-template-columns: minmax(0, 1.5fr) minmax(260px, 0.8fr);
      gap: 28px;
      align-items: stretch;
      margin: 10px 0 42px;
    }
    .home-kicker {
      margin: 0 0 8px;
      color: var(--lu-blue);
      font-size: 0.82rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .home-intro h2 {
      margin-top: 0;
      color: var(--lu-gray-900);
      border: 0;
      font-size: 2rem;
      max-width: 720px;
    }
    .home-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 22px;
    }
    .home-primary,
    .home-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 0 22px;
      border-radius: 8px;
      font-weight: 800;
      text-decoration: none;
    }
    .home-primary {
      background: var(--lu-yellow);
      color: var(--lu-on-yellow);
    }
    .home-secondary {
      border: 2px solid var(--lu-blue);
      color: var(--lu-blue);
    }
    .roadmap-panel {
      display: grid;
      gap: 10px;
      padding: 18px;
      border-radius: var(--lu-radius);
      background: var(--lu-surface-raised);
      box-shadow: var(--lu-shadow);
    }
    .roadmap-panel div {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      padding: 10px 0;
      border-bottom: 1px solid var(--lu-border);
    }
    .roadmap-panel div:last-child {
      border-bottom: 0;
    }
    .roadmap-panel strong {
      color: var(--lu-blue);
    }
    .roadmap-panel span {
      color: var(--lu-gray-600);
      font-size: 0.86rem;
      text-align: right;
    }
    .track-badge {
      display: inline-block;
      margin-bottom: 10px;
      padding: 3px 10px;
      border-radius: 6px;
      color: #FFFFFF;
      font-size: 0.76rem;
      font-weight: 900;
    }
    .track-badge.a1 { background: var(--lu-green); }
    .track-badge.a2 { background: #1565C0; }
    .track-badge.b1 { background: #E65100; }
    .track-badge.atlas { background: var(--lu-teal); }
    /* In dark mode --lu-green/--lu-teal go pale, so white text fails. */
    :global([data-theme='dark']) .track-badge.a1,
    :global([data-theme='dark']) .track-badge.atlas {
      color: var(--lu-on-yellow);
    }
    .section-heading {
      max-width: 760px;
      margin-bottom: 16px;
    }
    .section-heading p {
      margin-top: 0;
      color: var(--lu-gray-600);
    }
    .track-inventory {
      margin-top: 38px;
    }
    .track-inventory-grid {
      display: grid;
      grid-template-columns: minmax(260px, 0.75fr) minmax(0, 1.25fr);
      gap: 18px;
      align-items: start;
    }
    .track-column {
      border: 1px solid var(--lu-border);
      border-radius: var(--lu-radius);
      background: var(--lu-surface-raised);
      box-shadow: var(--lu-shadow);
      overflow: hidden;
    }
    .track-column h3 {
      margin: 0;
      padding: 14px 16px;
      border-bottom: 1px solid var(--lu-border);
      color: var(--lu-blue);
      font-size: 0.96rem;
    }
    .track-column ul {
      display: grid;
      gap: 0;
      margin: 0;
      padding: 0;
      list-style: none;
    }
    .track-column li {
      display: grid;
      grid-template-columns: minmax(92px, 0.38fr) minmax(130px, 0.72fr) minmax(150px, 0.74fr);
      gap: 10px;
      align-items: center;
      padding: 11px 16px;
      border-bottom: 1px solid var(--lu-border);
      font-size: 0.86rem;
    }
    .track-column li:last-child {
      border-bottom: 0;
    }
    .track-code {
      color: var(--lu-blue);
      font-weight: 900;
      white-space: nowrap;
    }
    .track-title {
      color: var(--lu-gray-900);
      font-weight: 700;
    }
    .track-meta {
      color: var(--lu-gray-600);
      font-size: 0.8rem;
      text-align: right;
    }
    /* Clickable seminar rows (e.g. the Folklore preview) keep the parent
       grid layout via display:contents so the three columns still align. */
    .track-link {
      display: contents;
      cursor: pointer;
    }
    .track-link:hover .track-title {
      color: var(--lu-blue);
      text-decoration: underline;
    }
    @media (max-width: 820px) {
      .home-intro {
        grid-template-columns: 1fr;
      }
      .home-intro h2 {
        font-size: 1.55rem;
      }
      .track-inventory-grid {
        grid-template-columns: 1fr;
      }
      .track-column li {
        grid-template-columns: 1fr;
        gap: 2px;
      }
      .track-meta {
        text-align: left;
      }
    }
  </style>
</CourseLayout>
