---
import CourseLayout from "../layouts/CourseLayout.astro";
import DailyWords from "../lexicon/DailyWords.astro";

const frontmatter = {
  title: "Слова дня / Words of the Day",
  description: "A daily Word Atlas surface with CEFR-capped Ukrainian vocabulary picks.",
};
---

<CourseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  currentPath="/words-of-the-day/"
  heroVariant="lexicon"
  wide
  showHero={false}
>
  <main class="word-atlas words-day-page" data-word-atlas>
    <section class="words-day-hero" aria-labelledby="words-day-title">
      <span class="words-day-badge">Слова дня</span>
      <h1 id="words-day-title">Слова дня / Words of the Day</h1>
      <p>Щоденна добірка слів з Атласу, обмежена вашим поточним рівнем.</p>
      <a class="words-day-practice-cta" href="/words-of-the-day/practice/">
        Практика — інтервальне повторення вашого рівня →
      </a>
    </section>

    {/* Atlas daily pool count aligns with practice density (#5502): 12 first. */}
    <DailyWords
      title="Добірка на сьогодні"
      description="Слова оновлюються за календарною датою; кожна картка веде до повної статті Атласу."
      count={12}
      showLevelSelector
    />
  </main>
</CourseLayout>

<style>
  .words-day-page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 2rem 1.5rem 3.5rem;
  }

  .words-day-hero {
    max-width: 820px;
    margin-bottom: 1.35rem;
  }

  .words-day-badge {
    display: inline-flex;
    align-items: center;
    min-height: 1.75rem;
    padding: 0 0.65rem;
    border-radius: 4px;
    background: var(--lu-state-active);
    color: var(--lu-primary);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .words-day-hero h1 {
    margin: 0.55rem 0 0;
    color: var(--lu-text);
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1;
  }

  .words-day-hero p {
    max-width: 680px;
    margin: 0.75rem 0 0;
    color: var(--lu-text-muted);
    font-size: 1.02rem;
    line-height: 1.55;
  }

  /* `.word-atlas.words-day-page` (0,3,0) beats the global `.lu-content .word-atlas a`
     (0,2,1) link color so the CTA text stays dark on the gold accent fill. */
  .word-atlas.words-day-page .words-day-practice-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    min-height: 3rem;
    margin-top: 1.1rem;
    padding: 0 1.25rem;
    border: 1px solid var(--lu-accent);
    border-radius: 12px;
    background: var(--lu-accent);
    color: var(--lu-on-accent);
    font-size: 1.02rem;
    font-weight: 900;
    letter-spacing: 0.01em;
    text-decoration: none;
    box-shadow:
      0 1px 0 color-mix(in srgb, #fff 35%, transparent) inset,
      0 4px 14px color-mix(in srgb, var(--lu-accent) 45%, transparent);
  }

  .words-day-practice-cta:hover,
  .words-day-practice-cta:focus-visible {
    outline: none;
    filter: brightness(1.04);
    box-shadow:
      0 0 0 3px var(--lu-state-active),
      0 6px 18px color-mix(in srgb, var(--lu-accent) 55%, transparent);
  }

  @media (max-width: 760px) {
    .words-day-page {
      padding: 1.25rem 1rem 2.75rem;
    }

    .word-atlas.words-day-page .words-day-practice-cta {
      width: 100%;
      min-height: 3.1rem;
    }
  }

  :global(.words-day-page .lexicon-daily-section) {
    padding: 0;
  }
</style>
