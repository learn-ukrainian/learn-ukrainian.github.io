---
/**
 * Атлас слів (Лексикон) — per-lemma detail route.
 */
import CourseLayout from "../../layouts/CourseLayout.astro";
import WordAtlasArticle from "../../lexicon/WordAtlasArticle.astro";
import manifest from "../../data/lexicon-manifest.json";

interface LexiconEntry {
  lemma: string;
  url_slug: string;
  gloss: string | null;
}

interface LexiconManifest {
  version: string;
  generated_at: string;
  entries: LexiconEntry[];
}

const data = manifest as LexiconManifest;

export async function getStaticPaths() {
  return (manifest as LexiconManifest).entries.map((entry) => ({
    params: { lemma: entry.url_slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: LexiconEntry };
const frontmatter = {
  title: entry.lemma,
  description: entry.gloss ? `${entry.lemma} — ${entry.gloss}` : `${entry.lemma} — стаття Лексикону`,
};
---

<CourseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  currentPath={`/lexicon/${entry.url_slug}/`}
  heroVariant="lexicon"
  wide
  showHero={false}
>
  <WordAtlasArticle
    entry={entry}
    allEntries={data.entries}
    generatedAt={data.generated_at}
    manifestVersion={data.version}
  />
</CourseLayout>
