---
/**
 * Хрестоматія — primary-source reading detail page.
 * Global, cross-track: renders one text from the `readings` collection, with a
 * sidebar listing the whole library. Reuses CourseLayout + <PrimaryReading> so it
 * matches the rest of the site by construction.
 */
import { getCollection, render } from 'astro:content';
import CourseLayout from '../../layouts/CourseLayout.astro';

const normalizeDocId = (id: string) => id.replace(/\.mdx?$/, '').replace(/\/index$/, '');

export async function getStaticPaths() {
  const readings = await getCollection('readings');
  const docs = await getCollection('docs');
  return readings.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, readings, docs },
  }));
}

const { entry, readings, docs } = Astro.props;
const { Content } = await render(entry);

const pluralTexts = (n: number) => (n === 1 ? 'text' : 'texts');

const sorted = [...readings].sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999) || a.data.title.localeCompare(b.data.title, 'uk'),
);
const links = sorted.map((r) => ({
  href: `/readings/${r.id}/`,
  label: r.data.title,
  num: '📜',
  active: r.id === entry.id,
}));

const docsBySlug = new Map(
  docs.map((doc) => {
    const id = normalizeDocId(doc.id);
    const slug = id.split('/').pop() ?? id;
    return [slug, { href: `/${id}/`, title: doc.data.title }];
  }),
);
const taughtInLinks = (entry.data.taught_in ?? [])
  .map((slug) => {
    const doc = docsBySlug.get(slug);
    return doc ? { ...doc, slug } : { href: null, title: slug, slug };
  });

const sidebar = {
  backHref: '/readings/',
  backLabel: 'Reading reference',
  titleLabel: 'Reading reference',
  navLabel: 'Primary sources',
  positionLabel: `${links.length} ${pluralTexts(links.length)}`,
  progressDone: 0,
  progressTotal: links.length,
  links,
};
---

<CourseLayout
  title={entry.data.title}
  description={entry.data.excerpt}
  eyebrow="Reading reference"
  subtitle={entry.data.excerpt}
  currentPath={`/readings/${entry.id}/`}
  heroVariant="readings"
  navItems={[
    { href: '/', label: 'Home' },
    { href: '/readings/', label: 'Reading reference' },
    { href: `/readings/${entry.id}/`, label: entry.data.title },
  ]}
  sidebar={sidebar}
>
  {taughtInLinks.length ? (
    <p class="reading-taught-in">
      <strong>Вивчається в:</strong>{' '}
      {taughtInLinks.map((item, index) => (
        <>
          {index > 0 ? ', ' : ''}
          {item.href ? <a href={item.href}>{item.title}</a> : <span>{item.title}</span>}
        </>
      ))}
    </p>
  ) : null}
  <Content />
</CourseLayout>
