<section class="atlas-section lexicon-browse" aria-labelledby="lexicon-browse-title" data-lexicon-browse>
  <div class="lexicon-browse-heading">
    <h2 id="lexicon-browse-title">Перегляд А-Я</h2>
    <p>Виберіть літеру й рівень, щоб переглянути словникові статті Атласу.</p>
  </div>

  <div class="lexicon-browse-controls">
    <div class="lexicon-browse-control" aria-labelledby="lexicon-browse-letter-label">
      <span id="lexicon-browse-letter-label" class="lexicon-browse-label">Літера</span>
      <div class="lexicon-browse-chip-row" data-letter-list></div>
    </div>

    <div class="lexicon-browse-control" aria-labelledby="lexicon-browse-level-label">
      <span id="lexicon-browse-level-label" class="lexicon-browse-label">Рівень</span>
      <div class="lexicon-browse-chip-row" data-level-list></div>
    </div>
  </div>

  <p class="lexicon-browse-status" data-browse-status>Завантажуємо слова...</p>
  <ul class="lexicon-browse-results" data-browse-results aria-live="polite"></ul>
</section>

<script>
  import {
    CEFR_LEVELS,
    filterRowsByLetter,
    filterRowsByLevel,
    normalizeLevelFilter,
    parseCefrLevel,
    populatedUkrainianLetters,
    type CefrLevel,
    type LevelFilter,
    type LexiconBrowseRow,
    type UkrainianLetter,
  } from "../lib/lexicon/levels";

  const browseRoot = document.querySelector<HTMLElement>("[data-lexicon-browse]");
  const letterList = browseRoot?.querySelector<HTMLElement>("[data-letter-list]");
  const levelList = browseRoot?.querySelector<HTMLElement>("[data-level-list]");
  const status = browseRoot?.querySelector<HTMLElement>("[data-browse-status]");
  const resultsList = browseRoot?.querySelector<HTMLUListElement>("[data-browse-results]");

  const esc = (value: unknown): string =>
    String(value ?? "").replace(
      /[&<>"']/g,
      (c) =>
        ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        })[c] ?? c,
    );

  const isBrowseRow = (value: unknown): value is LexiconBrowseRow => {
    if (!value || typeof value !== "object") return false;
    const row = value as Partial<LexiconBrowseRow>;
    return typeof row.l === "string" && typeof row.s === "string";
  };

  const renderLevelButton = (level: LevelFilter, label: string, activeLevel: LevelFilter): string =>
    `<button class="lexicon-browse-chip" type="button" data-level="${esc(level)}" aria-pressed="${
      level === activeLevel ? "true" : "false"
    }">${esc(label)}</button>`;

  const renderLetterButton = (
    letter: UkrainianLetter,
    activeLetter: UkrainianLetter | null,
  ): string =>
    `<button class="lexicon-browse-chip letter" type="button" data-letter="${esc(letter)}" aria-pressed="${
      letter === activeLetter ? "true" : "false"
    }">${esc(letter)}</button>`;

  const renderResult = (row: LexiconBrowseRow): string => {
    const href = `/lexicon/${encodeURIComponent(row.s)}/`;
    const cefr = parseCefrLevel(row.c);
    return `<li class="lexicon-browse-item">
      <a class="lexicon-browse-link" href="${href}">
        <span class="lexicon-browse-lemma">${esc(row.l)}</span>
        ${row.g ? `<span class="lexicon-browse-gloss">${esc(row.g)}</span>` : ""}
        ${cefr ? `<span class="lexicon-browse-cefr">${esc(cefr)}</span>` : ""}
      </a>
    </li>`;
  };

  if (browseRoot && letterList && levelList && status && resultsList) {
    let rows: LexiconBrowseRow[] = [];
    let activeLevel: LevelFilter = "all";
    let activeLetter: UkrainianLetter | null = null;

    const rowsForLevel = () => filterRowsByLevel(rows, activeLevel);

    const renderLevels = () => {
      const populated = new Set(
        rows.map((row) => parseCefrLevel(row.c)).filter((level): level is CefrLevel => Boolean(level)),
      );
      const levels = CEFR_LEVELS.filter((level) => populated.has(level));
      if (activeLevel !== "all" && !levels.includes(activeLevel)) activeLevel = "all";
      levelList.innerHTML = [
        renderLevelButton("all", "Усі", activeLevel),
        ...levels.map((level) => renderLevelButton(level, level, activeLevel)),
      ].join("");
    };

    const renderLetters = () => {
      const letters = populatedUkrainianLetters(rowsForLevel());
      if (!activeLetter || !letters.includes(activeLetter)) {
        activeLetter = letters[0] ?? null;
      }
      letterList.innerHTML = letters.map((letter) => renderLetterButton(letter, activeLetter)).join("");
    };

    const renderResults = () => {
      if (!activeLetter) {
        resultsList.innerHTML = "";
        status.textContent = "Немає слів для вибраного фільтра.";
        return;
      }

      const results = filterRowsByLetter(rowsForLevel(), activeLetter).sort((a, b) =>
        a.l.localeCompare(b.l, "uk-UA"),
      );
      resultsList.innerHTML = results.map(renderResult).join("");
      status.textContent = `${activeLetter} · ${results.length} слів`;
    };

    const renderBrowse = () => {
      renderLevels();
      renderLetters();
      renderResults();
    };

    letterList.addEventListener("click", (event) => {
      const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-letter]");
      if (!button) return;
      activeLetter = button.dataset.letter as UkrainianLetter;
      renderLetters();
      renderResults();
    });

    levelList.addEventListener("click", (event) => {
      const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-level]");
      if (!button) return;
      activeLevel = normalizeLevelFilter(button.dataset.level);
      renderBrowse();
    });

    const loadBrowseRows = async () => {
      try {
        const response = await fetch("/lexicon/search-index.json");
        if (!response.ok) throw new Error(`Search index request failed: ${response.status}`);
        const data = await response.json();
        rows = Array.isArray(data) ? data.filter(isBrowseRow) : [];
        if (rows.length === 0) {
          status.textContent = "Атлас поки що не має слів для перегляду.";
          return;
        }
        renderBrowse();
      } catch {
        status.textContent = "Не вдалося завантажити А-Я перегляд.";
      }
    };

    loadBrowseRows();
  }
</script>

<style>
  .lexicon-browse {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  .lexicon-browse-heading {
    margin-bottom: 1.2rem;
  }

  .lexicon-browse-heading h2 {
    margin: 0;
    color: var(--lu-text);
    font-size: clamp(1.55rem, 3vw, 2.15rem);
  }

  .lexicon-browse-heading p,
  .lexicon-browse-status {
    margin: 0.35rem 0 0;
    color: var(--lu-text-muted);
    line-height: 1.55;
  }

  .lexicon-browse-controls {
    display: grid;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .lexicon-browse-control {
    display: grid;
    gap: 0.5rem;
  }

  .lexicon-browse-label {
    color: var(--lu-text);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .lexicon-browse-chip-row {
    display: flex;
    gap: 0.45rem;
    max-width: 100%;
    overflow-x: auto;
    padding-bottom: 0.15rem;
    scrollbar-width: thin;
  }

  .lexicon-browse-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    padding: 0 0.85rem;
    border: 1px solid var(--lu-border);
    border-radius: 8px;
    background: var(--lu-surface);
    color: var(--lu-text);
    cursor: pointer;
    flex: 0 0 auto;
    font: inherit;
    font-size: 0.95rem;
    font-weight: 900;
    white-space: nowrap;
  }

  .lexicon-browse-chip:hover,
  .lexicon-browse-chip:focus-visible {
    border-color: var(--lu-primary);
    outline: none;
    box-shadow: 0 0 0 3px var(--lu-state-active);
  }

  .lexicon-browse-chip[aria-pressed="true"] {
    border-color: var(--lu-primary);
    background: var(--lu-primary);
    color: #fff;
  }

  .lexicon-browse-status {
    min-height: 1.5rem;
    margin-bottom: 0.85rem;
  }

  .lexicon-browse-results {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .lexicon-browse-item {
    min-width: 0;
  }

  .lexicon-browse-link {
    display: grid;
    min-height: 6.5rem;
    gap: 0.45rem;
    align-content: start;
    padding: 0.9rem 1rem;
    border: 1px solid var(--lu-border);
    border-radius: 8px;
    background: var(--lu-surface);
    color: var(--lu-text);
    text-decoration: none;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  }

  .lexicon-browse-link:hover,
  .lexicon-browse-link:focus-visible {
    border-color: var(--lu-primary);
    outline: none;
    box-shadow: 0 0 0 3px var(--lu-state-active);
  }

  .lexicon-browse-lemma {
    font-weight: 900;
    line-height: 1.25;
  }

  .lexicon-browse-gloss {
    color: var(--lu-text-muted);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .lexicon-browse-cefr {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 1.35rem;
    margin-top: auto;
    padding: 0 0.45rem;
    border-radius: 4px;
    background: var(--lu-state-active);
    color: var(--lu-primary);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  @media (max-width: 680px) {
    .lexicon-browse {
      padding: 0 1rem 3rem;
    }

    .lexicon-browse-results {
      grid-template-columns: 1fr;
    }
  }
</style>
