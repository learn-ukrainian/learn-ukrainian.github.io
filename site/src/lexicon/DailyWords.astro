---
import { CEFR_LEVELS } from "../lib/lexicon/levels";

type Props = {
  title?: string;
  description?: string;
  count?: number;
  showLevelSelector?: boolean;
};

const {
  title = "Слова дня",
  description = "Коротка щоденна добірка для повторення й відкриття словникових статей.",
  count = 8,
  showLevelSelector = false,
} = Astro.props as Props;

const dailyCount = Math.max(1, Math.floor(count));
---

<section
  class="atlas-section lexicon-daily-section"
  aria-labelledby="lexicon-daily-title"
  data-daily-words
  data-daily-count={dailyCount}
  data-daily-level-selector={showLevelSelector ? "true" : "false"}
>
  <div class="lexicon-daily-heading">
    <h2 id="lexicon-daily-title">{title}</h2>
    <p>{description}</p>
  </div>

  {showLevelSelector && (
    <div class="lexicon-daily-controls" aria-label="Learner level">
      <span class="lexicon-daily-control-label">Рівень</span>
      <div class="lexicon-daily-levels" role="list" data-daily-levels>
        {CEFR_LEVELS.map((level) => (
          <button
            class="lexicon-daily-level-chip"
            type="button"
            data-daily-level={level}
            aria-pressed={level === "A1" ? "true" : "false"}
          >
            {level}
          </button>
        ))}
      </div>
    </div>
  )}

  <p class="lexicon-daily-status" data-daily-status>Завантажуємо добірку...</p>
  <ul id="lexicon-daily-list" class="lexicon-daily-grid" aria-live="polite" data-daily-list></ul>
</section>

<script>
  import { dateSeed, pickDaily, type DailyWord } from "../lib/lexicon/daily";
  import {
    filterByCumulativeLevel,
    LEARNER_LEVEL_STORAGE_KEY,
    normalizeCefrLevel,
    type CefrLevel,
  } from "../lib/lexicon/levels";

  const dwEsc = (value: unknown): string =>
    String(value ?? "").replace(
      /[&<>"]/g,
      (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c] ?? c,
    );

  const readLearnerLevel = (): CefrLevel => {
    try {
      return normalizeCefrLevel(window.localStorage.getItem(LEARNER_LEVEL_STORAGE_KEY));
    } catch {
      return "A1";
    }
  };

  const storeLearnerLevel = (level: CefrLevel) => {
    try {
      window.localStorage.setItem(LEARNER_LEVEL_STORAGE_KEY, level);
    } catch {
      // Storage can be unavailable in hardened browser contexts.
    }
  };

  const renderChips = (word: DailyWord): string => {
    const chips: string[] = [];
    if (word.k === "avoid") {
      chips.push('<span class="lexicon-daily-chip danger">остерігайтеся</span>');
    }
    if (word.cefr) {
      chips.push(`<span class="lexicon-daily-chip">${dwEsc(word.cefr)}</span>`);
    }
    return chips.length > 0 ? `<span class="lexicon-daily-chips">${chips.join("")}</span>` : "";
  };

  const renderExample = (word: DailyWord): string => {
    const example = word.example?.trim();
    if (!example) return "";
    const exampleEn = word.exampleEn?.trim();
    return `<span class="lexicon-daily-example" data-testid="daily-example-${dwEsc(word.slug)}" lang="uk">
      ${dwEsc(example)}${exampleEn ? `<span class="lexicon-daily-example-en" lang="en">${dwEsc(exampleEn)}</span>` : ""}
    </span>`;
  };

  const renderCard = (word: DailyWord): string => {
    const href = `/lexicon/${encodeURIComponent(String(word.slug))}/`;
    return `<li class="lexicon-daily-item">
      <a class="lexicon-daily-card" href="${href}">
        <span class="lexicon-daily-lemma">${dwEsc(word.lemma)}</span>
        ${word.gloss ? `<span class="lexicon-daily-gloss">${dwEsc(word.gloss)}</span>` : ""}
        ${renderExample(word)}
        ${renderChips(word)}
      </a>
    </li>`;
  };

  const hydrateDailySection = (dailySection: HTMLElement) => {
    const dailyList = dailySection.querySelector<HTMLUListElement>("[data-daily-list]");
    const dailyStatus = dailySection.querySelector<HTMLElement>("[data-daily-status]");
    const levelButtons = Array.from(
      dailySection.querySelectorAll<HTMLButtonElement>("[data-daily-level]"),
    );
    const count = Number(dailySection.dataset.dailyCount ?? "8") || 8;
    const useLevelSelector = dailySection.dataset.dailyLevelSelector === "true";

    let activeLevel = readLearnerLevel();
    let pool: DailyWord[] = [];

    if (useLevelSelector) {
      storeLearnerLevel(activeLevel);
    }

    const hideDailySection = () => {
      if (dailyList) dailyList.innerHTML = "";
      dailySection.hidden = true;
    };

    const syncLevelButtons = () => {
      for (const button of levelButtons) {
        button.setAttribute(
          "aria-pressed",
          normalizeCefrLevel(button.dataset.dailyLevel) === activeLevel ? "true" : "false",
        );
      }
    };

    const renderDailyWords = () => {
      if (!dailyList) return;
      const eligiblePool = useLevelSelector ? filterByCumulativeLevel(pool, activeLevel) : pool;
      const picks = pickDaily(eligiblePool, dateSeed(new Date()), count);

      if (picks.length === 0) {
        dailyList.innerHTML = "";
        if (dailyStatus) {
          dailyStatus.hidden = false;
          dailyStatus.textContent = `Немає слів для рівня ${activeLevel}.`;
        }
        return;
      }

      dailyList.innerHTML = picks.map(renderCard).join("");
      if (dailyStatus) {
        dailyStatus.hidden = false;
        dailyStatus.textContent = useLevelSelector
          ? `${activeLevel} · ${picks.length} слів`
          : "";
        dailyStatus.hidden = !useLevelSelector;
      }
      syncLevelButtons();
    };

    for (const button of levelButtons) {
      button.addEventListener("click", () => {
        activeLevel = normalizeCefrLevel(button.dataset.dailyLevel);
        storeLearnerLevel(activeLevel);
        renderDailyWords();
      });
    }

    const loadDailyWords = async () => {
      try {
        const response = await fetch("/lexicon/daily-pool.json");
        if (!response.ok) throw new Error(`Daily pool request failed: ${response.status}`);
        const data = (await response.json()) as DailyWord[];
        if (!Array.isArray(data) || data.length === 0) {
          hideDailySection();
          return;
        }
        pool = data;
        syncLevelButtons();
        renderDailyWords();
      } catch {
        hideDailySection();
      }
    };

    loadDailyWords();
  };

  for (const dailySection of document.querySelectorAll<HTMLElement>("[data-daily-words]")) {
    hydrateDailySection(dailySection);
  }
</script>

<style>
  .lexicon-daily-section {
    padding: 0 1.5rem 1.5rem;
  }

  .lexicon-daily-heading,
  .lexicon-daily-controls,
  .lexicon-daily-status,
  .lexicon-daily-grid {
    max-width: 960px;
  }

  .lexicon-daily-heading {
    margin: 0 auto 1.15rem;
  }

  .lexicon-daily-heading h2 {
    display: inline-block;
    margin: 0;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--lu-accent);
    color: var(--lu-text);
    font-size: clamp(1.55rem, 3vw, 2.15rem);
  }

  .lexicon-daily-heading p,
  .lexicon-daily-status {
    margin: 0.35rem 0 0;
    color: var(--lu-text-muted);
    line-height: 1.55;
  }

  .lexicon-daily-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem;
    margin: 0 auto 1rem;
  }

  .lexicon-daily-control-label {
    color: var(--lu-text);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .lexicon-daily-levels {
    display: flex;
    gap: 0.45rem;
    max-width: 100%;
    overflow-x: auto;
    padding-bottom: 0.15rem;
    scrollbar-width: thin;
  }

  .lexicon-daily-level-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    padding: 0 0.85rem;
    border: 1px solid var(--lu-border);
    border-radius: 8px;
    background: var(--lu-surface);
    color: var(--lu-text);
    cursor: pointer;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 900;
  }

  .lexicon-daily-level-chip:hover,
  .lexicon-daily-level-chip:focus-visible {
    border-color: var(--lu-primary);
    outline: none;
    box-shadow: 0 0 0 3px var(--lu-state-active);
  }

  .lexicon-daily-level-chip[aria-pressed="true"] {
    border-color: var(--lu-primary);
    background: var(--lu-primary);
    color: var(--lu-on-primary);
  }

  .lexicon-daily-status {
    margin: 0 auto 1rem;
  }

  .lexicon-daily-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.75rem;
    margin: 0 auto;
    padding: 0;
    list-style: none;
  }

  :global(.lexicon-daily-item) {
    min-width: 0;
  }

  :global(.lexicon-daily-card) {
    display: flex;
    min-height: 7.25rem;
    height: 100%;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.95rem 1rem;
    border: 1px solid var(--lu-border);
    border-radius: 8px;
    background: var(--lu-surface);
    color: var(--lu-text);
    text-decoration: none;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  }

  :global(.lexicon-daily-card:hover),
  :global(.lexicon-daily-card:focus-visible) {
    border-color: var(--lu-primary);
    outline: none;
    box-shadow: 0 0 0 3px var(--lu-state-active);
  }

  :global(.lexicon-daily-lemma) {
    color: var(--lu-blue);
    font-weight: 900;
    line-height: 1.25;
  }

  :global(.lexicon-daily-gloss) {
    color: var(--lu-text-muted);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  :global(.lexicon-daily-example) {
    display: block;
    margin-top: 0.25rem;
    color: var(--lu-text);
    font-size: 0.95rem;
    font-style: italic;
    line-height: 1.5;
  }

  :global(.lexicon-daily-example-en) {
    display: block;
    margin-top: 0.15rem;
    color: var(--lu-text-muted);
    font-size: 0.85rem;
    font-style: normal;
  }

  :global(.lexicon-daily-chips) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
  }

  :global(.lexicon-daily-chip) {
    display: inline-flex;
    align-items: center;
    min-height: 1.35rem;
    padding: 0 0.45rem;
    border-radius: 4px;
    background: var(--lu-state-active);
    color: var(--lu-primary);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  :global(.lexicon-daily-chip.danger) {
    border: 1px solid var(--lu-state-wrong-fg);
    background: var(--lu-state-wrong-bg);
    color: var(--lu-state-wrong-fg);
    text-transform: none;
  }

  @media (max-width: 680px) {
    .lexicon-daily-section {
      padding: 0 1rem 1rem;
    }

    .lexicon-daily-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
