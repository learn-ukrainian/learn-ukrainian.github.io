---
/**
 * Full А-Я Word Atlas index (the restored "old browse" — #3771 design). Rendered
 * server-side (SSG) from the committed lightweight search index (~487 KB, the same
 * {l,s,g,r,k,c} records the typeahead uses) — NOT the 39 MB manifest. Sticky alphabet
 * nav + every word grouped by letter; the client script only filters the pre-rendered
 * rows. Lives on /lexicon/browse/ so the landing stays search-first.
 */
import index from "../data/lexicon-search-index.json";
import {
  firstUkrainianLetter,
  parseCefrLevel,
  type LexiconBrowseRow,
  type UkrainianLetter,
} from "../lib/lexicon/levels";

const rows = (index as LexiconBrowseRow[]).filter(
  (row) => typeof row?.l === "string" && typeof row?.s === "string",
);

const collator = new Intl.Collator("uk", { sensitivity: "base" });

const byLetter = new Map<UkrainianLetter, LexiconBrowseRow[]>();
for (const row of rows) {
  const letter = firstUkrainianLetter(row.l);
  if (!letter) continue;
  const bucket = byLetter.get(letter) ?? [];
  bucket.push(row);
  byLetter.set(letter, bucket);
}

const groups = Array.from(byLetter.entries())
  .sort(([a], [b]) => collator.compare(a, b))
  .map(([letter, items]) => ({
    letter,
    items: items.slice().sort((a, b) => collator.compare(a.l, b.l)),
  }));

const totalWords = groups.reduce((sum, group) => sum + group.items.length, 0);

// Pre-compute a lowercased lemma+gloss+romanized haystack per row so the client filter
// is a cheap substring test (and matches Latin queries like "ofis" → офіс).
const haystackOf = (row: LexiconBrowseRow): string =>
  [row.l, row.g ?? "", row.r ?? ""].join(" ").normalize("NFC").toLocaleLowerCase("uk");
---

<section class="atlas-index" aria-labelledby="atlas-index-title" data-atlas-index>
  <div class="atlas-index-heading">
    <h2 id="atlas-index-title">Перегляд А–Я</h2>
    <p>Усі слова Атласу за українським алфавітом. Натисніть літеру, щоб перейти до розділу.</p>
  </div>

  <form class="atlas-index-filter" role="search" data-index-filter>
    <label for="atlas-index-search">Шукати в покажчику</label>
    <input
      id="atlas-index-search"
      name="q"
      type="search"
      placeholder="слово, переклад або латинкою…"
      autocomplete="off"
      data-index-search
    />
  </form>

  <nav class="atlas-letter-nav" aria-label="Український алфавіт">
    {
      groups.map(({ letter }) => (
        <a class="atlas-letter-link" href={`#letter-${letter}`} data-letter={letter}>
          {letter}
        </a>
      ))
    }
  </nav>

  <p
    class="atlas-index-status"
    data-index-status
    data-total-label={`${totalWords} слів · ${groups.length} літер`}
    aria-live="polite"
  >
    {totalWords} слів · {groups.length} літер
  </p>

  <div class="atlas-letter-groups">
    {
      groups.map(({ letter, items }) => (
        <section class="atlas-letter-section" data-letter-section={letter}>
          <h3 id={`letter-${letter}`} class="atlas-letter-heading">
            {letter}
          </h3>
          <ul class="atlas-index-list">
            {items.map((row) => {
              const cefr = parseCefrLevel(row.c);
              const surzhyk = row.k === "avoid";
              return (
                <li class="atlas-index-item" data-haystack={haystackOf(row)}>
                  <a class="atlas-index-link" href={`/lexicon/${encodeURIComponent(row.s)}/`}>
                    <span class="atlas-index-lemma">{row.l}</span>
                    {row.g && <span class="atlas-index-gloss">«{row.g}»</span>}
                    <span class="atlas-index-tags">
                      {cefr && <span class="atlas-index-cefr">{cefr}</span>}
                      {surzhyk && <span class="atlas-index-warn">остерігайтеся</span>}
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      ))
    }
  </div>

  <div class="atlas-index-empty" data-index-empty hidden>
    <p class="atlas-index-empty-code">Немає збігів</p>
    <p>Спробуйте коротший запит.</p>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>("[data-atlas-index]");
  const searchInput = root?.querySelector<HTMLInputElement>("[data-index-search]");
  const letterNav = root?.querySelector<HTMLElement>(".atlas-letter-nav");
  const status = root?.querySelector<HTMLElement>("[data-index-status]");
  const groups = root?.querySelector<HTMLElement>(".atlas-letter-groups");
  const empty = root?.querySelector<HTMLElement>("[data-index-empty]");

  const norm = (value: string): string => value.normalize("NFC").toLocaleLowerCase("uk");

  if (root && searchInput && letterNav && status && groups && empty) {
    const totalLabel = status.dataset.totalLabel ?? status.textContent ?? "";
    const sections = Array.from(groups.querySelectorAll<HTMLElement>("[data-letter-section]"));

    const applyFilter = () => {
      const query = norm(searchInput.value).trim();
      let visible = 0;

      for (const section of sections) {
        let sectionVisible = 0;
        for (const item of section.querySelectorAll<HTMLElement>(".atlas-index-item")) {
          const match = !query || (item.dataset.haystack ?? "").includes(query);
          item.hidden = !match;
          if (match) sectionVisible += 1;
        }
        section.hidden = sectionVisible === 0;
        visible += sectionVisible;
        const letter = section.dataset.letterSection ?? "";
        const navLink = letterNav.querySelector<HTMLElement>(`[data-letter="${CSS.escape(letter)}"]`);
        if (navLink) navLink.classList.toggle("is-empty", sectionVisible === 0);
      }

      empty.hidden = visible !== 0;
      status.textContent = query
        ? `${visible} слів за запитом «${searchInput.value.trim()}»`
        : totalLabel;
    };

    let filterTimer: ReturnType<typeof setTimeout> | undefined;
    searchInput.addEventListener("input", () => {
      if (filterTimer) clearTimeout(filterTimer);
      filterTimer = setTimeout(applyFilter, 150);
    });
  }
</script>

<style>
  .atlas-index {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
    display: grid;
    gap: 1.1rem;
  }

  .atlas-index-heading h2 {
    margin: 0;
    color: var(--lu-text);
    font-size: clamp(1.55rem, 3vw, 2.15rem);
  }

  .atlas-index-heading p,
  .atlas-index-status {
    margin: 0.35rem 0 0;
    color: var(--lu-text-muted);
    line-height: 1.55;
  }

  .atlas-index-filter {
    display: grid;
    gap: 0.4rem;
  }

  .atlas-index-filter label {
    color: var(--lu-text);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .atlas-index-filter input {
    min-height: 48px;
    padding: 0 0.9rem;
    border: 1px solid var(--lu-border);
    border-radius: 8px;
    background: var(--lu-surface);
    color: var(--lu-text);
    font: inherit;
    font-size: 16px;
  }

  .atlas-index-filter input:focus-visible {
    border-color: var(--lu-primary);
    outline: none;
    box-shadow: 0 0 0 3px var(--lu-state-active);
  }

  .atlas-letter-nav {
    position: sticky;
    top: 0.25rem;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    padding: 0.6rem;
    border: 1px solid var(--lu-border);
    border-radius: 8px;
    background: var(--lu-surface);
    box-shadow: 0 6px 18px color-mix(in srgb, var(--lu-text) 8%, transparent);
  }

  .atlas-letter-link {
    min-width: 2.1rem;
    min-height: 2.1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    color: var(--lu-primary);
    font-weight: 900;
    text-decoration: none;
  }

  .atlas-letter-link:hover,
  .atlas-letter-link:focus-visible {
    outline: none;
    background: var(--lu-state-active);
    box-shadow: 0 0 0 2px var(--lu-primary);
  }

  .atlas-letter-link.is-empty {
    opacity: 0.3;
    pointer-events: none;
  }

  .atlas-index-status {
    min-height: 1.4rem;
    font-weight: 700;
  }

  .atlas-letter-groups {
    display: grid;
    gap: 1.6rem;
  }

  .atlas-letter-section[hidden],
  .atlas-index-item[hidden],
  .atlas-index-empty[hidden] {
    display: none;
  }

  .atlas-letter-heading {
    margin: 0 0 0.7rem;
    padding-bottom: 0.3rem;
    border-bottom: 2px solid var(--lu-accent);
    color: var(--lu-primary);
    font-size: 1.3rem;
    /* Clear the sticky alphabet nav when jumping to an anchor. */
    scroll-margin-top: 4rem;
  }

  .atlas-index-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .atlas-index-item {
    min-width: 0;
  }

  .atlas-index-link {
    display: grid;
    gap: 0.2rem;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--lu-border);
    border-left: 3px solid var(--lu-primary);
    border-radius: 6px;
    background: var(--lu-surface);
    color: var(--lu-text);
    text-decoration: none;
  }

  .atlas-index-link:hover,
  .atlas-index-link:focus-visible {
    border-color: var(--lu-primary);
    outline: none;
    box-shadow: 0 0 0 3px var(--lu-state-active);
  }

  .atlas-index-lemma {
    font-weight: 900;
    line-height: 1.25;
  }

  .atlas-index-gloss {
    color: var(--lu-text-muted);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .atlas-index-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.1rem;
  }

  .atlas-index-cefr,
  .atlas-index-warn {
    display: inline-flex;
    align-items: center;
    min-height: 1.3rem;
    padding: 0 0.4rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .atlas-index-cefr {
    background: var(--lu-state-active);
    color: var(--lu-primary);
  }

  .atlas-index-warn {
    background: var(--lu-state-wrong-bg, #fee2e2);
    color: var(--lu-state-wrong-fg, #991b1b);
    text-transform: none;
  }

  .atlas-index-empty {
    padding: 1rem;
    border: 1px solid var(--lu-border);
    border-left: 4px solid var(--lu-accent);
    border-radius: 8px;
    background: var(--lu-surface);
  }

  .atlas-index-empty-code {
    margin: 0;
    color: var(--lu-primary);
    font-weight: 900;
  }

  .atlas-index-empty p:last-child {
    margin: 0.35rem 0 0;
    color: var(--lu-text-muted);
  }

  @media (max-width: 680px) {
    .atlas-index {
      padding: 0 1rem 3rem;
    }

    .atlas-index-list {
      grid-template-columns: 1fr;
    }
  }
</style>
