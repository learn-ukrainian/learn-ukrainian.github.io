---
/**
 * А-Я Word Atlas browse shell. The SSG page inlines only the small metadata
 * file; word rows are fetched from per-letter JSON shards after a letter click.
 */
import flaggedRows from "../data/lexicon-browse-flagged.json";
import browseMeta from "../data/lexicon-browse-meta.json";
import { UKRAINIAN_ALPHABET } from "../lib/lexicon/levels";

const clsLabels = {
  avoid: "уникати",
  rus: "русизм",
  calq: "калька",
  arch: "архаїзм",
  dial: "діалектизм",
  hist: "історизм",
  borr: "запозичення",
} as const;

const chipCounts = (browseMeta.chipCounts ?? {}) as Record<string, number>;
const chips = Object.entries(clsLabels).filter(([code]) => (chipCounts[code] ?? 0) > 0);
const letterCounts = (browseMeta.letterCounts ?? {}) as Record<string, number>;
const atlasEntryNoun = (count: number): string => {
  const mod100 = Math.abs(count) % 100;
  if (mod100 >= 11 && mod100 <= 14) return "записів";
  const mod10 = Math.abs(count) % 10;
  if (mod10 === 1) return "запис";
  if (mod10 >= 2 && mod10 <= 4) return "записи";
  return "записів";
};
const totalCount = browseMeta.total ?? 0;
const alphabetWithEntries = UKRAINIAN_ALPHABET.filter(
  (letter) => (letterCounts[letter] ?? 0) > 0,
);
const totalLabelUk = `${totalCount} ${atlasEntryNoun(totalCount)} Атласу · ${UKRAINIAN_ALPHABET.length} літери`;
const totalLabelEn = `${totalCount.toLocaleString("en-US")} atlas entries · ${UKRAINIAN_ALPHABET.length} letters`;
---

<section
  class="atlas-index"
  data-atlas-index
  data-browse-meta={JSON.stringify(browseMeta)}
  data-flagged-rows={JSON.stringify(flaggedRows)}
  data-total-label-uk={totalLabelUk}
  data-total-label-en={totalLabelEn}
>
  <div class="atlas-index-heading">
    <h2 class="lu-i18n-block">
      <span data-loc="en">Browse the Atlas A–Z</span>
      <span data-loc="uk">Перегляд Атласу А–Я</span>
    </h2>
    <p class="lu-i18n-block">
      <span data-loc="en">The alphabetical index opens words one letter at a time.</span>
      <span data-loc="uk">Алфавітний покажчик відкриває слова по одній літері.</span>
    </p>
  </div>

  <nav class="atlas-letter-nav" aria-label="Літери українського алфавіту">
    {
      alphabetWithEntries.map((letter) => {
        const count = letterCounts[letter] ?? 0;
        return (
          <button
            type="button"
            class="atlas-letter-link"
            data-letter={letter}
            data-base-count={count}
            aria-pressed="false"
          >
            {letter}
          </button>
        );
      })
    }
  </nav>
  <p class="atlas-letter-nav-note lu-i18n-block">
    <span data-loc="en">Showing letters that have Atlas entries.</span>
    <span data-loc="uk">Показано літери, для яких є записи в Атласі.</span>
  </p>

  {
    chips.length > 0 && (
      <div class="atlas-chip-row" aria-label="Фільтр за позначкою">
        {chips.map(([code, label]) => (
          <button
            type="button"
            class="atlas-chip"
            data-chip={code}
            aria-pressed="false"
          >
            {label}
          </button>
        ))}
      </div>
    )
  }

  <label class="atlas-index-filter">
  <span>Пошук в Атласі</span>
  <input
    type="search"
    data-index-search
    placeholder="Шукати слово, переклад або латинку"
    autocomplete="off"
  />
</label>

  <p
    class="atlas-index-status lu-i18n-block"
    data-index-status
    aria-live="polite"
  >
    <span data-loc="uk">{totalLabelUk}</span>
    <span data-loc="en">{totalLabelEn}</span>
  </p>

  <section class="atlas-letter-section" data-letter-section hidden>
  <h3 id="atlas-selected-letter" class="atlas-letter-heading" tabindex="-1" data-letter-heading></h3>
  <ul class="atlas-index-list" data-index-list></ul>
  <button class="atlas-more-button" type="button" data-index-more hidden>Показати ще</button>
  <p class="atlas-index-overflow" data-index-overflow hidden></p>
  <div class="atlas-sentinel" data-index-sentinel aria-hidden="true"></div>
</section>

  <div class="atlas-index-empty" data-index-empty>
    <p class="atlas-index-empty-code">Оберіть літеру алфавіту, щоб переглянути слова</p>
  </div>
</section>

<script>
  import { UKRAINIAN_ALPHABET } from "../lib/lexicon/levels";

type BrowseRow = {
  l: string;
  s: string;
  g: string | null;
  c?: string | null;
  cls?: string;
  hay?: string;
  r?: string | null;
  letter?: string | null;
};

  type BrowseMeta = {
    total: number;
    letterCounts: Record<string, number>;
    chipCounts: Record<string, number>;
    letterChip: Record<string, Record<string, number>>;
  };

  const CLS_LABELS: Record<string, string> = {
    avoid: "уникати",
    rus: "русизм",
    calq: "калька",
    arch: "архаїзм",
    dial: "діалектизм",
    hist: "історизм",
    borr: "запозичення",
  };

  const CHUNK_SIZE = 150;
  const GLOBAL_SEARCH_LIMIT = 200;
  const alphabet = new Set<string>(UKRAINIAN_ALPHABET);
  const atlasEntryNoun = (count: number): string => {
    const mod100 = Math.abs(count) % 100;
    if (mod100 >= 11 && mod100 <= 14) return "записів";
    const mod10 = Math.abs(count) % 10;
    if (mod10 === 1) return "запис";
    if (mod10 >= 2 && mod10 <= 4) return "записи";
    return "записів";
  };
  const atlasEntryCountLabel = (count: number): string => `${count} ${atlasEntryNoun(count)}`;
  const root = document.querySelector<HTMLElement>("[data-atlas-index]");
  const normalize = (value: string): string => value.normalize("NFC").toLocaleLowerCase("uk-UA");
  const escapeHtml = (value: string): string =>
    value.replace(/[&<>"']/g, (char) => {
      const entities: Record<string, string> = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return entities[char] ?? char;
    });

  if (root) {
  const meta = JSON.parse(root.dataset.browseMeta ?? "{}") as BrowseMeta;
  const flaggedRows = JSON.parse(root.dataset.flaggedRows ?? "[]") as BrowseRow[];
  const totalCount = meta.total ?? 0;
  const totalLabelUk =
    root.dataset.totalLabelUk ??
    `${atlasEntryCountLabel(totalCount)} Атласу · ${UKRAINIAN_ALPHABET.length} літери`;
  const totalLabelEn =
    root.dataset.totalLabelEn ??
    `${totalCount.toLocaleString("en-US")} atlas entries · ${UKRAINIAN_ALPHABET.length} letters`;
  const setStatusBilingual = (uk: string, en: string): void => {
    if (!status) return;
    status.classList.add("lu-i18n-block");
    status.innerHTML = `<span data-loc="uk">${escapeHtml(uk)}</span><span data-loc="en">${escapeHtml(en)}</span>`;
  };
  const setStatusText = (value: string): void => {
    if (!status) return;
    status.classList.remove("lu-i18n-block");
    status.textContent = value;
  };
    const searchInput = root.querySelector<HTMLInputElement>("[data-index-search]");
    const status = root.querySelector<HTMLElement>("[data-index-status]");
    const section = root.querySelector<HTMLElement>("[data-letter-section]");
    const heading = root.querySelector<HTMLElement>("[data-letter-heading]");
    const list = root.querySelector<HTMLElement>("[data-index-list]");
  const empty = root.querySelector<HTMLElement>("[data-index-empty]");
  const moreButton = root.querySelector<HTMLButtonElement>("[data-index-more]");
  const overflow = root.querySelector<HTMLElement>("[data-index-overflow]");
  const sentinel = root.querySelector<HTMLElement>("[data-index-sentinel]");
  const letterButtons = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-letter]"));
  const chipButtons = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-chip]"));
  const cache = new Map<string, BrowseRow[]>();
  let globalSearchRows: BrowseRow[] | null = null;
  let globalSearchRequest: Promise<BrowseRow[]> | null = null;
  const state: {
    letter: string | null;
    cls: string | null;
    q: string;
    rows: BrowseRow[];
    visibleLimit: number;
    loading: boolean;
    error: string | null;
    overflow: number;
  } = {
    letter: null,
    cls: null,
    q: "",
    rows: [],
    visibleLimit: CHUNK_SIZE,
    loading: false,
    error: null,
    overflow: 0,
  };

  const filteredRows = (): BrowseRow[] => {
    const query = normalize(state.q).trim();
    return state.rows.filter((row) => {
      if (state.cls && row.cls !== state.cls) return false;
      if (!query) return true;
      return normalize(row.hay ?? [row.l, row.g ?? "", row.r ?? ""].join(" ")).includes(query);
    });
  };

  const setNoLetterRows = (rows: BrowseRow[], overflow = 0): void => {
    state.rows = rows;
    state.overflow = overflow;
    state.loading = false;
    state.error = null;
  };

  const categoryRows = (): BrowseRow[] => {
    if (!state.cls) return [];
    return flaggedRows.filter((row) => row.cls === state.cls);
  };

  const loadGlobalSearchRows = async (): Promise<BrowseRow[]> => {
    if (globalSearchRows) return globalSearchRows;
    if (!globalSearchRequest) {
      globalSearchRequest = fetch("/lexicon/search-index.json")
        .then((response) => {
          if (!response.ok) throw new Error(`HTTP ${response.status}`);
          return response.json() as Promise<BrowseRow[]>;
        })
        .then((rows) => {
          globalSearchRows = rows;
          return rows;
        })
        .catch((error) => {
          globalSearchRequest = null;
          throw error;
        });
    }
    return globalSearchRequest;
  };

  const refreshNoLetterRows = async (): Promise<void> => {
    if (state.letter) return;
    const query = normalize(state.q).trim();
    state.visibleLimit = CHUNK_SIZE;
    state.overflow = 0;
    if (!query) {
      setNoLetterRows(categoryRows());
      render();
      return;
    }
    state.loading = true;
    state.error = null;
    render();
    try {
      const rows = await loadGlobalSearchRows();
      if (state.letter || normalize(state.q).trim() !== query) return;
      const matches = rows.filter((row) => {
        if (state.cls && row.cls !== state.cls) return false;
        return normalize(row.hay ?? [row.l, row.g ?? "", row.r ?? ""].join(" ")).includes(query);
      });
      setNoLetterRows(matches.slice(0, GLOBAL_SEARCH_LIMIT), Math.max(0, matches.length - GLOBAL_SEARCH_LIMIT));
    } catch {
      if (state.letter || normalize(state.q).trim() !== query) return;
      state.rows = [];
      state.overflow = 0;
      state.loading = false;
      state.error = "Не вдалося завантажити пошук";
    }
    render();
  };

    const setStatus = (filteredCount = 0): void => {
      if (!status) return;
    if (!state.letter) {
      if (state.loading) {
        setStatusText("Шукаємо…");
        return;
      }
      if (state.error) {
        setStatusText(state.error);
        return;
      }
      if (state.q.trim()) {
        setStatusText(`${state.cls ? `${CLS_LABELS[state.cls] ?? state.cls}: ` : ""}${filteredCount} збігів`);
        return;
      }
      if (state.cls) {
        setStatusText(`${CLS_LABELS[state.cls] ?? state.cls}: ${atlasEntryCountLabel(filteredCount)}`);
        return;
      }
      setStatusBilingual(totalLabelUk, totalLabelEn);
      return;
    }
      if (state.loading) {
        setStatusText(`Завантажуємо ${state.letter}…`);
        return;
      }
      if (state.error) {
        setStatusText(state.error);
        return;
      }
      setStatusText(`${state.letter}: ${atlasEntryCountLabel(filteredCount)}`);
    };

    const updateControls = (): void => {
      for (const button of letterButtons) {
        const letter = button.dataset.letter ?? "";
        const baseCount = Number(button.dataset.baseCount ?? 0);
        const chipCount = state.cls ? (meta.letterChip?.[letter]?.[state.cls] ?? 0) : baseCount;
        const disabled = baseCount === 0 || (!state.letter && Boolean(state.cls) && chipCount === 0);
        button.disabled = disabled;
        button.classList.toggle("is-empty", baseCount === 0);
        button.classList.toggle("is-chip-empty", baseCount > 0 && Boolean(state.cls) && chipCount === 0);
        button.setAttribute("aria-pressed", String(letter === state.letter));
      }
      for (const button of chipButtons) {
        button.setAttribute("aria-pressed", String(button.dataset.chip === state.cls));
    }
    if (searchInput) {
      searchInput.disabled = false;
      searchInput.placeholder = state.letter ? "Фільтрувати слова цієї літери" : "Шукати слово, переклад або латинку";
    }
  };

    const rowId = (row: BrowseRow): string => `word-${row.s}`;
    const rowHtml = (row: BrowseRow): string => {
      const cefr = row.c ? `<span class="atlas-index-cefr">${escapeHtml(row.c)}</span>` : "";
      const warn = row.cls === "avoid" ? '<span class="atlas-index-warn">остерігайтеся</span>' : "";
      const gloss = row.g ? `<span class="atlas-index-gloss">«${escapeHtml(row.g)}»</span>` : "";
      return `
        <li class="atlas-index-item">
          <a
            id="${escapeHtml(rowId(row))}"
            class="atlas-index-link"
            href="/lexicon/${encodeURIComponent(row.s)}/"
          >
            <span class="atlas-index-lemma">${escapeHtml(row.l)}</span>
            ${gloss}
            <span class="atlas-index-tags">${cefr}${warn}</span>
          </a>
        </li>
      `;
    };

    const focusHashTarget = (rows: BrowseRow[]): boolean => {
      const rawHash = decodeURIComponent(window.location.hash.slice(1));
      if (!rawHash) return false;
      const slug = rawHash.startsWith("word-") ? rawHash.slice(5) : rawHash;
      const index = rows.findIndex((row) => row.s === slug || rowId(row) === rawHash);
      if (index < 0) return false;
      if (index >= state.visibleLimit) {
        state.visibleLimit = Math.ceil((index + 1) / CHUNK_SIZE) * CHUNK_SIZE;
        render();
        return true;
      }
      const target = document.getElementById(rowId(rows[index]));
      if (target instanceof HTMLElement) {
        target.focus({ preventScroll: true });
        target.scrollIntoView({ block: "center" });
      }
      return true;
    };

  function render(): void {
    updateControls();
    if (!section || !heading || !list || !empty || !moreButton || !overflow || !sentinel) return;
    const hasEntryPoint = Boolean(state.letter || state.cls || state.q.trim());
    if (!hasEntryPoint) {
      section.hidden = true;
      list.innerHTML = "";
      empty.hidden = false;
      empty.innerHTML = '<p class="atlas-index-empty-code">Оберіть літеру алфавіту, щоб переглянути слова</p>';
      overflow.hidden = true;
      setStatus();
      return;
    }

    section.hidden = false;
    heading.textContent = state.letter
      ?? (state.cls ? CLS_LABELS[state.cls] ?? state.cls : `Пошук: ${state.q.trim()}`);
    if (state.loading) {
      list.innerHTML = "";
      empty.hidden = true;
      moreButton.hidden = true;
      overflow.hidden = true;
      sentinel.hidden = true;
      setStatus();
      return;
    }
    if (state.error) {
      list.innerHTML = "";
      empty.hidden = false;
      empty.innerHTML = '<p class="atlas-index-empty-code">Не вдалося завантажити дані</p>';
      moreButton.hidden = true;
      overflow.hidden = true;
      sentinel.hidden = true;
      setStatus();
      return;
    }

      const rows = filteredRows();
      const visibleRows = rows.slice(0, state.visibleLimit);
      list.innerHTML = visibleRows.map(rowHtml).join("");
      empty.hidden = rows.length !== 0;
      if (rows.length === 0) {
        empty.innerHTML = '<p class="atlas-index-empty-code">Немає збігів</p><p>Спробуйте інший фільтр.</p>';
    }
    const hasMore = rows.length > visibleRows.length;
    moreButton.hidden = !hasMore;
    overflow.hidden = state.overflow === 0 || hasMore;
    overflow.textContent = state.overflow > 0 ? `ще ${atlasEntryCountLabel(state.overflow)} — звузьте запит` : "";
    sentinel.hidden = !hasMore;
    setStatus(rows.length);
      focusHashTarget(rows);
    }

    const updateUrl = (replace = false): void => {
      const url = new URL(window.location.href);
      if (state.letter) url.searchParams.set("letter", state.letter);
      else url.searchParams.delete("letter");
      if (state.cls) url.searchParams.set("cls", state.cls);
      else url.searchParams.delete("cls");
      if (state.q.trim()) url.searchParams.set("q", state.q.trim());
      else url.searchParams.delete("q");
      if (replace) {
        window.history.replaceState({}, "", url);
      } else {
        window.history.pushState({}, "", url);
      }
    };

    const loadLetter = async (letter: string, focusHeading = true): Promise<void> => {
      if (!alphabet.has(letter)) return;
    state.letter = letter;
    state.visibleLimit = CHUNK_SIZE;
    state.error = null;
    state.overflow = 0;
    if (searchInput) searchInput.value = state.q;
    if (cache.has(letter)) {
      state.rows = cache.get(letter) ?? [];
      state.loading = false;
      state.overflow = 0;
      render();
        if (focusHeading && heading) heading.focus({ preventScroll: true });
        return;
      }
      state.loading = true;
      state.rows = [];
      render();
      try {
        const response = await fetch(`/lexicon/browse/${encodeURIComponent(letter)}.json`);
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        const rows = (await response.json()) as BrowseRow[];
        cache.set(letter, rows);
        // Guard against a stale fetch: if a newer letter was selected while this
        // request was in flight, drop the result rather than clobber the active letter.
      if (state.letter !== letter) return;
      state.rows = rows;
      state.error = null;
      state.overflow = 0;
      } catch {
        if (state.letter !== letter) return;
        state.rows = [];
        state.error = `Не вдалося завантажити ${letter}`;
      } finally {
        if (state.letter === letter) {
          state.loading = false;
          render();
          if (focusHeading && heading) heading.focus({ preventScroll: true });
        }
      }
    };

    const applyLocation = async (replace = true): Promise<void> => {
      const params = new URLSearchParams(window.location.search);
      const nextLetter = params.get("letter")?.toLocaleUpperCase("uk-UA") ?? null;
      const nextCls = params.get("cls");
      state.cls = nextCls && CLS_LABELS[nextCls] ? nextCls : null;
      state.q = params.get("q") ?? "";
      if (searchInput) searchInput.value = state.q;
    if (nextLetter && alphabet.has(nextLetter)) {
      await loadLetter(nextLetter, false);
    } else {
      state.letter = null;
      state.visibleLimit = CHUNK_SIZE;
      await refreshNoLetterRows();
    }
    updateUrl(replace);
  };

    for (const button of letterButtons) {
      button.addEventListener("click", () => {
        const letter = button.dataset.letter;
        if (!letter) return;
        void loadLetter(letter).then(() => updateUrl());
      });
    }

    for (const button of chipButtons) {
      button.addEventListener("click", () => {
      const chip = button.dataset.chip ?? null;
      state.cls = state.cls === chip ? null : chip;
      state.visibleLimit = CHUNK_SIZE;
      if (state.letter) {
        render();
      } else {
        void refreshNoLetterRows();
      }
      updateUrl();
    });
  }

  let filterTimer: ReturnType<typeof setTimeout> | undefined;
  searchInput?.addEventListener("input", () => {
    if (!searchInput) return;
    if (filterTimer) clearTimeout(filterTimer);
    filterTimer = setTimeout(() => {
      state.q = searchInput.value;
      state.visibleLimit = CHUNK_SIZE;
      if (state.letter) {
        render();
      } else {
        void refreshNoLetterRows();
      }
      updateUrl();
    }, 150);
  });

    const showMore = (): void => {
      const rows = filteredRows();
      if (state.visibleLimit >= rows.length) return;
      state.visibleLimit += CHUNK_SIZE;
      render();
    };
    moreButton?.addEventListener("click", showMore);
    if (sentinel && "IntersectionObserver" in window) {
      const observer = new IntersectionObserver((entries) => {
        if (entries.some((entry) => entry.isIntersecting)) showMore();
      });
      observer.observe(sentinel);
    }

    window.addEventListener("popstate", () => {
      void applyLocation(true);
    });

    void applyLocation(true);
  }
</script>

<style>
  .atlas-index {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
    display: grid;
    gap: 1.1rem;
  }

  .atlas-index-heading h2 {
    margin: 0;
    color: var(--lu-text);
    font-size: clamp(1.55rem, 3vw, 2.15rem);
  }

  .atlas-index-heading p,
  .atlas-index-status {
    margin: 0.35rem 0 0;
    color: var(--lu-text-muted);
    line-height: 1.55;
  }

  .atlas-letter-nav,
  .atlas-chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .atlas-letter-nav-note {
    margin: 0;
    color: var(--lu-text-muted);
    font-size: 0.85rem;
    line-height: 1.45;
  }

  .atlas-letter-nav {
    position: sticky;
    top: 0.25rem;
    z-index: 2;
    padding: 0.45rem;
    border: 1px solid var(--lu-border);
    border-radius: 8px;
    background: var(--lu-surface);
    box-shadow: 0 6px 18px rgb(15 23 42 / 10%);
  }

  .atlas-letter-link,
  .atlas-chip,
  .atlas-more-button {
    min-height: 2.75rem;
    border: 1px solid var(--lu-border);
    border-radius: 8px;
    background: var(--lu-surface);
    color: var(--lu-primary);
    font: inherit;
    font-weight: 900;
    cursor: pointer;
  }

  .atlas-letter-link {
    width: 2.75rem;
    min-width: 2.75rem;
    padding: 0;
  }

  .atlas-chip,
  .atlas-more-button {
    padding: 0 0.8rem;
  }

  .atlas-letter-link:hover,
  .atlas-letter-link:focus-visible,
  .atlas-chip:hover,
  .atlas-chip:focus-visible,
  .atlas-more-button:hover,
  .atlas-more-button:focus-visible {
    outline: none;
    background: var(--lu-state-active);
    box-shadow: 0 0 0 2px var(--lu-primary);
  }

  .atlas-letter-link[aria-pressed="true"],
  .atlas-chip[aria-pressed="true"] {
    border-color: var(--lu-primary);
    background: var(--lu-primary);
    color: var(--lu-surface);
  }

  .atlas-letter-link.is-empty,
  .atlas-letter-link.is-chip-empty,
  .atlas-letter-link:disabled {
    opacity: 0.32;
    cursor: not-allowed;
  }

  .atlas-index-filter {
    display: grid;
    gap: 0.4rem;
  }

  .atlas-index-filter span {
