{"lemma": "юшка", "url_slug": "юшка", "gloss": "fish soup, light broth", "pos": "noun:f", "ipa": null, "primary_source": "built_vocabulary", "course_usage": [{"track": "b1", "module_num": 18, "slug": "restaurant-and-food", "context": "built_vocabulary"}], "heritage_status": {"classification": "standard", "attestations": [{"source": "VESUM", "ref": "юшка", "detail": "lemma match (14 forms)"}], "is_russianism": false, "russian_shadow": false, "calque_warning": null}, "pronunciation": {"ipa": "[ˈjuʃkɐ]", "source": "kaikki/Wiktionary (CC BY-SA 3.0)"}, "sections": {"synonyms": {"items": ["щерба", "суп", "зупа", "крупник", "юшечка"], "source": "slovnyk.me: Словник синонімів Караванського", "source_urls": ["https://slovnyk.me/dict/synonyms_karavansky/%D1%8E%D1%88%D0%BA%D0%B0"]}, "idioms": {"items": [{"text": "умитися юшкою", "phrase": "умитися юшкою", "definition": "Залитися кров’ю від сильного удару. — Як дам тобі стусана, то й юшкою вмиєшся, — сказав Мина (І. Нечуй-Левицький); Ярош, не довго думаючи, затопив своєму приятелеві просто в пику. Той умився юшкою (С. Воскрекасенко)", "source": "Фразеологічний словник української мови", "source_url": "https://slovnyk.me/dict/phraseology/%D1%8E%D1%88%D0%BA%D0%B0"}], "source": "slovnyk.me: Фразеологічний словник української мови", "source_urls": ["https://slovnyk.me/dict/phraseology/%D1%8E%D1%88%D0%BA%D0%B0"]}}, "enrichment": {"stress": {"form": "ю́шка", "source": "ukrainian-word-stress"}, "cefr": {"level": "B1", "source": "PULS CEFR", "pos": "іменник", "text": "юшка (B1, іменник)"}, "morphology": {"pos": "іменник", "form_count": 14, "forms": [{"form": "юшці", "label": "жін., давальний", "stress": "ю́шці"}, {"form": "юшко", "label": "жін., кличний", "stress": "ю́шко"}, {"form": "юшці", "label": "жін., місцевий", "stress": "ю́шці"}, {"form": "юшка", "label": "жін., називний", "stress": "ю́шка"}, {"form": "юшкою", "label": "жін., орудний", "stress": "ю́шкою"}, {"form": "юшки", "label": "жін., родовий"}, {"form": "юшку", "label": "жін., знахідний", "stress": "ю́шку"}, {"form": "юшкам", "label": "множина, давальний", "stress": "юшка́м"}, {"form": "юшки", "label": "множина, кличний"}, {"form": "юшках", "label": "множина, місцевий", "stress": "юшка́х"}, {"form": "юшки", "label": "множина, називний"}, {"form": "юшками", "label": "множина, орудний", "stress": "юшка́ми"}, {"form": "юшок", "label": "множина, родовий", "stress": "юшо́к"}, {"form": "юшки", "label": "множина, знахідний"}], "source": "VESUM", "paradigm": {"kind": "noun", "cases": {"називний": {"singular": "юшка", "plural": "юшки"}, "родовий": {"singular": "юшки", "plural": "юшок"}, "давальний": {"singular": "юшці", "plural": "юшкам"}, "знахідний": {"singular": "юшку", "plural": "юшки"}, "орудний": {"singular": "юшкою", "plural": "юшками"}, "місцевий": {"singular": "юшці", "plural": "юшках"}, "кличний": {"singular": "юшко", "plural": "юшки"}}}, "stress": {"source": "ukrainian-word-stress", "forms": {"юшці": "ю́шці", "юшко": "ю́шко", "юшка": "ю́шка", "юшкою": "ю́шкою", "юшку": "ю́шку", "юшкам": "юшка́м", "юшках": "юшка́х", "юшками": "юшка́ми", "юшок": "юшо́к"}}}, "meaning": {"definitions": ["суп м'ясний, картопляний, рибний і т. ін", "рідина з будь-якої готової страви", "відвар з чого-небудь"], "source": "Вікісловник"}, "definition_cards": [{"id": "sum11", "source": "СУМ-11", "source_pill": "СУМ-11", "note": "радянське видання · перевірено: чисто", "definitions": ["Ю́ШКА, и, ж. 1. Суп м’ясний, картопляний, рибний і т. ін. Стало на рибу, стане і на юшку (Укр.. присл.., 1963. 67); Відриваючи по шматку мамалигу та бгаючи її в руках на галки, він мачав ті галки в юшку з квасолі (Коцюб., I, 1955, 238); За кілька хвилин ми всі четверо разом із фурманом сиділи й хлебтали смачну картопляну юшку (Досв., Вибр., 1959, 41); — Коропів таких, як тут, ніде не знайдеш. За день відра два наловити можна. Така юшка буде — пальці оближеш (Тулуб, В степу.., 1964. 111); Мати налила миску юшки з м’яса (Гжицький, Чорне озеро, 1961, 63); // Рідина з будь-якої готової страви. Чоловіки.. беруть руками м’ясо, тягнуть з тарілок так нечепурно, аж юшка тече по скатерті (Н.-Лев., III, 1956, 273); *У порівн. До роботи Юхрим був рідким, наче юшка, зате круто міг замісити якусь сутягу чи паскудство (Стельмах, Гуси-лебеді.., 1964, 17); // Відвар з чого-небудь. Яка грушка, така й юшк…"], "sovietization_risk": 0}], "literary_attestation": {"text": "…тих мурів постріли, мов щиглі. Ой, поцілує куля ніжно лева в рот! І тепле оливо в левиних пащах стигне, аж продереться день – розрізане шатро. Вирують вулиці – скажені каруселі, і юшка олива в котлах димучих площ булькоче і кипить, немов смола пекельна, завернутий з землі у небо смаглий дощ. Коли стає густа заслона мряки тонша, мов нетлі, виринають постаті з дим…", "source": "literary_fts", "source_label": "Антонич Б.-І. · Богдан-Ігор Антонич. Із збірки \"Книга Лева\" · 1909", "chunk_id": "ef8276cb_c0021", "source_url": ""}, "translation": {"en": ["soup (dish)", "soup (especially fish soup)", "soup made from broth"], "source": "dmklinger", "pos": "noun"}, "sources": ["PULS CEFR", "VESUM", "dmklinger", "literary_fts", "slovnyk.me: Словник синонімів Караванського", "slovnyk.me: Фразеологічний словник української мови", "ukrainian-word-stress", "Вікісловник", "СУМ-11"]}}
