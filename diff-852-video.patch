+        assert 'label="Watch this"' in result
+
+    def test_plain_bullet_url(self):
+        body = '- Літера А: https://www.youtube.com/watch?v=hvB3VpcR3ZE'
+        result = embed_youtube_video_links(body)
+        assert '<YouTubeVideo' in result
