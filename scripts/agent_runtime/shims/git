#!/usr/bin/env bash
set -euo pipefail

_deny() {
  cat >&2 <<'EOF'
error: agent invoked with AGENT_NO_MERGE=1 cannot push directly to main.
       User reviews and merges. See INCIDENT #1403.
EOF
  exit 1
}

_real_git() {
  local shim_dir
  shim_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

  if [[ -n "${AGENT_REAL_GIT:-}" && "${AGENT_REAL_GIT:-}" != "$shim_dir/git" && "${AGENT_REAL_GIT:-}" != */scripts/agent_runtime/shims/git ]]; then
    printf '%s\n' "$AGENT_REAL_GIT"
    return 0
  fi

  local path_entry
  IFS=':' read -r -a _path_entries <<< "${AGENT_ORIGINAL_PATH:-${PATH:-}}"
  for path_entry in "${_path_entries[@]}"; do
    [[ -z "$path_entry" || "$path_entry" == "$shim_dir" || "$path_entry" == */scripts/agent_runtime/shims ]] && continue
    if [[ -x "$path_entry/git" ]]; then
      printf '%s\n' "$path_entry/git"
      return 0
    fi
  done

  return 1
}

_is_main_refspec() {
  local token="${1#+}"

  [[ "$token" == "main" || "$token" == "refs/heads/main" ]] && return 0
  [[ "$token" == *":main" || "$token" == *":refs/heads/main" ]] && return 0
  [[ "$token" == "main:"* || "$token" == "refs/heads/main:"* ]] && return 0

  return 1
}

_blocks_git_push() {
  [[ "${1:-}" == "push" ]] || return 1
  shift

  local arg
  for arg in "$@"; do
    [[ "$arg" == "--" ]] && continue
    [[ "$arg" == -* ]] && continue
    _is_main_refspec "$arg" && return 0
  done

  return 1
}

if [[ "${AGENT_NO_MERGE:-}" == "1" ]] && _blocks_git_push "$@"; then
  _deny
fi

_blocks_branch_switch() {
  local shim_dir
  shim_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local repo_root
  repo_root="$(cd "$shim_dir/../../.." && pwd)"

  "$repo_root/.venv/bin/python" -c '
import sys
import subprocess
from pathlib import Path

repo_root = sys.argv[1]
git_args = sys.argv[2:]

sys.path.insert(0, repo_root)
from scripts.guardrails.worktree_containment import is_primary_checkout, is_protected_branch, PROTECTED_BRANCHES

if not (is_primary_checkout() and is_protected_branch()):
    sys.exit(1)

if not git_args:
    sys.exit(1)

cmd = git_args[0]
if cmd not in ("checkout", "switch"):
    sys.exit(1)

creates_branch = any(arg in ("-b", "-B", "-c", "-C") for arg in git_args[1:])
if creates_branch:
    sys.exit(0)

target = None
for arg in git_args[1:]:
    if arg == "--":
        break
    if not arg.startswith("-"):
        target = arg
        break

if not target:
    sys.exit(1)

if target in PROTECTED_BRANCHES:
    sys.exit(1)

if cmd == "switch":
    if "--detach" not in git_args and "-d" not in git_args:
        sys.exit(0)
    sys.exit(1)

is_local = (subprocess.run(["git", "show-ref", "--verify", "--quiet", f"refs/heads/{target}"]).returncode == 0)
is_remote = (subprocess.run(["git", "show-ref", "--verify", "--quiet", f"refs/remotes/origin/{target}"]).returncode == 0)

if is_local or is_remote:
    target_idx = git_args.index(target)
    remaining_args = git_args[target_idx+1:]
    if "--" in remaining_args:
        sys.exit(1)
    has_file_args = False
    for arg in remaining_args:
        if not arg.startswith("-"):
            has_file_args = True
            break
    if has_file_args:
        sys.exit(1)
    sys.exit(0)

sys.exit(1)
' "$repo_root" "$@"
}

# INCIDENT 2026-07-05 (fork bomb): _blocks_branch_switch spawns a python guard whose
# worktree_containment._run_git calls bare "git" -> PATH resolves back to THIS shim ->
# guard again -> infinite bash+python chains until the per-user process limit (observed:
# ~2,200 stuck processes, machine-wide fork failures). Two independent breakers:
#   1. Bash-side pre-filter: the guard only concerns checkout/switch — never spawn the
#      python (which itself runs git) for any other subcommand.
#   2. AGENT_GIT_SHIM_GUARD_ACTIVE sentinel, FAIL-CLOSED (codex review msg 2014): the
#      guard's subtree only ever runs read-only plumbing (rev-parse/show-ref/ls-files),
#      which the pre-filter passes through. A checkout/switch arriving WITH the sentinel
#      set is therefore either recursion or spoofing — both are DENIED outright, without
#      spawning the guard python. Spoofing the sentinel strengthens the block; it cannot
#      bypass it. The push-deny above stays active regardless.
if [[ "${AGENT_NO_MERGE:-}" == "1" ]] && [[ "${1:-}" == "checkout" || "${1:-}" == "switch" ]]; then
  if [[ "${AGENT_GIT_SHIM_GUARD_ACTIVE:-}" == "1" ]]; then
    cat >&2 <<EOF
error: branch switch denied inside the containment guard's own subtree (fail-closed sentinel).
EOF
    exit 1
  elif AGENT_GIT_SHIM_GUARD_ACTIVE=1 _blocks_branch_switch "$@"; then
    cat >&2 <<EOF
error: agent cannot switch branches in the primary checkout.
       Create and cd into a dispatch worktree (.worktrees/dispatch/<agent>/<task>/) before switching branches.
EOF
    exit 1
  fi
fi

real_git="$(_real_git)" || {
  echo "error: could not locate the real git binary behind the agent shim." >&2
  exit 127
}

exec "$real_git" "$@"
